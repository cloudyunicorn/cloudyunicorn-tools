---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="BMI Calculator"
  description="Calculate your Body Mass Index (BMI) using metric or imperial units. Get instant classifications, ideal weight ranges, and health guides."
>
  <div class="relative min-h-[calc(100vh-16rem)] bg-background py-12">
    <div class="absolute inset-0 bg-grid-pattern bg-grid-fade pointer-events-none opacity-20"></div>

    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 space-y-12">
      <!-- Breadcrumbs -->
      <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-xs font-mono text-neutral-500">
        <a href="/" class="hover:text-neutral-600 dark:hover:text-neutral-300">Tools</a>
        <span>/</span>
        <span class="text-neutral-600 dark:text-neutral-300">BMI Calculator</span>
      </nav>

      <!-- Section Header -->
      <div class="space-y-4">
        <h1 class="text-3xl sm:text-5xl font-bold tracking-tight text-neutral-900 dark:text-white text-pretty">
          BMI Calculator
        </h1>
        <p class="text-neutral-400 max-w-xl text-sm sm:text-base">
          Quickly compute your Body Mass Index (BMI). Supports metric and imperial units, and provides healthy ranges customized for your height.
        </p>
      </div>

      <!-- Main Columns -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        <!-- Form Inputs (Left) -->
        <div class="lg:col-span-5 border border-neutral-200 dark:border-neutral-800 bg-neutral-50/50 dark:bg-neutral-900/30 backdrop-blur-sm rounded-xl p-6 space-y-6">
          <!-- Unit Toggle (Pill tabs) -->
          <div class="flex p-1 rounded-lg bg-neutral-100 dark:bg-[#0e0e0e] border border-neutral-200 dark:border-neutral-800" role="tablist" aria-label="Measurement Units">
            <button
              type="button"
              id="unit-metric"
              role="tab"
              aria-selected="true"
              aria-controls="panel-metric"
              class="flex-1 text-center text-xs font-semibold py-2 rounded-md transition-all outline-none border border-transparent text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white aria-selected:bg-white dark:aria-selected:bg-neutral-900 aria-selected:text-neutral-900 dark:aria-selected:text-white aria-selected:border-neutral-200 dark:aria-selected:border-neutral-800 aria-selected:shadow-sm dark:aria-selected:shadow-none"
            >
              Metric (cm, kg)
            </button>
            <button
              type="button"
              id="unit-imperial"
              role="tab"
              aria-selected="false"
              aria-controls="panel-imperial"
              class="flex-1 text-center text-xs font-semibold py-2 rounded-md transition-all outline-none border border-transparent text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white aria-selected:bg-white dark:aria-selected:bg-neutral-900 aria-selected:text-neutral-900 dark:aria-selected:text-white aria-selected:border-neutral-200 dark:aria-selected:border-neutral-800 aria-selected:shadow-sm dark:aria-selected:shadow-none"
            >
              Imperial (ft, lbs)
            </button>
          </div>

          <form id="bmi-form" class="space-y-5" novalidate>
            <!-- Metric Form Group -->
            <div id="panel-metric" role="tabpanel" class="space-y-5">
              <!-- Height (cm) -->
              <div class="space-y-2">
                <label for="height-metric" class="block text-xs font-mono text-neutral-500 dark:text-neutral-400 uppercase tracking-widest">
                  Height (cm) <span class="text-red-500" aria-hidden="true">*</span>
                </label>
                <div class="relative">
                  <input 
                    type="number" 
                    inputmode="numeric"
                    id="height-metric" 
                    name="heightMetric"
                    placeholder="e.g. 175…"
                    min="50"
                    max="300"
                    class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded-md h-11 pl-3 pr-12 text-sm text-neutral-900 dark:text-white focus:border-neutral-900 dark:focus:border-white focus:ring-1 focus:ring-neutral-900 dark:focus:ring-white outline-none transition-colors"
                  />
                  <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs font-mono text-neutral-400 dark:text-neutral-500">cm</span>
                </div>
                <span id="height-metric-error" class="hidden text-xs text-red-500 font-medium" role="alert"></span>
              </div>

              <!-- Weight (kg) -->
              <div class="space-y-2">
                <label for="weight-metric" class="block text-xs font-mono text-neutral-500 dark:text-neutral-400 uppercase tracking-widest">
                  Weight (kg) <span class="text-red-500" aria-hidden="true">*</span>
                </label>
                <div class="relative">
                  <input 
                    type="number" 
                    inputmode="numeric"
                    id="weight-metric" 
                    name="weightMetric"
                    placeholder="e.g. 70…"
                    min="10"
                    max="500"
                    class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded-md h-11 pl-3 pr-12 text-sm text-neutral-900 dark:text-white focus:border-neutral-900 dark:focus:border-white focus:ring-1 focus:ring-neutral-900 dark:focus:ring-white outline-none transition-colors"
                  />
                  <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs font-mono text-neutral-400 dark:text-neutral-500">kg</span>
                </div>
                <span id="weight-metric-error" class="hidden text-xs text-red-500 font-medium" role="alert"></span>
              </div>
            </div>

            <!-- Imperial Form Group (Hidden initially) -->
            <div id="panel-imperial" role="tabpanel" class="hidden space-y-5">
              <!-- Height (feet/inches) -->
              <div class="space-y-2">
                <span class="block text-xs font-mono text-neutral-500 dark:text-neutral-400 uppercase tracking-widest">
                  Height <span class="text-red-500" aria-hidden="true">*</span>
                </span>
                <div class="grid grid-cols-2 gap-3">
                  <div class="relative">
                    <label for="height-ft" class="sr-only">Height in Feet</label>
                    <input 
                      type="number" 
                      inputmode="numeric"
                      id="height-ft" 
                      name="heightFt"
                      placeholder="e.g. 5…"
                      min="1"
                      max="10"
                      class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded-md h-11 pl-3 pr-12 text-sm text-neutral-900 dark:text-white focus:border-neutral-900 dark:focus:border-white focus:ring-1 focus:ring-neutral-900 dark:focus:ring-white outline-none transition-colors"
                    />
                    <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs font-mono text-neutral-400 dark:text-neutral-500">ft</span>
                  </div>
                  <div class="relative">
                    <label for="height-in" class="sr-only">Height in Inches</label>
                    <input 
                      type="number" 
                      inputmode="numeric"
                      id="height-in" 
                      name="heightIn"
                      placeholder="e.g. 9…"
                      min="0"
                      max="11"
                      class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded-md h-11 pl-3 pr-12 text-sm text-neutral-900 dark:text-white focus:border-neutral-900 dark:focus:border-white focus:ring-1 focus:ring-neutral-900 dark:focus:ring-white outline-none transition-colors"
                    />
                    <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs font-mono text-neutral-400 dark:text-neutral-500">in</span>
                  </div>
                </div>
                <span id="height-imperial-error" class="hidden text-xs text-red-500 font-medium" role="alert"></span>
              </div>

              <!-- Weight (lbs) -->
              <div class="space-y-2">
                <label for="weight-lbs" class="block text-xs font-mono text-neutral-500 dark:text-neutral-400 uppercase tracking-widest">
                  Weight (lbs) <span class="text-red-500" aria-hidden="true">*</span>
                </label>
                <div class="relative">
                  <input 
                    type="number" 
                    inputmode="numeric"
                    id="weight-lbs" 
                    name="weightLbs"
                    placeholder="e.g. 150…"
                    min="10"
                    max="1000"
                    class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded-md h-11 pl-3 pr-12 text-sm text-neutral-900 dark:text-white focus:border-neutral-900 dark:focus:border-white focus:ring-1 focus:ring-neutral-900 dark:focus:ring-white outline-none transition-colors"
                  />
                  <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs font-mono text-neutral-400 dark:text-neutral-500">lbs</span>
                </div>
                <span id="weight-lbs-error" class="hidden text-xs text-red-500 font-medium" role="alert"></span>
              </div>
            </div>

            <!-- Submit Button -->
            <button
              type="submit"
              id="calc-btn"
              class="w-full h-11 bg-neutral-950 dark:bg-white text-white dark:text-black hover:bg-neutral-800 dark:hover:bg-neutral-200 transition-colors font-semibold text-sm rounded-md focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-neutral-950 dark:focus-visible:ring-white outline-none"
            >
              Calculate BMI
            </button>
          </form>
        </div>

        <!-- Output Display (Right) -->
        <div class="lg:col-span-7 space-y-6">
          <!-- Initial Prompt / Empty State -->
          <div id="empty-state" class="border border-neutral-200 dark:border-neutral-800 bg-neutral-50/10 dark:bg-neutral-900/10 rounded-xl p-12 text-center space-y-4">
            <svg class="w-12 h-12 text-neutral-400 dark:text-neutral-600 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 002 2h2a2 2 0 002-2z"></path>
            </svg>
            <div class="space-y-2">
              <h2 class="text-base font-semibold text-neutral-900 dark:text-white">No BMI calculated yet</h2>
              <p class="text-sm text-neutral-500 max-w-sm mx-auto">
                Select your system, fill in your weight and height parameters, and click calculate to view the category breakdown.
              </p>
            </div>
          </div>

          <!-- Calculation Results (Hidden by default) -->
          <div id="results-panel" class="hidden space-y-6">
            <!-- Primary BMI card -->
            <div class="border border-neutral-200 dark:border-neutral-850 bg-neutral-50/20 dark:bg-neutral-900/10 rounded-xl p-6 grid grid-cols-1 sm:grid-cols-2 gap-6 items-center">
              <div class="space-y-2">
                <h2 class="text-xs font-mono text-neutral-500 uppercase tracking-widest">Calculated BMI</h2>
                <div id="bmi-val" class="text-5xl sm:text-6xl font-bold font-mono text-neutral-900 dark:text-white text-glow tabular-nums">0.0</div>
                <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-neutral-100 dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800" id="category-badge">
                  <span class="w-2 h-2 rounded-full" id="category-dot"></span>
                  <span id="category-text" class="text-neutral-900 dark:text-white">Normal Weight</span>
                </div>
              </div>

              <!-- Ideal Weight Card -->
              <div class="border border-neutral-200 dark:border-neutral-800 bg-neutral-100/50 dark:bg-neutral-950/40 rounded-lg p-4 space-y-2">
                <h3 class="text-xs font-mono text-neutral-500 uppercase tracking-widest">Healthy Targets</h3>
                <p class="text-xs text-neutral-500 dark:text-neutral-400">Recommended range for your height:</p>
                <div id="ideal-range" class="text-lg font-semibold text-neutral-900 dark:text-white font-mono tabular-nums">0.0 - 0.0 kg</div>
              </div>
            </div>

            <!-- Sleek Horizontal BMI Spectrum Gauge -->
            <div class="border border-neutral-200 dark:border-neutral-800 bg-neutral-50/20 dark:bg-neutral-900/20 rounded-xl p-6 space-y-4">
              <h3 class="text-xs font-mono text-neutral-500 uppercase tracking-widest">BMI Classification Scale</h3>
              
              <div class="space-y-6">
                <!-- Bar Spectrum -->
                <div class="relative pt-6">
                  <!-- Active Indicator Marker -->
                  <div 
                    id="spectrum-marker" 
                    class="absolute top-0 -translate-x-1/2 flex flex-col items-center transition-all duration-500" 
                    style="left: 50%"
                  >
                    <span id="marker-val" class="text-[11px] font-bold font-mono text-neutral-900 dark:text-white bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-700 px-1.5 py-0.5 rounded leading-none shadow-md">24.5</span>
                    <span class="w-1.5 h-1.5 bg-neutral-100 dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-900 rotate-45 -mt-0.5 shadow-md"></span>
                  </div>

                  <!-- Color Bar Segment Blocks -->
                  <div class="h-2.5 rounded-full w-full flex overflow-hidden bg-neutral-200 dark:bg-neutral-800">
                    <div class="h-full bg-blue-500/80 w-[18.5%]" title="Underweight (< 18.5)"></div>
                    <div class="h-full bg-emerald-500/80 w-[25%]" title="Normal (18.5 - 24.9)"></div>
                    <div class="h-full bg-amber-500/80 w-[20%]" title="Overweight (25.0 - 29.9)"></div>
                    <div class="h-full bg-red-500/80 w-[36.5%]" title="Obese (>= 30.0)"></div>
                  </div>
                </div>

                <!-- Labels Grid -->
                <div class="grid grid-cols-4 text-[10px] font-mono text-neutral-500">
                  <div>
                    <span class="block text-neutral-400 font-bold">Underweight</span>
                    <span>&lt; 18.5</span>
                  </div>
                  <div class="text-center">
                    <span class="block text-neutral-400 font-bold">Normal</span>
                    <span>18.5 – 24.9</span>
                  </div>
                  <div class="text-center">
                    <span class="block text-neutral-400 font-bold">Overweight</span>
                    <span>25.0 – 29.9</span>
                  </div>
                  <div class="text-right">
                    <span class="block text-neutral-400 font-bold">Obese</span>
                    <span>&ge; 30.0</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Health Information Advice Block -->
            <div id="advice-card" class="border border-neutral-200 dark:border-neutral-800 bg-neutral-50/10 dark:bg-neutral-900/10 rounded-xl p-5 flex items-start gap-4">
              <div class="w-8 h-8 rounded bg-neutral-100 dark:bg-neutral-950 border border-neutral-200 dark:border-neutral-800 flex items-center justify-center text-neutral-900 dark:text-white shrink-0" aria-hidden="true">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <div class="space-y-1 text-sm">
                <h4 class="font-semibold text-neutral-900 dark:text-white" id="advice-title">Recommendations</h4>
                <p class="text-neutral-500 dark:text-neutral-400 text-xs sm:text-sm leading-relaxed" id="advice-text">
                  Calculating BMI provides a general health indicator, but does not measure body fat directly. Consult with a medical professional regarding your body composition metrics.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Client-side calculations and interface management
    function initBmiCalculator() {
      let activeUnit: 'metric' | 'imperial' = 'metric';

      const btnMetric = document.getElementById('unit-metric') as HTMLButtonElement;
      const btnImperial = document.getElementById('unit-imperial') as HTMLButtonElement;
      const bmiForm = document.getElementById('bmi-form') as HTMLFormElement;

      if (!bmiForm) return; // Exit if not on BMI calculator page
      
      const panelMetric = document.getElementById('panel-metric') as HTMLDivElement;
      const panelImperial = document.getElementById('panel-imperial') as HTMLDivElement;

      // Metric Fields
      const heightMetric = document.getElementById('height-metric') as HTMLInputElement;
      const weightMetric = document.getElementById('weight-metric') as HTMLInputElement;
      const heightMetricErr = document.getElementById('height-metric-error') as HTMLSpanElement;
      const weightMetricErr = document.getElementById('weight-metric-error') as HTMLSpanElement;

      // Imperial Fields
      const heightFt = document.getElementById('height-ft') as HTMLInputElement;
      const heightIn = document.getElementById('height-in') as HTMLInputElement;
      const weightLbs = document.getElementById('weight-lbs') as HTMLInputElement;
      const heightImpErr = document.getElementById('height-imperial-error') as HTMLSpanElement;
      const weightLbsErr = document.getElementById('weight-lbs-error') as HTMLSpanElement;

      // Result Nodes
      const emptyState = document.getElementById('empty-state') as HTMLDivElement;
      const resultsPanel = document.getElementById('results-panel') as HTMLDivElement;
      const bmiVal = document.getElementById('bmi-val') as HTMLDivElement;
      const categoryBadge = document.getElementById('category-badge') as HTMLDivElement;
      const categoryDot = document.getElementById('category-dot') as HTMLSpanElement;
      const categoryText = document.getElementById('category-text') as HTMLSpanElement;
      const idealRange = document.getElementById('ideal-range') as HTMLDivElement;

      const spectrumMarker = document.getElementById('spectrum-marker') as HTMLDivElement;
      const markerVal = document.getElementById('marker-val') as HTMLSpanElement;

      const adviceTitle = document.getElementById('advice-title') as HTMLHeadingElement;
      const adviceText = document.getElementById('advice-text') as HTMLParagraphElement;

      // Switch Tab Panels
      function switchUnit(unit: 'metric' | 'imperial') {
        activeUnit = unit;
        if (unit === 'metric') {
          btnMetric.setAttribute('aria-selected', 'true');
          btnImperial.setAttribute('aria-selected', 'false');
          panelMetric.classList.remove('hidden');
          panelImperial.classList.add('hidden');
        } else {
          btnImperial.setAttribute('aria-selected', 'true');
          btnMetric.setAttribute('aria-selected', 'false');
          panelImperial.classList.remove('hidden');
          panelMetric.classList.add('hidden');
        }
      }

      btnMetric.addEventListener('click', () => switchUnit('metric'));
      btnImperial.addEventListener('click', () => switchUnit('imperial'));

      // Handle Calculation
      bmiForm.addEventListener('submit', (e) => {
        e.preventDefault();

        // Reset errors
        heightMetricErr.classList.add('hidden');
        weightMetricErr.classList.add('hidden');
        heightImpErr.classList.add('hidden');
        weightLbsErr.classList.add('hidden');

        let heightMeters = 0;
        let weightKg = 0;
        let isValid = true;

        if (activeUnit === 'metric') {
          const hVal = parseFloat(heightMetric.value);
          const wVal = parseFloat(weightMetric.value);

          if (!hVal || hVal < 50 || hVal > 300) {
            heightMetricErr.textContent = 'Please enter a valid height between 50 and 300 cm.';
            heightMetricErr.classList.remove('hidden');
            heightMetric.focus();
            isValid = false;
          }

          if (!wVal || wVal < 10 || wVal > 500) {
            weightMetricErr.textContent = 'Please enter a valid weight between 10 and 500 kg.';
            weightMetricErr.classList.remove('hidden');
            if (isValid) weightMetric.focus();
            isValid = false;
          }

          if (!isValid) return;

          heightMeters = hVal / 100;
          weightKg = wVal;
        } else {
          const ft = parseFloat(heightFt.value) || 0;
          const inch = parseFloat(heightIn.value) || 0;
          const wLbs = parseFloat(weightLbs.value);

          const totalInches = (ft * 12) + inch;

          if (totalInches < 20 || totalInches > 120) {
            heightImpErr.textContent = 'Please enter a valid height (between 1ft 8in and 10ft).';
            heightImpErr.classList.remove('hidden');
            heightFt.focus();
            isValid = false;
          }

          if (!wLbs || wLbs < 20 || wLbs > 1000) {
            weightLbsErr.textContent = 'Please enter a valid weight between 20 and 1000 lbs.';
            weightLbsErr.classList.remove('hidden');
            if (isValid) weightLbs.focus();
            isValid = false;
          }

          if (!isValid) return;

          heightMeters = totalInches * 0.0254; // inch to meters
          weightKg = wLbs * 0.45359237; // lbs to kg
        }

        // Math
        const bmi = weightKg / (heightMeters * heightMeters);
        const bmiRounded = Math.round(bmi * 10) / 10;

        // Classify
        let category = '';
        let colorClass = '';
        let borderClass = '';
        let dotBg = '';
        let adviceTitleStr = '';
        let adviceTextStr = '';

        if (bmi < 18.5) {
          category = 'Underweight';
          colorClass = 'text-blue-600 dark:text-blue-400 bg-blue-500/5';
          borderClass = 'border-blue-500/20 dark:border-blue-500/10';
          dotBg = 'bg-blue-600 dark:bg-blue-400';
          adviceTitleStr = 'Underweight Recommendations';
          adviceTextStr = 'Focus on nutrient-dense foods, lean protein, healthy fats, and strength exercises to build healthy muscle mass.';
        } else if (bmi >= 18.5 && bmi <= 24.9) {
          category = 'Normal Weight';
          colorClass = 'text-emerald-600 dark:text-emerald-400 bg-emerald-500/5';
          borderClass = 'border-emerald-500/20 dark:border-emerald-500/10';
          dotBg = 'bg-emerald-600 dark:bg-emerald-400';
          adviceTitleStr = 'Optimal Weight Range';
          adviceTextStr = 'Excellent work. Maintain your current lifestyle, focusing on a balanced diet of whole foods and at least 150 minutes of exercise per week.';
        } else if (bmi >= 25.0 && bmi <= 29.9) {
          category = 'Overweight';
          colorClass = 'text-amber-600 dark:text-amber-400 bg-amber-500/5';
          borderClass = 'border-amber-500/20 dark:border-amber-500/10';
          dotBg = 'bg-amber-600 dark:bg-amber-400';
          adviceTitleStr = 'Overweight Recommendations';
          adviceTextStr = 'Consider slight calorie deficits alongside a blend of aerobic cardio and resistance training. Emphasize fibers and unprocessed items.';
        } else {
          category = 'Obese';
          colorClass = 'text-red-600 dark:text-red-400 bg-red-500/5';
          borderClass = 'border-red-500/20 dark:border-red-500/10';
          dotBg = 'bg-red-600 dark:bg-red-400';
          adviceTitleStr = 'Clinical Health Advice';
          adviceTextStr = 'Consult with a practitioner or nutritionist to design a sustainable nutrition and physical plan that supports cardiovascular health and joint integrity.';
        }

        // Update values
        emptyState.classList.add('hidden');
        resultsPanel.classList.remove('hidden');

        bmiVal.textContent = bmiRounded.toFixed(1);
        
        // Update badge styling classes
        categoryBadge.className = `inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold border ${colorClass} ${borderClass}`;
        categoryDot.className = `w-2 h-2 rounded-full ${dotBg}`;
        categoryText.textContent = category;

        // Ideal range targets: Healthy BMI is defined as 18.5 to 24.9
        const minIdealKg = 18.5 * (heightMeters * heightMeters);
        const maxIdealKg = 24.9 * (heightMeters * heightMeters);

        if (activeUnit === 'metric') {
          idealRange.textContent = `${Math.round(minIdealKg)} – ${Math.round(maxIdealKg)} kg`;
        } else {
          const minLbs = minIdealKg * 2.20462;
          const maxLbs = maxIdealKg * 2.20462;
          idealRange.textContent = `${Math.round(minLbs)} – ${Math.round(maxLbs)} lbs`;
        }

        // Calculate indicator slider position: BMI scale ranges from 15 to 40 roughly
        const minScale = 15;
        const maxScale = 40;
        let percentage = ((bmi - minScale) / (maxScale - minScale)) * 100;
        if (percentage < 0) percentage = 0;
        if (percentage > 100) percentage = 100;

        spectrumMarker.style.left = `${percentage}%`;
        markerVal.textContent = bmiRounded.toFixed(1);

        // Advice Box
        adviceTitle.textContent = adviceTitleStr;
        adviceText.textContent = adviceTextStr;
      });
    }

    // Initialize on page load and swaps
    document.addEventListener('astro:page-load', initBmiCalculator);
  </script>
</Layout>
