---
import Layout from '../layouts/Layout.astro';

// Generate height & weight chart rows dynamically (3'0" to 7'6" in 2-inch increments)
const heightRows = [];
for (let inches = 36; inches <= 90; inches += 2) {
  const ft = Math.floor(inches / 12);
  const inch = inches % 12;
  const cm = Math.round(inches * 2.54);
  const hM = inches * 0.0254;

  const whoMin = 18.5 * hM * hM;
  const whoMax = 24.9 * hM * hM;

  // Ideal Men Range based on balanced BMI curves (representing median health risk profile)
  const menMin = 22.0 * hM * hM;
  const menMax = 28.0 * hM * hM;

  // Ideal Women Range based on balanced BMI curves
  const womenMin = 20.0 * hM * hM;
  const womenMax = 26.0 * hM * hM;

  heightRows.push({
    heightStr: `${ft}'${inch}" (${cm} cm)`,
    who: `${whoMin.toFixed(1)} – ${whoMax.toFixed(1)} kg / ${Math.round(whoMin * 2.20462)} – ${Math.round(whoMax * 2.20462)} lbs`,
    men: `${menMin.toFixed(1)} – ${menMax.toFixed(1)} kg / ${Math.round(menMin * 2.20462)} – ${Math.round(menMax * 2.20462)} lbs`,
    women: `${womenMin.toFixed(1)} – ${womenMax.toFixed(1)} kg / ${Math.round(womenMin * 2.20462)} – ${Math.round(womenMax * 2.20462)} lbs`
  });
}
---

<Layout 
  title="BMI Calculator — Body Mass Index"
  description="Calculate your Body Mass Index (BMI) online using metric (kg) or imperial (lbs) units. Get your ideal weight range, BMI scale category, and healthy body weight charts."
>
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "BMI Calculator",
      "url": "https://www.cloudyunicorn.com/bmi-calculator",
      "applicationCategory": "HealthApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "description": "Compute your Body Mass Index (BMI) instantly. Supports Metric and Imperial standards, and provides a clear graphical classification scale.",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    }
  </script>

  <div class="relative min-h-[calc(100vh-16rem)] bg-background py-12">
    <div class="absolute inset-0 bg-grid-pattern bg-grid-fade pointer-events-none opacity-20"></div>

    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 space-y-12">
      <!-- Breadcrumbs -->
      <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-xs font-mono text-neutral-500">
        <a href="/" class="hover:text-neutral-600 dark:hover:text-neutral-300">Tools</a>
        <span>/</span>
        <span class="text-neutral-600 dark:text-neutral-300">BMI Calculator</span>
      </nav>

      <!-- Section Header -->
      <div class="space-y-4">
        <h1 class="text-3xl sm:text-5xl font-bold tracking-tight text-neutral-900 dark:text-white text-pretty">
          BMI Calculator
        </h1>
        <p class="text-neutral-400 max-w-xl text-sm sm:text-base">
          Quickly compute your Body Mass Index (BMI). Supports metric and imperial units, and provides healthy ranges customized for your height.
        </p>
      </div>

      <!-- Main Columns -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        <!-- Form Inputs (Left) -->
        <div class="lg:col-span-5 premium-glass-card rounded-xl p-6 space-y-6">
          <!-- Unit Toggle (Pill tabs) -->
          <div class="flex p-1 rounded-lg bg-neutral-100 dark:bg-[#0e0e0e] border border-neutral-200 dark:border-neutral-800" role="tablist" aria-label="Measurement Units">
            <button
              type="button"
              id="unit-metric"
              role="tab"
              aria-selected="true"
              aria-controls="panel-metric"
              class="flex-1 text-center text-xs font-semibold py-2 rounded-md transition-all outline-none border border-transparent text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white aria-selected:bg-neutral-50 dark:aria-selected:bg-neutral-900 aria-selected:text-neutral-900 dark:aria-selected:text-white aria-selected:border-neutral-200 dark:aria-selected:border-neutral-800 aria-selected:shadow-sm dark:aria-selected:shadow-none"
            >
              Metric (cm, kg)
            </button>
            <button
              type="button"
              id="unit-imperial"
              role="tab"
              aria-selected="false"
              aria-controls="panel-imperial"
              class="flex-1 text-center text-xs font-semibold py-2 rounded-md transition-all outline-none border border-transparent text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white aria-selected:bg-neutral-50 dark:aria-selected:bg-neutral-900 aria-selected:text-neutral-900 dark:aria-selected:text-white aria-selected:border-neutral-200 dark:aria-selected:border-neutral-800 aria-selected:shadow-sm dark:aria-selected:shadow-none"
            >
              Imperial (ft, lbs)
            </button>
          </div>

          <form id="bmi-form" class="space-y-5" novalidate>
            <!-- Metric Form Group -->
            <div id="panel-metric" role="tabpanel" class="space-y-5">
              <!-- Height (cm) -->
              <div class="space-y-2">
                <label for="height-metric" class="block text-xs font-mono text-neutral-500 dark:text-neutral-400 uppercase tracking-widest">
                  Height (cm) <span class="text-red-500" aria-hidden="true">*</span>
                </label>
                <div class="relative">
                  <input 
                    type="number" 
                    inputmode="numeric"
                    id="height-metric" 
                    name="heightMetric"
                    placeholder="e.g. 175…"
                    min="30"
                    max="300"
                    class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded-md h-11 pl-3 pr-12 text-sm text-neutral-900 dark:text-white focus:border-neutral-900 dark:focus:border-white focus:ring-1 focus:ring-neutral-900 dark:focus:ring-white outline-none transition-colors"
                  />
                  <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs font-mono text-neutral-400 dark:text-neutral-500">cm</span>
                </div>
                <span id="height-metric-error" class="hidden text-xs text-red-700 dark:text-red-400 font-medium" role="alert"></span>
              </div>

              <!-- Weight (kg) -->
              <div class="space-y-2">
                <label for="weight-metric" class="block text-xs font-mono text-neutral-500 dark:text-neutral-400 uppercase tracking-widest">
                  Weight (kg) <span class="text-red-500" aria-hidden="true">*</span>
                </label>
                <div class="relative">
                  <input 
                    type="number" 
                    inputmode="numeric"
                    id="weight-metric" 
                    name="weightMetric"
                    placeholder="e.g. 70…"
                    min="10"
                    max="500"
                    class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded-md h-11 pl-3 pr-12 text-sm text-neutral-900 dark:text-white focus:border-neutral-900 dark:focus:border-white focus:ring-1 focus:ring-neutral-900 dark:focus:ring-white outline-none transition-colors"
                  />
                  <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs font-mono text-neutral-400 dark:text-neutral-500">kg</span>
                </div>
                <span id="weight-metric-error" class="hidden text-xs text-red-700 dark:text-red-400 font-medium" role="alert"></span>
              </div>
            </div>

            <!-- Imperial Form Group (Hidden initially) -->
            <div id="panel-imperial" role="tabpanel" class="hidden space-y-5">
              <!-- Height (feet/inches) -->
              <div class="space-y-2">
                <span class="block text-xs font-mono text-neutral-500 dark:text-neutral-400 uppercase tracking-widest">
                  Height <span class="text-red-500" aria-hidden="true">*</span>
                </span>
                <div class="grid grid-cols-2 gap-3">
                  <div class="relative">
                    <label for="height-ft" class="sr-only">Height in Feet</label>
                    <input 
                      type="number" 
                      inputmode="numeric"
                      id="height-ft" 
                      name="heightFt"
                      placeholder="e.g. 5…"
                      min="1"
                      max="10"
                      class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded-md h-11 pl-3 pr-12 text-sm text-neutral-900 dark:text-white focus:border-neutral-900 dark:focus:border-white focus:ring-1 focus:ring-neutral-900 dark:focus:ring-white outline-none transition-colors"
                    />
                    <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs font-mono text-neutral-400 dark:text-neutral-500">ft</span>
                  </div>
                  <div class="relative">
                    <label for="height-in" class="sr-only">Height in Inches</label>
                    <input 
                      type="number" 
                      inputmode="numeric"
                      id="height-in" 
                      name="heightIn"
                      placeholder="e.g. 9…"
                      min="0"
                      max="11"
                      class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded-md h-11 pl-3 pr-12 text-sm text-neutral-900 dark:text-white focus:border-neutral-900 dark:focus:border-white focus:ring-1 focus:ring-neutral-900 dark:focus:ring-white outline-none transition-colors"
                    />
                    <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs font-mono text-neutral-400 dark:text-neutral-500">in</span>
                  </div>
                </div>
                <span id="height-imperial-error" class="hidden text-xs text-red-700 dark:text-red-400 font-medium" role="alert"></span>
              </div>

              <!-- Weight (lbs) -->
              <div class="space-y-2">
                <label for="weight-lbs" class="block text-xs font-mono text-neutral-500 dark:text-neutral-400 uppercase tracking-widest">
                  Weight (lbs) <span class="text-red-500" aria-hidden="true">*</span>
                </label>
                <div class="relative">
                  <input 
                    type="number" 
                    inputmode="numeric"
                    id="weight-lbs" 
                    name="weightLbs"
                    placeholder="e.g. 150…"
                    min="10"
                    max="1000"
                    class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded-md h-11 pl-3 pr-12 text-sm text-neutral-900 dark:text-white focus:border-neutral-900 dark:focus:border-white focus:ring-1 focus:ring-neutral-900 dark:focus:ring-white outline-none transition-colors"
                  />
                  <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs font-mono text-neutral-400 dark:text-neutral-500">lbs</span>
                </div>
                <span id="weight-lbs-error" class="hidden text-xs text-red-700 dark:text-red-400 font-medium" role="alert"></span>
              </div>
            </div>

            <!-- Submit Button -->
            <button
              type="submit"
              id="calc-btn"
              class="w-full h-11 bg-neutral-950 dark:bg-white text-white dark:text-black hover:bg-neutral-800 dark:hover:bg-neutral-200 transition-colors font-semibold text-sm rounded-md focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-neutral-950 dark:focus-visible:ring-white outline-none"
            >
              Calculate BMI
            </button>
          </form>
        </div>

        <!-- Output Display (Right) -->
        <div class="lg:col-span-7 space-y-6">
          <!-- Initial Prompt / Empty State (Muted skeleton mode placeholder) -->
          <div id="empty-state" class="hidden"></div>

          <!-- Calculation Results (Muted dashboard footprint by default) -->
          <div id="results-panel" class="space-y-6 opacity-40 pointer-events-none select-none transition-all duration-500">
            <!-- Awaiting Input Status Banner -->
            <div id="dashboard-status-banner" class="border border-dashed border-neutral-300 dark:border-neutral-700 bg-neutral-50/50 dark:bg-neutral-900/30 rounded-xl p-4 text-center text-xs font-mono text-neutral-505 flex items-center justify-center gap-2">
              <span class="inline-block w-2 h-2 rounded-full bg-neutral-400 dark:bg-neutral-600 animate-pulse"></span>
              AWAITING PARAMETERS — CLICK CALCULATE TO POPULATE
            </div>

            <!-- Primary BMI card -->
            <div class="premium-glass-card rounded-xl p-6 grid grid-cols-1 sm:grid-cols-2 gap-6 items-center">
              <div class="space-y-2">
                <h2 class="text-xs font-mono text-neutral-505 uppercase tracking-widest">Calculated BMI</h2>
                <div id="bmi-val" class="text-5xl sm:text-6xl font-bold font-mono text-neutral-900 dark:text-white text-glow tabular-nums">—</div>
                <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-neutral-100 dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800" id="category-badge">
                  <span class="w-2 h-2 rounded-full" id="category-dot"></span>
                  <span id="category-text" class="text-neutral-900 dark:text-white">—</span>
                </div>
              </div>

              <!-- Ideal Weight Card -->
              <div class="premium-glass-card-subtle rounded-lg p-4 space-y-2">
                <h3 class="text-xs font-mono text-neutral-505 uppercase tracking-widest">Healthy Targets</h3>
                <p class="text-xs text-neutral-500 dark:text-neutral-450">Recommended range for your height:</p>
                <div id="ideal-range" class="text-lg font-semibold text-neutral-900 dark:text-white font-mono tabular-nums">— – — kg</div>
              </div>
            </div>

            <!-- Sleek Horizontal BMI Spectrum Gauge -->
            <div class="premium-glass-card rounded-xl p-6 space-y-4">
              <h3 class="text-xs font-mono text-neutral-500 uppercase tracking-widest">BMI Classification Scale</h3>
              
              <div class="space-y-6">
                <!-- Bar Spectrum -->
                <div class="relative pt-6">
                  <!-- Active Indicator Marker -->
                  <div 
                    id="spectrum-marker" 
                    class="absolute top-0 -translate-x-1/2 flex flex-col items-center transition-all duration-500 opacity-0" 
                    style="left: 50%"
                  >
                    <span id="marker-val" class="text-[11px] font-bold font-mono text-neutral-900 dark:text-white bg-neutral-50 dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-700 px-1.5 py-0.5 rounded leading-none shadow-md">—</span>
                    <span class="w-1.5 h-1.5 bg-neutral-50 dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-900 rotate-45 -mt-0.5 shadow-md"></span>
                  </div>

                  <!-- Color Bar Segment Blocks -->
                  <div class="h-2.5 rounded-full w-full flex overflow-hidden bg-neutral-200 dark:bg-neutral-800">
                    <div class="h-full bg-blue-500/80 w-[18.5%]" title="Underweight (< 18.5)"></div>
                    <div class="h-full bg-emerald-500/80 w-[25%]" title="Normal (18.5 - 24.9)"></div>
                    <div class="h-full bg-amber-500/80 w-[20%]" title="Overweight (25.0 - 29.9)"></div>
                    <div class="h-full bg-red-500/80 w-[36.5%]" title="Obese (>= 30.0)"></div>
                  </div>
                </div>

                <!-- Labels Grid -->
                <div class="grid grid-cols-4 text-[10px] font-mono text-neutral-500">
                  <div>
                    <span class="block text-neutral-400 font-bold">Underweight</span>
                    <span>&lt; 18.5</span>
                  </div>
                  <div class="text-center">
                    <span class="block text-neutral-400 font-bold">Normal</span>
                    <span>18.5 – 24.9</span>
                  </div>
                  <div class="text-center">
                    <span class="block text-neutral-400 font-bold">Overweight</span>
                    <span>25.0 – 29.9</span>
                  </div>
                  <div class="text-right">
                    <span class="block text-neutral-400 font-bold">Obese</span>
                    <span>&ge; 30.0</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Health Information Advice Block -->
            <div id="advice-card" class="border border-neutral-200 dark:border-neutral-800 bg-neutral-50/10 dark:bg-neutral-900/10 rounded-xl p-5 flex items-start gap-4">
              <div class="w-8 h-8 rounded bg-neutral-100 dark:bg-neutral-950 border border-neutral-200 dark:border-neutral-800 flex items-center justify-center text-neutral-900 dark:text-white shrink-0" aria-hidden="true">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <div class="space-y-1 text-sm">
                <h4 class="font-semibold text-neutral-900 dark:text-white" id="advice-title">Recommendations</h4>
                <p class="text-neutral-500 dark:text-neutral-400 text-xs sm:text-sm leading-relaxed" id="advice-text">
                  Calculating BMI provides a general health indicator, but does not measure body fat directly. Consult with a medical professional regarding your body composition metrics.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- BMI Reference Charts Section -->
      <section class="border-t border-neutral-200 dark:border-neutral-800 pt-12 space-y-6">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
          <div class="space-y-1">
            <h2 class="text-xl font-bold text-neutral-900 dark:text-white">
              BMI Reference Charts (Men &amp; Women)
            </h2>
            <p class="text-xs text-neutral-500 dark:text-neutral-400">
              Compare your BMI results against standard WHO classifications and gender-adjusted ideal ranges.
            </p>
          </div>
          
          <!-- Tab Selector -->
          <div class="flex p-1 rounded-lg bg-neutral-100 dark:bg-[#0e0e0e] border border-neutral-200 dark:border-neutral-800 w-full sm:w-80" role="tablist" aria-label="Chart Views">
            <button
              type="button"
              id="chart-tab-ranges"
              role="tab"
              aria-selected="true"
              aria-controls="chart-panel-ranges"
              class="flex-1 text-center text-[11px] font-semibold py-1.5 rounded-md transition-all outline-none border border-transparent text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white aria-selected:bg-neutral-50 dark:aria-selected:bg-neutral-900 aria-selected:text-neutral-900 dark:aria-selected:text-white aria-selected:border-neutral-200 dark:aria-selected:border-neutral-800 aria-selected:shadow-sm dark:aria-selected:shadow-none animate-fade-in"
            >
              BMI Classifications
            </button>
            <button
              type="button"
              id="chart-tab-table"
              role="tab"
              aria-selected="false"
              aria-controls="chart-panel-table"
              class="flex-1 text-center text-[11px] font-semibold py-1.5 rounded-md transition-all outline-none border border-transparent text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white aria-selected:bg-neutral-50 dark:aria-selected:bg-neutral-900 aria-selected:text-neutral-900 dark:aria-selected:text-white aria-selected:border-neutral-200 dark:aria-selected:border-neutral-800 aria-selected:shadow-sm dark:aria-selected:shadow-none animate-fade-in"
            >
              Height &amp; Weight Chart
            </button>
          </div>
        </div>

        <!-- Panel 1: Classifications Grid -->
        <div id="chart-panel-ranges" role="tabpanel" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <!-- Underweight -->
          <div class="border border-neutral-200 dark:border-neutral-800 bg-neutral-50/20 dark:bg-neutral-900/10 p-5 rounded-xl space-y-2">
            <div class="flex items-center justify-between">
              <span class="text-xs font-bold font-mono text-blue-700 uppercase tracking-wider">Underweight</span>
              <span class="text-xs font-mono font-semibold px-2 py-0.5 rounded bg-blue-500/10 text-blue-700 border border-blue-500/15">&lt; 18.5</span>
            </div>
            <p class="text-xs text-neutral-500 leading-relaxed">
              Below the optimal ratio. May indicate nutritional deficiencies, high metabolism, or other factors.
            </p>
            <div class="text-[10px] text-neutral-400 italic pt-1 border-t border-neutral-100 dark:border-neutral-900">
              Healthy target weight is typically higher.
            </div>
          </div>

          <!-- Normal -->
          <div class="border border-neutral-200 dark:border-neutral-800 bg-neutral-50/20 dark:bg-neutral-900/10 p-5 rounded-xl space-y-2">
            <div class="flex items-center justify-between">
              <span class="text-xs font-bold font-mono text-emerald-700 uppercase tracking-wider">Normal Range</span>
              <span class="text-xs font-mono font-semibold px-2 py-0.5 rounded bg-emerald-500/10 text-emerald-700 border border-emerald-500/15">18.5 – 24.9</span>
            </div>
            <p class="text-xs text-neutral-500 leading-relaxed">
              Associated with the lowest risk of cardiovascular issues and other metabolic conditions.
            </p>
            <div class="text-[10px] text-neutral-400 italic pt-1 border-t border-neutral-100 dark:border-neutral-900">
              Optimal weight range for general longevity.
            </div>
          </div>

          <!-- Overweight -->
          <div class="border border-neutral-200 dark:border-neutral-800 bg-neutral-50/20 dark:bg-neutral-900/10 p-5 rounded-xl space-y-2">
            <div class="flex items-center justify-between">
              <span class="text-xs font-bold font-mono text-amber-800 uppercase tracking-wider">Overweight</span>
              <span class="text-xs font-mono font-semibold px-2 py-0.5 rounded bg-amber-500/10 text-amber-800 border border-amber-500/15">25.0 – 29.9</span>
            </div>
            <p class="text-xs text-neutral-500 leading-relaxed">
              Increased body weight relative to height. Incorporating physical activity and balanced nutrition is recommended.
            </p>
            <div class="text-[10px] text-neutral-400 italic pt-1 border-t border-neutral-100 dark:border-neutral-900">
              Muscle mass in athletes can sometimes push scores here.
            </div>
          </div>

          <!-- Obese I -->
          <div class="border border-neutral-200 dark:border-neutral-800 bg-neutral-50/20 dark:bg-neutral-900/10 p-5 rounded-xl space-y-2">
            <div class="flex items-center justify-between">
              <span class="text-xs font-bold font-mono text-rose-700 uppercase tracking-wider">Obese Class I</span>
              <span class="text-xs font-mono font-semibold px-2 py-0.5 rounded bg-rose-500/10 text-rose-700 border border-rose-500/15">30.0 – 34.9</span>
            </div>
            <p class="text-xs text-neutral-500 leading-relaxed">
              Moderately high fat volume relative to height. Advised to evaluate health risks with a medical practitioner.
            </p>
          </div>

          <!-- Obese II -->
          <div class="border border-neutral-200 dark:border-neutral-800 bg-neutral-50/20 dark:bg-neutral-900/10 p-5 rounded-xl space-y-2">
            <div class="flex items-center justify-between">
              <span class="text-xs font-bold font-mono text-red-700 uppercase tracking-wider">Obese Class II</span>
              <span class="text-xs font-mono font-semibold px-2 py-0.5 rounded bg-red-500/10 text-red-700 border border-red-500/15">35.0 – 39.9</span>
            </div>
            <p class="text-xs text-neutral-500 leading-relaxed">
              High risk of obesity-related comorbidities (hypertension, diabetes, heart disease). Focus on metabolic health.
            </p>
          </div>

          <!-- Obese III -->
          <div class="border border-neutral-200 dark:border-neutral-800 bg-neutral-50/20 dark:bg-neutral-900/10 p-5 rounded-xl space-y-2">
            <div class="flex items-center justify-between">
              <span class="text-xs font-bold font-mono text-purple-700 uppercase tracking-wider">Obese Class III</span>
              <span class="text-xs font-mono font-semibold px-2 py-0.5 rounded bg-purple-500/10 text-purple-700 border border-purple-500/15">&ge; 40.0</span>
            </div>
            <p class="text-xs text-neutral-500 leading-relaxed">
              Severe/morbid obesity. Therapeutic lifestyle interventions, diet adjustments, or clinical consultations are recommended.
            </p>
          </div>

          <!-- Gender Differences Disclaimer -->
          <div class="sm:col-span-2 lg:col-span-3 border border-dashed border-neutral-200 dark:border-neutral-800 bg-neutral-50/10 dark:bg-neutral-900/5 p-4 rounded-xl flex items-start gap-3">
            <svg class="w-4 h-4 text-neutral-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <div class="text-[11px] text-neutral-500 dark:text-neutral-400 leading-relaxed">
              <strong>Understanding Gender Differences:</strong> Standard BMI calculations apply identically to adult men and women. However, because biological men generally carry higher muscle mass (which weighs more than fat) and biological women carry higher body fat proportions, your BMI score is a general estimate. Athletes, bodybuilders, or pregnant women should focus on body fat percentage or waist-to-hip measurements instead.
