  <script>
    // Client-side calculations and interface management
    function initBmiCalculator() {
      let activeUnit: 'metric' | 'imperial' = 'metric';

      const btnMetric = document.getElementById('unit-metric') as HTMLButtonElement;
      const btnImperial = document.getElementById('unit-imperial') as HTMLButtonElement;
      const bmiForm = document.getElementById('bmi-form') as HTMLFormElement;

      if (!bmiForm) return; // Exit if not on BMI calculator page
      
      const panelMetric = document.getElementById('panel-metric') as HTMLDivElement;
      const panelImperial = document.getElementById('panel-imperial') as HTMLDivElement;

      // Metric Fields
      const heightMetric = document.getElementById('height-metric') as HTMLInputElement;
      const weightMetric = document.getElementById('weight-metric') as HTMLInputElement;
      const heightMetricErr = document.getElementById('height-metric-error') as HTMLSpanElement;
      const weightMetricErr = document.getElementById('weight-metric-error') as HTMLSpanElement;

      // Imperial Fields
      const heightFt = document.getElementById('height-ft') as HTMLInputElement;
      const heightIn = document.getElementById('height-in') as HTMLInputElement;
      const weightLbs = document.getElementById('weight-lbs') as HTMLInputElement;
      const heightImpErr = document.getElementById('height-imperial-error') as HTMLSpanElement;
      const weightLbsErr = document.getElementById('weight-lbs-error') as HTMLSpanElement;

      // Result Nodes
      const emptyState = document.getElementById('empty-state') as HTMLDivElement;
      const resultsPanel = document.getElementById('results-panel') as HTMLDivElement;
      const bmiVal = document.getElementById('bmi-val') as HTMLDivElement;
      const categoryBadge = document.getElementById('category-badge') as HTMLDivElement;
      const categoryDot = document.getElementById('category-dot') as HTMLSpanElement;
      const categoryText = document.getElementById('category-text') as HTMLSpanElement;
      const idealRange = document.getElementById('ideal-range') as HTMLDivElement;

      const spectrumMarker = document.getElementById('spectrum-marker') as HTMLDivElement;
      const markerVal = document.getElementById('marker-val') as HTMLSpanElement;

      const adviceTitle = document.getElementById('advice-title') as HTMLHeadingElement;
      const adviceText = document.getElementById('advice-text') as HTMLParagraphElement;

      // Switch Tab Panels
      function switchUnit(unit: 'metric' | 'imperial') {
        activeUnit = unit;
        if (unit === 'metric') {
          btnMetric.setAttribute('aria-selected', 'true');
          btnImperial.setAttribute('aria-selected', 'false');
          panelMetric.classList.remove('hidden');
          panelImperial.classList.add('hidden');
        } else {
          btnImperial.setAttribute('aria-selected', 'true');
          btnMetric.setAttribute('aria-selected', 'false');
          panelImperial.classList.remove('hidden');
          panelMetric.classList.add('hidden');
        }
      }

      btnMetric.addEventListener('click', () => switchUnit('metric'));
      btnImperial.addEventListener('click', () => switchUnit('imperial'));

      // BMI Reference Chart Tabs
      const tabRanges = document.getElementById('chart-tab-ranges') as HTMLButtonElement;
      const tabTable = document.getElementById('chart-tab-table') as HTMLButtonElement;
      const panelRanges = document.getElementById('chart-panel-ranges') as HTMLDivElement;
      const panelTable = document.getElementById('chart-panel-table') as HTMLDivElement;

      if (tabRanges && tabTable && panelRanges && panelTable) {
        tabRanges.addEventListener('click', () => {
          tabRanges.setAttribute('aria-selected', 'true');
          tabTable.setAttribute('aria-selected', 'false');
          panelRanges.classList.remove('hidden');
          panelTable.classList.add('hidden');
        });
        tabTable.addEventListener('click', () => {
          tabTable.setAttribute('aria-selected', 'true');
          tabRanges.setAttribute('aria-selected', 'false');
          panelTable.classList.remove('hidden');
          panelRanges.classList.add('hidden');
        });
      }

      // Handle Calculation
      bmiForm.addEventListener('submit', (e) => {
        e.preventDefault();

        // Reset errors
        heightMetricErr.classList.add('hidden');
        weightMetricErr.classList.add('hidden');
        heightImpErr.classList.add('hidden');
        weightLbsErr.classList.add('hidden');

        let heightMeters = 0;
        let weightKg = 0;
        let isValid = true;

        if (activeUnit === 'metric') {
          const hVal = parseFloat(heightMetric.value);
          const wVal = parseFloat(weightMetric.value);

          if (!hVal || hVal < 30 || hVal > 300) {
            heightMetricErr.textContent = 'Please enter a valid height between 30 and 300 cm.';
            heightMetricErr.classList.remove('hidden');
            heightMetric.focus();
            isValid = false;
          }

          if (!wVal || wVal < 10 || wVal > 500) {
            weightMetricErr.textContent = 'Please enter a valid weight between 10 and 500 kg.';
            weightMetricErr.classList.remove('hidden');
            if (isValid) weightMetric.focus();
            isValid = false;
          }

          if (!isValid) return;

          heightMeters = hVal / 100;
          weightKg = wVal;
        } else {
          const ft = parseFloat(heightFt.value) || 0;
          const inch = parseFloat(heightIn.value) || 0;
          const wLbs = parseFloat(weightLbs.value);

          const totalInches = (ft * 12) + inch;

          if (totalInches < 12 || totalInches > 120) {
            heightImpErr.textContent = 'Please enter a valid height (between 1ft 0in and 10ft).';
            heightImpErr.classList.remove('hidden');
            heightFt.focus();
            isValid = false;
          }

          if (!wLbs || wLbs < 20 || wLbs > 1000) {
            weightLbsErr.textContent = 'Please enter a valid weight between 20 and 1000 lbs.';
            weightLbsErr.classList.remove('hidden');
            if (isValid) weightLbs.focus();
            isValid = false;
          }

          if (!isValid) return;

          heightMeters = totalInches * 0.0254; // inch to meters
          weightKg = wLbs * 0.45359237; // lbs to kg
        }

        // Math
        const bmi = weightKg / (heightMeters * heightMeters);
        const bmiRounded = Math.round(bmi * 10) / 10;

        // Classify
        let category = '';
        let colorClass = '';
        let borderClass = '';
        let dotBg = '';
        let adviceTitleStr = '';
        let adviceTextStr = '';

        if (bmi < 18.5) {
          category = 'Underweight';
          colorClass = 'text-blue-700 bg-blue-500/5';
          borderClass = 'border-blue-500/20';
          dotBg = 'bg-blue-700';
          adviceTitleStr = 'Underweight Recommendations';
          adviceTextStr = 'Focus on nutrient-dense foods, lean protein, healthy fats, and strength exercises to build healthy muscle mass.';
        } else if (bmi >= 18.5 && bmi <= 24.9) {
          category = 'Normal Weight';
          colorClass = 'text-emerald-700 bg-emerald-500/5';
          borderClass = 'border-emerald-500/20';
          dotBg = 'bg-emerald-700';
          adviceTitleStr = 'Optimal Weight Range';
          adviceTextStr = 'Excellent work. Maintain your current lifestyle, focusing on a balanced diet of whole foods and at least 150 minutes of exercise per week.';
        } else if (bmi >= 25.0 && bmi <= 29.9) {
          category = 'Overweight';
          colorClass = 'text-amber-800 bg-amber-500/5';
          borderClass = 'border-amber-500/20';
          dotBg = 'bg-amber-800';
          adviceTitleStr = 'Overweight Recommendations';
          adviceTextStr = 'Consider slight calorie deficits alongside a blend of aerobic cardio and resistance training. Emphasize fibers and unprocessed items.';
        } else {
          category = 'Obese';
          colorClass = 'text-red-700 bg-red-500/5';
          borderClass = 'border-red-500/20';
          dotBg = 'bg-red-700';
          adviceTitleStr = 'Clinical Health Advice';
          adviceTextStr = 'Consult with a practitioner or nutritionist to design a sustainable nutrition and physical plan that supports cardiovascular health and joint integrity.';
        }

        // Update values
        if (emptyState) emptyState.classList.add('hidden');
        if (resultsPanel) {
          resultsPanel.classList.remove('opacity-40', 'pointer-events-none', 'select-none');
        }
        const statusBanner = document.getElementById('dashboard-status-banner');
        if (statusBanner) {
          statusBanner.classList.add('hidden');
        }
        if (spectrumMarker) {
          spectrumMarker.classList.remove('opacity-0');
        }

        bmiVal.textContent = bmiRounded.toFixed(1);
        
        // Update badge styling classes
        categoryBadge.className = `inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold border ${colorClass} ${borderClass}`;
        categoryDot.className = `w-2 h-2 rounded-full ${dotBg}`;
        categoryText.textContent = category;

        // Ideal range targets: Healthy BMI is defined as 18.5 to 24.9
        const minIdealKg = 18.5 * (heightMeters * heightMeters);
        const maxIdealKg = 24.9 * (heightMeters * heightMeters);

        if (activeUnit === 'metric') {
          idealRange.textContent = `${Math.round(minIdealKg)} – ${Math.round(maxIdealKg)} kg`;
        } else {
          const minLbs = minIdealKg * 2.20462;
          const maxLbs = maxIdealKg * 2.20462;
          idealRange.textContent = `${Math.round(minLbs)} – ${Math.round(maxLbs)} lbs`;
        }

        // Calculate indicator slider position: BMI scale ranges from 15 to 40 roughly
        const minScale = 15;
        const maxScale = 40;
        let percentage = ((bmi - minScale) / (maxScale - minScale)) * 100;
        if (percentage < 0) percentage = 0;
        if (percentage > 100) percentage = 100;

        spectrumMarker.style.left = `${percentage}%`;
        markerVal.textContent = bmiRounded.toFixed(1);

        // Advice Box
        adviceTitle.textContent = adviceTitleStr;
        adviceText.textContent = adviceTextStr;
      });
    }

    // Initialize on page load and swaps
    document.addEventListener('astro:page-load', initBmiCalculator);
  </script>
</Layout>
