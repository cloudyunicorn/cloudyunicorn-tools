---
import Layout from '../layouts/Layout.astro';
import SocialShare from '../components/SocialShare.astro';
---

<Layout 
  title="Days Between Dates Calculator | Business Day Counter"
  description="Free online date calculator to count days between two dates, calculate business days, and add or subtract offsets from a starting base date."
>
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Days Between Two Dates Calculator",
      "url": "https://www.cloudyunicorn.com/days-calculator",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "description": "Calculate date durations, total days, business days excluding weekends and US holidays, and add/subtract offsets from a starting date.",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    }
  </script>

  <div class="relative min-h-[calc(100vh-16rem)] bg-background py-12">
    <div class="absolute inset-0 bg-grid-pattern bg-grid-fade pointer-events-none opacity-20"></div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 space-y-12">
      <!-- Breadcrumbs -->
      <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-xs font-mono text-neutral-500">
        <a href="/" class="hover:text-neutral-600 dark:hover:text-neutral-300">Tools</a>
        <span>/</span>
        <span class="text-neutral-600 dark:text-neutral-300">Days Calculator</span>
      </nav>

      <!-- Section Header -->
      <div class="space-y-4">
        <h1 class="text-3xl sm:text-5xl font-bold tracking-tight text-neutral-900 dark:text-white text-pretty">
          Days Between Two Dates Calculator
        </h1>
        <p class="text-neutral-400 max-w-2xl text-sm sm:text-base">
          Determine duration intervals down to the exact days, weeks, or business days. Switch modes to add/subtract offsets to forecast milestones.
        </p>
      </div>

      <!-- Main Columns -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        
        <!-- Inputs & Setup (Left) -->
        <div class="lg:col-span-7 space-y-6">
          
          <!-- Mode Tabs (Pill tabs) -->
          <div class="flex p-1 rounded-lg bg-neutral-100 dark:bg-[#0e0e0e] border border-neutral-200 dark:border-neutral-800" role="tablist" aria-label="Calculator Mode">
            <button
              type="button"
              id="mode-diff"
              role="tab"
              aria-selected="true"
              aria-controls="panel-diff"
              class="flex-1 text-center text-xs font-semibold py-2.5 rounded-md transition-all outline-none border border-transparent text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white aria-selected:bg-neutral-50 dark:aria-selected:bg-neutral-900 aria-selected:text-neutral-900 dark:aria-selected:text-white aria-selected:border-neutral-200 dark:aria-selected:border-neutral-800 aria-selected:shadow-sm dark:aria-selected:shadow-none cursor-pointer"
            >
              Days Between Dates
            </button>
            <button
              type="button"
              id="mode-offset"
              role="tab"
              aria-selected="false"
              aria-controls="panel-offset"
              class="flex-1 text-center text-xs font-semibold py-2.5 rounded-md transition-all outline-none border border-transparent text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white aria-selected:bg-neutral-50 dark:aria-selected:bg-neutral-900 aria-selected:text-neutral-900 dark:aria-selected:text-white aria-selected:border-neutral-200 dark:aria-selected:border-neutral-800 aria-selected:shadow-sm dark:aria-selected:shadow-none cursor-pointer"
            >
              Add / Subtract Days
            </button>
          </div>

          <!-- Mode 1 Panel: Days Between Dates -->
          <div id="panel-diff" role="tabpanel" class="premium-glass-card rounded-xl p-6 space-y-5">
            <h2 class="text-lg font-bold text-neutral-900 dark:text-white flex items-center gap-2">
              <svg class="w-5 h-5 text-neutral-400 dark:text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
              Date Range Coordinates
            </h2>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <!-- Start Date -->
              <div class="space-y-2 relative" id="start-date-container">
                <label for="start-date" class="block text-xs font-mono text-neutral-400 uppercase tracking-widest">
                  Start Date
                </label>
                <div class="relative">
                  <input 
                    type="text" 
                    id="start-date" 
                    readonly
                    placeholder="Select start date…"
                    class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded-md h-11 pl-3 pr-10 text-sm text-neutral-900 dark:text-white focus:border-neutral-900 dark:focus:border-white focus:ring-1 focus:ring-neutral-900 dark:focus:ring-white outline-none cursor-pointer transition-colors"
                  />
                  <button
                    type="button"
                    class="absolute right-3 top-1/2 -translate-y-1/2 text-neutral-500 hover:text-neutral-900 dark:hover:text-white focus-visible:ring-1 focus-visible:ring-neutral-900 dark:focus-visible:ring-white outline-none rounded cursor-pointer"
                    aria-label="Open start date calendar"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                    </svg>
                  </button>
                </div>
                <!-- Calendar Popup -->
                <div class="hidden absolute left-0 mt-2 z-50 w-72 bg-neutral-50 dark:bg-[#0e0e0e] border border-neutral-200 dark:border-neutral-800 rounded-lg shadow-2xl p-4 space-y-3 calendar-popup" role="dialog" aria-modal="true" aria-label="Start date calendar picker">
                  <div class="flex items-center justify-between gap-1">
                    <button type="button" class="p-1 rounded hover:bg-neutral-100 dark:hover:bg-neutral-800 text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white prev-month-btn" aria-label="Previous month animate-all">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                    </button>
                    <div class="flex items-center gap-1.5">
                      <select class="bg-background border border-neutral-200 dark:border-neutral-800 text-xs font-semibold text-neutral-900 dark:text-white px-1.5 py-1 rounded outline-none cursor-pointer month-select" aria-label="Select month"></select>
                      <select class="bg-background border border-neutral-200 dark:border-neutral-800 text-xs font-semibold text-neutral-900 dark:text-white px-1.5 py-1 rounded outline-none cursor-pointer year-select" aria-label="Select year"></select>
                    </div>
                    <button type="button" class="p-1 rounded hover:bg-neutral-100 dark:hover:bg-neutral-800 text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white next-month-btn" aria-label="Next month animate-all">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                    </button>
                  </div>
                  <div class="grid grid-cols-7 text-center text-[10px] font-mono text-neutral-400 dark:text-neutral-500 font-bold border-b border-neutral-200 dark:border-neutral-900 pb-1.5">
                    <span>Su</span><span>Mo</span><span>Tu</span><span>We</span><span>Th</span><span>Fr</span><span>Sa</span>
                  </div>
                  <div class="grid grid-cols-7 gap-1 text-center text-xs days-grid"></div>
                  <div class="flex items-center justify-between border-t border-neutral-200 dark:border-neutral-900 pt-2.5">
                    <button type="button" class="text-[10px] font-mono text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white today-btn font-semibold px-1 py-0.5 rounded cursor-pointer">Today</button>
                    <button type="button" class="text-[10px] font-mono text-neutral-500 hover:text-neutral-900 dark:hover:text-white close-btn font-semibold px-1 py-0.5 rounded cursor-pointer">Close</button>
                  </div>
                </div>
              </div>

              <!-- End Date -->
              <div class="space-y-2 relative" id="end-date-container">
                <label for="end-date" class="block text-xs font-mono text-neutral-400 uppercase tracking-widest">
                  End Date
                </label>
                <div class="relative">
                  <input 
                    type="text" 
                    id="end-date" 
                    readonly
                    placeholder="Select end date…"
                    class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded-md h-11 pl-3 pr-10 text-sm text-neutral-900 dark:text-white focus:border-neutral-900 dark:focus:border-white focus:ring-1 focus:ring-neutral-900 dark:focus:ring-white outline-none cursor-pointer transition-colors"
                  />
                  <button
                    type="button"
                    class="absolute right-3 top-1/2 -translate-y-1/2 text-neutral-500 hover:text-neutral-900 dark:hover:text-white focus-visible:ring-1 focus-visible:ring-neutral-900 dark:focus-visible:ring-white outline-none rounded cursor-pointer"
                    aria-label="Open end date calendar"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                    </svg>
                  </button>
                </div>
                <!-- Calendar Popup -->
                <div class="hidden absolute left-0 mt-2 z-50 w-72 bg-neutral-50 dark:bg-[#0e0e0e] border border-neutral-200 dark:border-neutral-800 rounded-lg shadow-2xl p-4 space-y-3 calendar-popup" role="dialog" aria-modal="true" aria-label="End date calendar picker">
                  <div class="flex items-center justify-between gap-1">
                    <button type="button" class="p-1 rounded hover:bg-neutral-100 dark:hover:bg-neutral-800 text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white prev-month-btn" aria-label="Previous month animate-all">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                    </button>
                    <div class="flex items-center gap-1.5">
                      <select class="bg-background border border-neutral-200 dark:border-neutral-800 text-xs font-semibold text-neutral-900 dark:text-white px-1.5 py-1 rounded outline-none cursor-pointer month-select" aria-label="Select month"></select>
                      <select class="bg-background border border-neutral-200 dark:border-neutral-800 text-xs font-semibold text-neutral-900 dark:text-white px-1.5 py-1 rounded outline-none cursor-pointer year-select" aria-label="Select year"></select>
                    </div>
                    <button type="button" class="p-1 rounded hover:bg-neutral-100 dark:hover:bg-neutral-800 text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white next-month-btn" aria-label="Next month animate-all">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                    </button>
                  </div>
                  <div class="grid grid-cols-7 text-center text-[10px] font-mono text-neutral-400 dark:text-neutral-500 font-bold border-b border-neutral-200 dark:border-neutral-900 pb-1.5">
                    <span>Su</span><span>Mo</span><span>Tu</span><span>We</span><span>Th</span><span>Fr</span><span>Sa</span>
                  </div>
                  <div class="grid grid-cols-7 gap-1 text-center text-xs days-grid"></div>
                  <div class="flex items-center justify-between border-t border-neutral-200 dark:border-neutral-900 pt-2.5">
                    <button type="button" class="text-[10px] font-mono text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white today-btn font-semibold px-1 py-0.5 rounded cursor-pointer">Today</button>
                    <button type="button" class="text-[10px] font-mono text-neutral-500 hover:text-neutral-900 dark:hover:text-white close-btn font-semibold px-1 py-0.5 rounded cursor-pointer">Close</button>
                  </div>
                </div>
              </div>
            </div>

            <!-- Date shortcut buttons -->
            <div class="flex flex-wrap gap-2 pt-1">
              <button type="button" id="shortcut-1w" class="px-2.5 py-1.5 text-[10px] font-mono border border-neutral-200 dark:border-neutral-800 hover:border-neutral-900 dark:hover:border-white rounded bg-neutral-50 dark:bg-neutral-900 text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white transition-colors cursor-pointer">+1 Week</button>
              <button type="button" id="shortcut-1m" class="px-2.5 py-1.5 text-[10px] font-mono border border-neutral-200 dark:border-neutral-800 hover:border-neutral-900 dark:hover:border-white rounded bg-neutral-50 dark:bg-neutral-900 text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white transition-colors cursor-pointer">+1 Month</button>
              <button type="button" id="shortcut-3m" class="px-2.5 py-1.5 text-[10px] font-mono border border-neutral-200 dark:border-neutral-800 hover:border-neutral-900 dark:hover:border-white rounded bg-neutral-50 dark:bg-neutral-900 text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white transition-colors cursor-pointer">+3 Months</button>
              <button type="button" id="shortcut-1y" class="px-2.5 py-1.5 text-[10px] font-mono border border-neutral-200 dark:border-neutral-800 hover:border-neutral-900 dark:hover:border-white rounded bg-neutral-50 dark:bg-neutral-900 text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white transition-colors cursor-pointer">+1 Year</button>
            </div>

            <!-- Calculation Exclusions Options -->
            <div class="border-t border-neutral-200 dark:border-neutral-800 pt-5 space-y-4">
              <h3 class="text-xs font-mono text-neutral-400 uppercase tracking-widest">Calculation Modifiers</h3>
              
              <div class="space-y-3">
                <!-- Include end date checkbox -->
                <label class="flex items-center gap-3 cursor-pointer group text-xs text-neutral-600 dark:text-neutral-400">
                  <input 
                    type="checkbox" 
                    id="include-end-date" 
                    class="rounded border-neutral-300 dark:border-neutral-800 bg-background text-neutral-900 dark:text-white focus:ring-0 w-4 h-4 cursor-pointer"
                  />
                  <span>Include end date in calculation (adds 1 day)</span>
                </label>

                <!-- Exclude weekends checkbox -->
                <label class="flex items-center gap-3 cursor-pointer group text-xs text-neutral-600 dark:text-neutral-400">
                  <input 
                    type="checkbox" 
                    id="exclude-weekends" 
                    class="rounded border-neutral-300 dark:border-neutral-800 bg-background text-neutral-900 dark:text-white focus:ring-0 w-4 h-4 cursor-pointer"
                  />
                  <span>Exclude weekends (calculate business days)</span>
                </label>

                <!-- Exclude US holidays checkbox -->
                <label class="flex items-center gap-3 cursor-pointer group text-xs text-neutral-600 dark:text-neutral-400" id="holidays-wrapper">
                  <input 
                    type="checkbox" 
                    id="exclude-holidays" 
                    class="rounded border-neutral-300 dark:border-neutral-800 bg-background text-neutral-900 dark:text-white focus:ring-0 w-4 h-4 cursor-pointer"
                  />
                  <span>Exclude major US Federal holidays</span>
                </label>
              </div>
            </div>
          </div>

          <!-- Mode 2 Panel: Add/Subtract Days (Hidden by default) -->
          <div id="panel-offset" role="tabpanel" class="hidden premium-glass-card rounded-xl p-6 space-y-5">
            <h2 class="text-lg font-bold text-neutral-900 dark:text-white flex items-center gap-2">
              <svg class="w-5 h-5 text-neutral-400 dark:text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              Offset Adjustments
            </h2>

            <!-- Base Date -->
            <div class="space-y-2 relative" id="offset-base-date-container">
              <label for="offset-base-date" class="block text-xs font-mono text-neutral-400 uppercase tracking-widest">
                Starting Base Date
              </label>
              <div class="relative">
                <input 
                  type="text" 
                  id="offset-base-date" 
                  readonly
                  placeholder="Select starting date…"
                  class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded-md h-11 pl-3 pr-10 text-sm text-neutral-900 dark:text-white focus:border-neutral-900 dark:focus:border-white focus:ring-1 focus:ring-neutral-900 dark:focus:ring-white outline-none cursor-pointer transition-colors"
                />
                <button
                  type="button"
                  class="absolute right-3 top-1/2 -translate-y-1/2 text-neutral-500 hover:text-neutral-900 dark:hover:text-white focus-visible:ring-1 focus-visible:ring-neutral-900 dark:focus-visible:ring-white outline-none rounded cursor-pointer"
                  aria-label="Open starting date calendar"
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                  </svg>
                </button>
              </div>
              <!-- Calendar Popup -->
              <div class="hidden absolute left-0 mt-2 z-50 w-72 bg-neutral-50 dark:bg-[#0e0e0e] border border-neutral-200 dark:border-neutral-800 rounded-lg shadow-2xl p-4 space-y-3 calendar-popup" role="dialog" aria-modal="true" aria-label="Starting base date calendar picker">
                <div class="flex items-center justify-between gap-1">
                  <button type="button" class="p-1 rounded hover:bg-neutral-100 dark:hover:bg-neutral-800 text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white prev-month-btn" aria-label="Previous month animate-all">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                  </button>
                  <div class="flex items-center gap-1.5">
                    <select class="bg-background border border-neutral-200 dark:border-neutral-800 text-xs font-semibold text-neutral-900 dark:text-white px-1.5 py-1 rounded outline-none cursor-pointer month-select" aria-label="Select month"></select>
                    <select class="bg-background border border-neutral-200 dark:border-neutral-800 text-xs font-semibold text-neutral-900 dark:text-white px-1.5 py-1 rounded outline-none cursor-pointer year-select" aria-label="Select year"></select>
                  </div>
                  <button type="button" class="p-1 rounded hover:bg-neutral-100 dark:hover:bg-neutral-800 text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white next-month-btn" aria-label="Next month animate-all">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                  </button>
                </div>
                <div class="grid grid-cols-7 text-center text-[10px] font-mono text-neutral-400 dark:text-neutral-500 font-bold border-b border-neutral-200 dark:border-neutral-900 pb-1.5">
                  <span>Su</span><span>Mo</span><span>Tu</span><span>We</span><span>Th</span><span>Fr</span><span>Sa</span>
                </div>
                <div class="grid grid-cols-7 gap-1 text-center text-xs days-grid"></div>
                <div class="flex items-center justify-between border-t border-neutral-200 dark:border-neutral-900 pt-2.5">
                  <button type="button" class="text-[10px] font-mono text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white today-btn font-semibold px-1 py-0.5 rounded cursor-pointer">Today</button>
                  <button type="button" class="text-[10px] font-mono text-neutral-500 hover:text-neutral-900 dark:hover:text-white close-btn font-semibold px-1 py-0.5 rounded cursor-pointer">Close</button>
                </div>
              </div>
            </div>

            <!-- Offsets input grid -->
            <div class="grid grid-cols-3 gap-4 border-t border-neutral-200 dark:border-neutral-800 pt-5">
              <div class="space-y-2">
                <label for="offset-years" class="block text-[10px] font-mono text-neutral-400 uppercase tracking-wider">Years</label>
                <input type="number" id="offset-years" value="0" class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded h-10 px-3 text-xs text-neutral-900 dark:text-white outline-none focus:border-neutral-900 dark:focus:border-white font-mono" />
              </div>
              <div class="space-y-2">
                <label for="offset-months" class="block text-[10px] font-mono text-neutral-400 uppercase tracking-wider">Months</label>
                <input type="number" id="offset-months" value="0" class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded h-10 px-3 text-xs text-neutral-900 dark:text-white outline-none focus:border-neutral-900 dark:focus:border-white font-mono" />
              </div>
              <div class="space-y-2">
                <label for="offset-days" class="block text-[10px] font-mono text-neutral-400 uppercase tracking-wider">Days</label>
                <input type="number" id="offset-days" value="30" class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded h-10 px-3 text-xs text-neutral-900 dark:text-white outline-none focus:border-neutral-900 dark:focus:border-white font-mono" />
              </div>
            </div>

            <!-- Direction selector -->
            <div class="flex p-0.5 rounded-lg bg-neutral-100 dark:bg-neutral-950 border border-neutral-200 dark:border-neutral-800" role="tablist">
              <button type="button" id="offset-direction-add" class="flex-1 text-center text-xs font-semibold py-2 rounded-md transition-all border border-transparent text-neutral-900 dark:text-white bg-neutral-50 dark:bg-neutral-900 border-neutral-200 dark:border-neutral-800 shadow-sm cursor-pointer">Add Duration</button>
              <button type="button" id="offset-direction-sub" class="flex-1 text-center text-xs font-semibold py-2 rounded-md transition-all border border-transparent text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white cursor-pointer">Subtract Duration</button>
            </div>
          </div>
        </div>

        <!-- Dashboard Outputs & Charts (Right) -->
        <div class="lg:col-span-5 space-y-6">
          
          <!-- Primary result dashboard widget -->
          <div id="result-widget" class="relative overflow-hidden rounded-xl border p-6 flex flex-col justify-between transition-all duration-300 bg-neutral-50/50 dark:bg-neutral-900/10 border-neutral-200 dark:border-neutral-800 shadow-sm">
            <div id="result-glow" class="absolute top-0 right-0 -mt-6 -mr-6 w-44 h-44 blur-3xl rounded-full pointer-events-none opacity-20 bg-brand-blue"></div>

            <div class="relative z-10 space-y-5">
              <div class="flex items-center justify-between">
                <span class="text-xs font-mono uppercase tracking-widest text-neutral-500" id="result-title">Duration Span</span>
                <span id="result-badge" class="text-[10px] font-mono font-bold uppercase py-0.5 px-2.5 rounded-full border bg-neutral-100 dark:bg-neutral-950 text-neutral-600 dark:text-neutral-400 border-neutral-200 dark:border-neutral-800">
                  Active
                </span>
              </div>

              <!-- Main Large count -->
              <div class="space-y-1">
                <div class="flex items-baseline gap-2">
                  <span id="result-big-value" class="text-5xl font-extrabold tracking-tight text-neutral-900 dark:text-white font-mono">
                    --
                  </span>
                  <span id="result-big-unit" class="text-sm font-mono text-neutral-500">Days</span>
                </div>
                <p id="result-summary" class="text-xs text-neutral-500 leading-relaxed font-light">
                  Forecasted interval calculations.
                </p>
              </div>

              <!-- Detailed breakdowns grid -->
