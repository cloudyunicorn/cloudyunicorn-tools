---
import Layout from '../layouts/Layout.astro';
import SocialShare from '../components/SocialShare.astro';
---

<Layout 
  title="Premium Online Calculators"
  description="Free, instant, and privacy-first online tools for developers and builders. Calculate exact age, body mass index (BMI), and daily calorie requirements (BMR/TDEE)."
>
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "name": "CloudyUnicorn Tools",
          "url": "https://www.cloudyunicorn.com/",
          "description": "Free, instant, and privacy-first online tools for developers and builders."
        },
        {
          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "name": "What is CloudyUnicorn Tools?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "CloudyUnicorn Tools is a suite of premium, privacy-first online calculators designed for everyday use. Our focus is on clean, high-precision developer utilities."
              }
            },
            {
              "@type": "Question",
              "name": "Are calculations on this site private?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Yes, 100%. All calculations are done locally in your browser using JavaScript. No input parameters or results are ever sent to a server or stored in a database."
              }
            },
            {
              "@type": "Question",
              "name": "What tools are currently available?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Currently, we offer a precise Age Calculator, a BMI Calculator (with metric and imperial support), and a Calories Calculator (BMR/TDEE). More standalone tools are launched regularly."
              }
            },
            {
              "@type": "Question",
              "name": "Why does CloudyUnicorn Tools prioritize client-side calculations?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "By running all calculations locally in your browser, we eliminate any chance of data interception, minimize server latency to zero, and make the calculators work offline. Your sensitive variables (like age, weight, and habits) are processed entirely inside your browser."
              }
            },
            {
              "@type": "Question",
              "name": "Is there any cost associated with using these calculators?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "No. All tools on CloudyUnicorn Tools are 100% free and require no accounts or registrations. Our goal is to build a premium, high-precision web playground that provides maximum utility without clutter."
              }
            }
          ]
        }
      ]
    }
  </script>

  <!-- Hero Section with Vercel-style geometric grid background -->
  <section class="relative overflow-hidden border-b border-neutral-200 dark:border-neutral-800 bg-background bg-hero-glow pt-32 pb-20 lg:pt-40 lg:pb-28" aria-labelledby="hero-title">
    <div class="absolute inset-0 bg-grid-pattern bg-grid-fade pointer-events-none opacity-40"></div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center space-y-8">
      <!-- Tag / Badge -->
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-neutral-200 dark:border-neutral-800 bg-neutral-50/50 dark:bg-neutral-900/50 backdrop-blur-sm text-xs font-mono text-neutral-600 dark:text-neutral-400 select-none animate-pulse-subtle">
        <span class="w-1.5 h-1.5 rounded-full bg-brand-green"></span>
        <span>Version 1.0.0 Alpha Released</span>
      </div>

      <!-- Main Heading -->
      <div class="max-w-4xl mx-auto space-y-4">
        <h1 id="hero-title" class="text-4xl sm:text-6xl lg:text-7xl font-bold tracking-tight text-neutral-900 dark:text-white leading-none text-wrap-balance">
          Premium online calculators,<br />
          <span class="animate-text-gradient">without the clutter.</span>
        </h1>
        <p class="text-lg sm:text-xl text-neutral-600 dark:text-neutral-400 max-w-2xl mx-auto text-wrap-balance font-light">
          A clean, privacy-first suite of online calculators. Your data remains on your device and never leaves it. No signups or accounts required.
        </p>
      </div>

      <!-- Hero Buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a 
          href="#explore-tools" 
          class="w-full sm:w-auto px-6 py-3 rounded-md bg-neutral-950 dark:bg-white text-white dark:text-black font-semibold text-sm hover:bg-neutral-900 dark:hover:bg-neutral-200 transition-colors duration-150 text-center shadow-lg hover:shadow-black/5 dark:hover:shadow-white/5 cursor-pointer"
        >
          Explore Tools
        </a>
      </div>
    </div>
  </section>

  <!-- Tools Section -->
  <section id="explore-tools" class="py-20 bg-background" aria-labelledby="tools-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-12">
        <!-- Section Header -->
        <div class="max-w-3xl space-y-4">
          <h2 id="tools-heading" class="text-xs font-mono text-neutral-500 uppercase tracking-widest">Available Utilities</h2>
          <p class="text-3xl sm:text-4xl font-bold tracking-tight text-neutral-900 dark:text-white">
            Choose a calculator to get started
          </p>
          <p class="text-sm sm:text-base text-neutral-600 dark:text-neutral-400">
            Each utility runs completely client-side. Your inputs never touch our servers, ensuring your metrics and records remain 100% private.
          </p>
        </div>

        <!-- Search and Filter Controls -->
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 pt-4 border-b border-neutral-200 dark:border-neutral-800/80 pb-6">
          <!-- Search Bar -->
          <div class="relative w-full md:max-w-md">
            <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-neutral-400 dark:text-neutral-500">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
            </div>
            <input 
              type="text" 
              id="tool-search" 
              placeholder="Search tools by name or description..." 
              class="w-full bg-neutral-50/50 dark:bg-neutral-950/50 border border-neutral-200 dark:border-neutral-800 rounded-full h-10 pl-10 pr-4 text-xs text-neutral-900 dark:text-white focus:border-neutral-950 dark:focus:border-white focus:ring-1 focus:ring-neutral-950 dark:focus:ring-white outline-none transition-all"
            />
          </div>

          <!-- Tabs -->
          <div class="flex items-center gap-2 overflow-x-auto scrollbar-none pb-2 md:pb-0">
            <button data-filter="all" class="category-tab px-4 py-1.5 rounded-full text-xs font-mono font-semibold transition-all bg-neutral-950 dark:bg-white text-white dark:text-black border border-neutral-300 dark:border-neutral-700 cursor-pointer whitespace-nowrap shadow-sm">All Utilities</button>
            <button data-filter="fitness" class="category-tab px-4 py-1.5 rounded-full text-xs font-mono font-semibold transition-all text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white cursor-pointer whitespace-nowrap border border-transparent">⚡ Fitness & Diet</button>
            <button data-filter="time" class="category-tab px-4 py-1.5 rounded-full text-xs font-mono font-semibold transition-all text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white cursor-pointer whitespace-nowrap border border-transparent">📅 Time & Milestones</button>
            <button data-filter="finance" class="category-tab px-4 py-1.5 rounded-full text-xs font-mono font-semibold transition-all text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white cursor-pointer whitespace-nowrap border border-transparent">💼 Finance Utilities</button>
          </div>
        </div>


        <!-- Tools Grid -->
        <div id="tools-grid" class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <!-- Tool 1: Age Calculator -->
          <div class="vercel-glow-card rounded-xl p-6 flex flex-col justify-between h-[340px] tool-card" data-category="time">
            <div class="space-y-4">
              <!-- Icon/Header -->
              <div class="flex items-center justify-between">
                <div class="w-10 h-10 rounded-lg border border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-900/50 flex items-center justify-center text-neutral-900 dark:text-white" aria-hidden="true">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                </div>
                <span class="text-[11px] font-mono text-neutral-500 uppercase py-0.5 px-2 border border-neutral-200 dark:border-neutral-900 rounded bg-neutral-50 dark:bg-neutral-950">High Precision</span>
              </div>
              
              <!-- Title & Info -->
              <div class="space-y-2">
                <h3 class="text-xl font-bold text-neutral-900 dark:text-white tracking-tight">Age Calculator</h3>
                <p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">
                  Calculate your precise age in years, months, weeks, and days. Includes birthday count downs and a real-time running counter of seconds lived.
                </p>
              </div>
            </div>

            <div class="pt-4 border-t border-neutral-100 dark:border-neutral-900 flex items-center justify-between">
              <span class="text-xs text-neutral-500 font-mono">Input: Date of Birth</span>
              <a 
                href="/age-calculator" 
                class="px-4 py-2 rounded-md bg-neutral-950 dark:bg-neutral-900 hover:bg-neutral-900 dark:hover:bg-neutral-800 text-white font-medium text-xs border border-neutral-900 dark:border-neutral-800 hover:border-neutral-800 dark:hover:border-neutral-700 transition-all duration-150 cursor-pointer whitespace-nowrap"
                aria-label="Use the Age Calculator tool"
              >
                Calculate Age
              </a>
            </div>
          </div>

          <!-- Tool 2: BMI Calculator -->
          <div class="vercel-glow-card rounded-xl p-6 flex flex-col justify-between h-[340px] tool-card" data-category="fitness">
            <div class="space-y-4">
              <!-- Icon/Header -->
              <div class="flex items-center justify-between">
                <div class="w-10 h-10 rounded-lg border border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-900/50 flex items-center justify-center text-neutral-900 dark:text-white" aria-hidden="true">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2m0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 002 2h2a2 2 0 002-2z"></path>
                  </svg>
                </div>
                <span class="text-[11px] font-mono text-neutral-500 uppercase py-0.5 px-2 border border-neutral-200 dark:border-neutral-900 rounded bg-neutral-50 dark:bg-neutral-950">Dual Mode</span>
              </div>
              
              <!-- Title & Info -->
              <div class="space-y-2">
                <h3 class="text-xl font-bold text-neutral-900 dark:text-white tracking-tight">BMI Calculator</h3>
                <p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">
                  Compute your Body Mass Index (BMI) instantly. Supports Metric and Imperial standards, and provides a clear graphical classification scale with healthy weight advice.
                </p>
              </div>
            </div>

            <div class="pt-4 border-t border-neutral-100 dark:border-neutral-900 flex items-center justify-between">
              <span class="text-xs text-neutral-500 font-mono">Input: Height & Weight</span>
              <a 
                href="/bmi-calculator" 
                class="px-4 py-2 rounded-md bg-neutral-950 dark:bg-neutral-900 hover:bg-neutral-900 dark:hover:bg-neutral-800 text-white font-medium text-xs border border-neutral-900 dark:border-neutral-800 hover:border-neutral-800 dark:hover:border-neutral-700 transition-all duration-150 cursor-pointer whitespace-nowrap"
                aria-label="Use the BMI Calculator tool"
              >
                Calculate BMI
              </a>
            </div>
          </div>

          <!-- Tool 3: Calories Calculator -->
          <div class="vercel-glow-card rounded-xl p-6 flex flex-col justify-between h-[340px] tool-card" data-category="fitness">
            <div class="space-y-4">
              <!-- Icon/Header -->
              <div class="flex items-center justify-between">
                <div class="w-10 h-10 rounded-lg border border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-900/50 flex items-center justify-center text-neutral-900 dark:text-white" aria-hidden="true">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"></path>
                  </svg>
                </div>
                <span class="text-[11px] font-mono text-neutral-500 uppercase py-0.5 px-2 border border-neutral-200 dark:border-neutral-900 rounded bg-neutral-50 dark:bg-neutral-950">Nutritional Breakdowns</span>
              </div>
              
              <!-- Title & Info -->
              <div class="space-y-2">
                <h3 class="text-xl font-bold text-neutral-900 dark:text-white tracking-tight">Calories Calculator</h3>
                <p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">
                  Estimate daily metabolic calorie needs (BMR & TDEE) matching your specific activity profiles and weight targets. Provides personalized macronutrient guides.
                </p>
              </div>
            </div>

            <div class="pt-4 border-t border-neutral-100 dark:border-neutral-900 flex items-center justify-between">
              <span class="text-xs text-neutral-500 font-mono">Input: Stats & Activity</span>
              <a 
                href="/calories-calculator" 
                class="px-4 py-2 rounded-md bg-neutral-950 dark:bg-neutral-900 hover:bg-neutral-900 dark:hover:bg-neutral-800 text-white font-medium text-xs border border-neutral-900 dark:border-neutral-800 hover:border-neutral-800 dark:hover:border-neutral-700 transition-all duration-150 cursor-pointer whitespace-nowrap"
                aria-label="Use the Calories Calculator tool"
              >
                Calculate Calories
              </a>
            </div>
          </div>

          <!-- Tool 4: SaaS Cost Burn Calculator -->
          <div class="vercel-glow-card rounded-xl p-6 flex flex-col justify-between h-[340px] tool-card" data-category="finance">
            <div class="space-y-4">
              <!-- Icon/Header -->
              <div class="flex items-center justify-between">
                <div class="w-10 h-10 rounded-lg border border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-900/50 flex items-center justify-center text-neutral-900 dark:text-white" aria-hidden="true">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                </div>
                <span class="text-[11px] font-mono text-neutral-500 uppercase py-0.5 px-2 border border-neutral-200 dark:border-neutral-900 rounded bg-neutral-50 dark:bg-neutral-950">Runway &amp; Break-even</span>
              </div>
              
              <!-- Title & Info -->
              <div class="space-y-2">
                <h3 class="text-xl font-bold text-neutral-900 dark:text-white tracking-tight">SaaS Cost Burn Calculator</h3>
                <p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">
                  Track runtime SaaS expenses, payroll/contractor costs, and project cash runway. Estimate default alive status, break-even timelines, and growth metrics.
                </p>
              </div>
            </div>

            <div class="pt-4 border-t border-neutral-100 dark:border-neutral-900 flex items-center justify-between">
              <span class="text-xs text-neutral-500 font-mono">Input: Finances &amp; Expenses</span>
              <a 
                href="/saas-cost-burn-calculator" 
                class="px-4 py-2 rounded-md bg-neutral-950 dark:bg-neutral-900 hover:bg-neutral-900 dark:hover:bg-neutral-800 text-white font-medium text-xs border border-neutral-900 dark:border-neutral-800 hover:border-neutral-800 dark:hover:border-neutral-700 transition-all duration-150 cursor-pointer whitespace-nowrap"
                aria-label="Use the SaaS Cost Burn Calculator tool"
              >
                Calculate Runway
              </a>
            </div>
          </div>

          <!-- Tool 5: Mortgage Calculator -->
          <div class="vercel-glow-card rounded-xl p-6 flex flex-col justify-between h-[340px] tool-card" data-category="finance">
            <div class="space-y-4">
              <!-- Icon/Header -->
              <div class="flex items-center justify-between">
                <div class="w-10 h-10 rounded-lg border border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-900/50 flex items-center justify-center text-neutral-900 dark:text-white" aria-hidden="true">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                  </svg>
                </div>
                <span class="text-[11px] font-mono text-neutral-500 uppercase py-0.5 px-2 border border-neutral-200 dark:border-neutral-900 rounded bg-neutral-50 dark:bg-neutral-950">Amortization &amp; PMI</span>
              </div>
              
              <!-- Title & Info -->
              <div class="space-y-2">
                <h3 class="text-xl font-bold text-neutral-900 dark:text-white tracking-tight">Mortgage Calculator</h3>
                <p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">
                  Calculate comprehensive monthly home payments including principal, interest, taxes, insurance, HOA, and PMI. Model amortization schedules with extra payments.
                </p>
              </div>
            </div>

            <div class="pt-4 border-t border-neutral-100 dark:border-neutral-900 flex items-center justify-between">
              <span class="text-xs text-neutral-500 font-mono">Input: Rates &amp; Down Payment</span>
              <a 
                href="/mortgage-calculator" 
                class="px-4 py-2 rounded-md bg-neutral-950 dark:bg-neutral-900 hover:bg-neutral-900 dark:hover:bg-neutral-800 text-white font-medium text-xs border border-neutral-900 dark:border-neutral-800 hover:border-neutral-800 dark:hover:border-neutral-700 transition-all duration-150 cursor-pointer whitespace-nowrap"
                aria-label="Use the Mortgage Calculator tool"
              >
                Calculate Mortgage
              </a>
            </div>
          </div>

          <!-- Tool 6: Days Calculator -->
          <div class="vercel-glow-card rounded-xl p-6 flex flex-col justify-between h-[340px] tool-card" data-category="time">
            <div class="space-y-4">
              <!-- Icon/Header -->
              <div class="flex items-center justify-between">
                <div class="w-10 h-10 rounded-lg border border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-900/50 flex items-center justify-center text-neutral-900 dark:text-white" aria-hidden="true">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                  </svg>
                </div>
                <span class="text-[11px] font-mono text-neutral-500 uppercase py-0.5 px-2 border border-neutral-200 dark:border-neutral-900 rounded bg-neutral-50 dark:bg-neutral-950">Calendar &amp; Business Days</span>
              </div>
              
              <!-- Title & Info -->
              <div class="space-y-2">
                <h3 class="text-xl font-bold text-neutral-900 dark:text-white tracking-tight">Days Calculator</h3>
                <p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">
                  Calculate calendar days, business days excluding weekends, and floating US federal holidays between two dates. Model date offset projections.
                </p>
              </div>
            </div>

            <div class="pt-4 border-t border-neutral-100 dark:border-neutral-900 flex items-center justify-between">
              <span class="text-xs text-neutral-500 font-mono">Input: Two Dates &amp; Offsets</span>
              <a 
                href="/days-calculator" 
                class="px-4 py-2 rounded-md bg-neutral-950 dark:bg-neutral-900 hover:bg-neutral-900 dark:hover:bg-neutral-800 text-white font-medium text-xs border border-neutral-900 dark:border-neutral-800 hover:border-neutral-800 dark:hover:border-neutral-700 transition-all duration-150 cursor-pointer whitespace-nowrap"
                aria-label="Use the Days Calculator tool"
              >
                Calculate Days
              </a>
            </div>
          </div>
        </div>

        <!-- No Results State -->
        <div id="no-results" class="hidden py-16 text-center space-y-2">
          <p class="text-sm text-neutral-500 dark:text-neutral-400 font-light">
            No tools match your search criteria.
          </p>
        </div>

  <style>
    .tool-card {
      transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1), transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), border-color 0.3s ease, box-shadow 0.3s ease;
    }
  </style>

  <script is:inline>
    function initHomeFilters() {
      const tabs = document.querySelectorAll('.category-tab');
      const cards = document.querySelectorAll('.tool-card');
      const searchInput = document.getElementById('tool-search');
      const noResults = document.getElementById('no-results');

      let activeFilter = 'all';
      let searchQuery = '';

      function filterTools() {
        let visibleCount = 0;

        cards.forEach(card => {
          const category = card.getAttribute('data-category');
          const title = card.querySelector('h3')?.textContent?.toLowerCase() || '';
          const description = card.querySelector('p')?.textContent?.toLowerCase() || '';
          
          const matchesCategory = activeFilter === 'all' || category === activeFilter;
          const matchesSearch = title.includes(searchQuery) || description.includes(searchQuery);

          if (matchesCategory && matchesSearch) {
            card.classList.remove('hidden');
            // Force browser layout reflow before opacity change to trigger transition
            card.style.opacity = '0';
            setTimeout(() => {
              card.style.opacity = '1';
            }, 50);
            visibleCount++;
          } else {
            card.style.opacity = '0';
            card.classList.add('hidden');
          }
        });

        if (noResults) {
          if (visibleCount === 0) {
            noResults.classList.remove('hidden');
          } else {
            noResults.classList.add('hidden');
          }
        }
      }

      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          // Reset styling for all tabs
          tabs.forEach(t => {
            t.className = "category-tab px-4 py-1.5 rounded-full text-xs font-mono font-semibold transition-all text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white cursor-pointer whitespace-nowrap border border-transparent";
          });
          
          // Set active styling for the clicked tab
          tab.className = "category-tab px-4 py-1.5 rounded-full text-xs font-mono font-semibold transition-all bg-neutral-950 dark:bg-white text-white dark:text-black border border-neutral-300 dark:border-neutral-700 cursor-pointer whitespace-nowrap shadow-sm";

          activeFilter = tab.getAttribute('data-filter') || 'all';
          filterTools();
        });
      });

      if (searchInput) {
        searchInput.addEventListener('input', (e) => {
          searchQuery = e.target.value.toLowerCase().trim();
          filterTools();
        });
      }
    }

    // Initialize on page load and swaps
    document.addEventListener('astro:page-load', initHomeFilters);
  </script>

        <!-- Social Sharing -->
        <div class="pt-8 border-t border-neutral-200 dark:border-neutral-800">
