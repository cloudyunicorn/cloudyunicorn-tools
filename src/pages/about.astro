---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="About and Contact Us"
  description="Learn about the philosophy behind CloudyUnicorn Tools and reach out to our team with feedback or inquiries."
>
  <div class="relative min-h-[calc(100vh-16rem)] bg-background py-16 sm:py-24">
    <!-- Grid Background -->
    <div class="absolute inset-0 bg-grid-pattern bg-grid-fade pointer-events-none opacity-20"></div>
    <div class="absolute inset-0 bg-hero-glow opacity-30 pointer-events-none"></div>

    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 space-y-16 animate-fade-in">
      <!-- Page Header -->
      <div class="space-y-4 max-w-3xl">
        <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-xs font-mono text-neutral-500">
          <a href="/" class="hover:text-neutral-600 dark:hover:text-neutral-300">Tools</a>
          <span>/</span>
          <span class="text-neutral-600 dark:text-neutral-300">About and Contact</span>
        </nav>
        <h1 class="text-4xl sm:text-6xl font-bold tracking-tight text-neutral-900 dark:text-white leading-none">
          About and Contact
        </h1>
        <p class="text-neutral-600 dark:text-neutral-400 text-base sm:text-lg max-w-2xl font-light leading-relaxed">
          CloudyUnicorn Tools is a suite of premium, ad-free, and privacy-first online calculators designed by builders, for builders.
        </p>
      </div>

      <!-- Main Layout Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
        
        <!-- Left: About Content -->
        <div class="lg:col-span-7 space-y-8 text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">
          <section class="space-y-4">
            <h2 class="text-xl font-bold text-neutral-900 dark:text-white tracking-tight">Our Philosophy</h2>
            <p>
              The modern web is filled with clutter. Visiting a simple calculator page shouldn't mean scrolling past banner advertisements, dodging cookie consent walls, or fighting popups asking you to sign up for newsletters.
            </p>
            <p>
              We built <strong>CloudyUnicorn Tools</strong> to return to the fundamentals: fast, functional, and minimal utilities that do one job exceptionally well, with zero data collections or tracking.
            </p>
          </section>

          <!-- Key Principles Grid -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 pt-4">
            <div class="p-5 border border-neutral-200 dark:border-neutral-800 bg-neutral-50/20 dark:bg-neutral-900/10 rounded-xl space-y-2">
              <span class="inline-block p-2 rounded-lg bg-brand-green/10 border border-brand-green/15 text-brand-green-text font-mono text-xs font-bold uppercase tracking-wider">01. Privacy First</span>
              <p class="text-xs text-neutral-500">
                100% of our code runs directly in your browser. None of your input data is ever stored, analyzed, or sent to a remote database.
              </p>
            </div>
            <div class="p-5 border border-neutral-200 dark:border-neutral-800 bg-neutral-50/20 dark:bg-neutral-900/10 rounded-xl space-y-2">
              <span class="inline-block p-2 rounded-lg bg-brand-blue/10 border border-brand-blue/15 text-brand-blue-text font-mono text-xs font-bold uppercase tracking-wider">02. High Precision</span>
              <p class="text-xs text-neutral-500">
                We implement verified clinical and mathematical models (WHO guidelines, Harris-Benedict formula) ensuring developer-grade precision.
              </p>
            </div>
          </div>

          <section class="space-y-4">
            <h2 class="text-xl font-bold text-neutral-900 dark:text-white tracking-tight">Our Stack</h2>
            <p>
              This suite is built using **Astro** for server-side static layout rendering, combined with **Tailwind CSS v4** for clean, theme-adaptive layouts, and vanilla **client-side JavaScript** for reactivity. There are no heavy frameworks or tracking scripts running in the background.
            </p>
          </section>
        </div>

        <!-- Right: Contact Form Card -->
        <div class="lg:col-span-5 premium-glass-card rounded-xl p-6 space-y-6">
          <div class="space-y-1">
            <h2 class="text-lg font-bold text-neutral-900 dark:text-white tracking-tight">Get in Touch</h2>
            <p class="text-xs text-neutral-500">Have feedback, spotted a bug, or want to suggest a new tool? Drop us a message.</p>
          </div>

          <!-- Contact Form -->
          <form id="contact-form" class="space-y-4" novalidate>
            <div class="space-y-1.5">
              <label for="contact-name" class="block text-xs font-mono text-neutral-500 dark:text-neutral-400 uppercase tracking-widest">Name</label>
              <input 
                type="text" 
                id="contact-name" 
                required 
                placeholder="Your name" 
                class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded-md h-10 px-3 text-xs text-neutral-900 dark:text-white focus:border-neutral-900 dark:focus:border-white focus:ring-1 focus:ring-neutral-900 dark:focus:ring-white outline-none transition-colors"
              />
            </div>

            <div class="space-y-1.5">
              <label for="contact-email" class="block text-xs font-mono text-neutral-500 dark:text-neutral-400 uppercase tracking-widest">Email</label>
              <input 
                type="email" 
                id="contact-email" 
                required 
                placeholder="your@email.com" 
                class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded-md h-10 px-3 text-xs text-neutral-900 dark:text-white focus:border-neutral-900 dark:focus:border-white focus:ring-1 focus:ring-neutral-900 dark:focus:ring-white outline-none transition-colors"
              />
            </div>

            <div class="space-y-1.5">
              <label for="contact-message" class="block text-xs font-mono text-neutral-500 dark:text-neutral-400 uppercase tracking-widest">Message</label>
              <textarea 
                id="contact-message" 
                required 
                rows="4" 
                placeholder="Describe your inquiry..." 
                class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded-md p-3 text-xs text-neutral-900 dark:text-white focus:border-neutral-900 dark:focus:border-white focus:ring-1 focus:ring-neutral-900 dark:focus:ring-white outline-none transition-colors resize-none"
              ></textarea>
            </div>

            <button 
              type="submit" 
              class="w-full h-10 bg-neutral-950 dark:bg-white text-white dark:text-black hover:bg-neutral-800 dark:hover:bg-neutral-200 transition-colors font-semibold text-xs rounded-md focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-neutral-950 dark:focus-visible:ring-white outline-none"
            >
              Send Message
            </button>
          </form>

          <!-- Alternative Email copying method -->
          <div class="pt-6 border-t border-neutral-200 dark:border-neutral-800 flex flex-col items-center justify-between gap-3 text-center sm:text-left">
            <span class="text-[11px] font-mono text-neutral-400 uppercase tracking-wider">Direct Support Email</span>
            <div class="flex items-center gap-2 w-full">
              <span id="support-email" class="flex-1 text-xs font-semibold font-mono p-2 border border-neutral-200 dark:border-neutral-800 bg-neutral-100/50 dark:bg-neutral-900/50 rounded text-neutral-800 dark:text-neutral-300 select-all truncate">
                <!--email_off-->hello@cloudyunicorn.com<!--/email_off-->
              </span>
              <button 
                id="copy-email-btn"
                type="button" 
                class="h-9 px-3 border border-neutral-200 dark:border-neutral-800 hover:border-neutral-400 dark:hover:border-neutral-600 rounded bg-neutral-50/50 dark:bg-neutral-900/50 text-xs font-semibold text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white transition-all cursor-pointer flex items-center gap-1.5 shrink-0"
              >
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"></path>
                </svg>
                <span id="copy-btn-text">Copy</span>
              </button>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</Layout>

<script>
  function initAboutPage() {
    const contactForm = document.getElementById('contact-form') as HTMLFormElement;
    
    if (contactForm) {
      contactForm.addEventListener('submit', (e) => {
        e.preventDefault();
        
        const name = (document.getElementById('contact-name') as HTMLInputElement).value;
        const email = (document.getElementById('contact-email') as HTMLInputElement).value;
        const message = (document.getElementById('contact-message') as HTMLTextAreaElement).value;
        
        if (!name || !email || !message) {
          alert('Please fill out all fields.');
          return;
        }

        // Generate dynamic mailto link
        const subject = encodeURIComponent(`Inquiry from ${name} via CloudyUnicorn Tools`);
        const body = encodeURIComponent(`Name: ${name}\nEmail: ${email}\n\nMessage:\n${message}`);
        
        window.location.href = `mailto:hello@cloudyunicorn.com?subject=${subject}&body=${body}`;
      });
    }

    const copyBtn = document.getElementById('copy-email-btn');
    const copyBtnText = document.getElementById('copy-btn-text');
    const supportEmail = 'hello@cloudyunicorn.com';

    if (copyBtn && copyBtnText) {
      copyBtn.addEventListener('click', () => {
        navigator.clipboard.writeText(supportEmail).then(() => {
          copyBtnText.textContent = 'Copied!';
          copyBtn.classList.add('border-brand-green', 'text-brand-green-text');
          
          setTimeout(() => {
            copyBtnText.textContent = 'Copy';
            copyBtn.classList.remove('border-brand-green', 'text-brand-green-text');
          }, 2000);
        }).catch((err) => {
          console.error('Failed to copy text: ', err);
        });
      });
    }
  }

  // Handle initialization on page load and swaps
  document.addEventListener('astro:page-load', initAboutPage);
</script>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fadeIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>
