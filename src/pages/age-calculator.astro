---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Age Calculator — Calculate Your Age by Date of Birth"
  description="Free online age calculator to calculate your age by date of birth (DOB). Count exact years, months, days, weeks, and minutes lived, and track your next birthday countdown."
>
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Age Calculator",
      "url": "https://www.cloudyunicorn.com/age-calculator",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "description": "Calculate your precise age in years, months, weeks, and days. Includes birthday count downs and a real-time running counter of seconds lived.",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    }
  </script>

  <div class="relative min-h-[calc(100vh-16rem)] bg-background py-12">
    <div class="absolute inset-0 bg-grid-pattern bg-grid-fade pointer-events-none opacity-20"></div>

    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 space-y-12">
      <!-- Breadcrumbs / Top Nav -->
      <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-xs font-mono text-neutral-500">
        <a href="/" class="hover:text-neutral-600 dark:hover:text-neutral-300">Tools</a>
        <span>/</span>
        <span class="text-neutral-600 dark:text-neutral-300">Age Calculator</span>
      </nav>

      <!-- Section Header -->
      <div class="space-y-4">
        <h1 class="text-3xl sm:text-5xl font-bold tracking-tight text-neutral-900 dark:text-white text-pretty">
          Age Calculator
        </h1>
        <p class="text-neutral-400 max-w-xl text-sm sm:text-base">
          Enter your birth date and a reference date to compute your exact age, detailed lifespans, and next birthday countdown in real time.
        </p>
      </div>

      <!-- Main Columns -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        <!-- Input Form (Left) -->
        <div class="lg:col-span-5 relative z-20 premium-glass-card rounded-xl p-6 space-y-6">
          <form id="age-form" class="space-y-5" novalidate>
            <!-- Date of Birth -->
            <div class="space-y-2 relative" id="birth-date-container">
              <label for="birth-date" class="block text-xs font-mono text-neutral-400 uppercase tracking-widest">
                Date of Birth <span class="text-red-500" aria-hidden="true">*</span>
              </label>
              <div class="relative">
                <input 
                  type="text" 
                  id="birth-date" 
                  name="birthDate" 
                  readonly
                  required 
                  placeholder="Select birth date…"
                  class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded-md h-11 pl-3 pr-10 text-sm text-neutral-900 dark:text-white focus:border-neutral-900 dark:focus:border-white focus:ring-1 focus:ring-neutral-900 dark:focus:ring-white outline-none cursor-pointer transition-colors"
                />
                <button
                  type="button"
                  class="absolute right-3 top-1/2 -translate-y-1/2 text-neutral-500 hover:text-neutral-900 dark:hover:text-white focus-visible:ring-1 focus-visible:ring-neutral-900 dark:focus-visible:ring-white outline-none rounded"
                  aria-label="Open birth date calendar"
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                  </svg>
                </button>
              </div>
              <span id="birth-date-error" class="hidden text-xs text-red-700 dark:text-red-400 font-medium" role="alert"></span>
              
              <!-- Calendar Popup -->
              <div class="hidden absolute left-0 mt-2 z-50 w-72 bg-neutral-50 dark:bg-[#0e0e0e] border border-neutral-200 dark:border-neutral-800 rounded-lg shadow-2xl p-4 space-y-3 calendar-popup" role="dialog" aria-modal="true" aria-label="Birth date calendar picker">
                <div class="flex items-center justify-between gap-1">
                  <button type="button" class="p-1 rounded hover:bg-neutral-100 dark:hover:bg-neutral-800 text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white prev-month-btn" aria-label="Previous month">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                  </button>
                  <div class="flex items-center gap-1.5">
                    <select class="bg-background border border-neutral-200 dark:border-neutral-800 text-xs font-semibold text-neutral-900 dark:text-white px-1.5 py-1 rounded outline-none cursor-pointer month-select" aria-label="Select month"></select>
                    <select class="bg-background border border-neutral-200 dark:border-neutral-800 text-xs font-semibold text-neutral-900 dark:text-white px-1.5 py-1 rounded outline-none cursor-pointer year-select" aria-label="Select year"></select>
                  </div>
                  <button type="button" class="p-1 rounded hover:bg-neutral-100 dark:hover:bg-neutral-800 text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white next-month-btn" aria-label="Next month">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                  </button>
                </div>
                <div class="grid grid-cols-7 text-center text-[10px] font-mono text-neutral-400 dark:text-neutral-500 font-bold border-b border-neutral-200 dark:border-neutral-900 pb-1.5">
                  <span>Su</span><span>Mo</span><span>Tu</span><span>We</span><span>Th</span><span>Fr</span><span>Sa</span>
                </div>
                <div class="grid grid-cols-7 gap-1 text-center text-xs days-grid"></div>
                <div class="flex items-center justify-between border-t border-neutral-200 dark:border-neutral-900 pt-2.5">
                  <button type="button" class="text-[10px] font-mono text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white today-btn font-semibold px-1 py-0.5 rounded">Today</button>
                  <button type="button" class="text-[10px] font-mono text-neutral-500 hover:text-neutral-900 dark:hover:text-white close-btn font-semibold px-1 py-0.5 rounded">Close</button>
                </div>
              </div>
            </div>

            <!-- Reference Date -->
            <div class="space-y-2 relative" id="ref-date-container">
              <label for="ref-date" class="block text-xs font-mono text-neutral-400 uppercase tracking-widest">
                Age at the Date of
              </label>
              <div class="relative">
                <input 
                  type="text" 
                  id="ref-date" 
                  name="refDate" 
                  readonly
                  placeholder="Select reference date…"
                  class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded-md h-11 pl-3 pr-10 text-sm text-neutral-900 dark:text-white focus:border-neutral-900 dark:focus:border-white focus:ring-1 focus:ring-neutral-900 dark:focus:ring-white outline-none cursor-pointer transition-colors"
                />
                <button
                  type="button"
                  class="absolute right-3 top-1/2 -translate-y-1/2 text-neutral-500 hover:text-neutral-900 dark:hover:text-white focus-visible:ring-1 focus-visible:ring-neutral-900 dark:focus-visible:ring-white outline-none rounded"
                  aria-label="Open reference date calendar"
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                  </svg>
                </button>
              </div>
              <span id="ref-date-error" class="hidden text-xs text-red-700 dark:text-red-400 font-medium" role="alert"></span>
              
              <!-- Calendar Popup -->
              <div class="hidden absolute left-0 mt-2 z-50 w-72 bg-neutral-50 dark:bg-[#0e0e0e] border border-neutral-200 dark:border-neutral-800 rounded-lg shadow-2xl p-4 space-y-3 calendar-popup" role="dialog" aria-modal="true" aria-label="Reference date calendar picker">
                <div class="flex items-center justify-between gap-1">
                  <button type="button" class="p-1 rounded hover:bg-neutral-100 dark:hover:bg-neutral-800 text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white prev-month-btn" aria-label="Previous month">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                  </button>
                  <div class="flex items-center gap-1.5">
                    <select class="bg-background border border-neutral-200 dark:border-neutral-800 text-xs font-semibold text-neutral-900 dark:text-white px-1.5 py-1 rounded outline-none cursor-pointer month-select" aria-label="Select month"></select>
                    <select class="bg-background border border-neutral-200 dark:border-neutral-800 text-xs font-semibold text-neutral-900 dark:text-white px-1.5 py-1 rounded outline-none cursor-pointer year-select" aria-label="Select year"></select>
                  </div>
                  <button type="button" class="p-1 rounded hover:bg-neutral-100 dark:hover:bg-neutral-800 text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white next-month-btn" aria-label="Next month">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                  </button>
                </div>
                <div class="grid grid-cols-7 text-center text-[10px] font-mono text-neutral-400 dark:text-neutral-500 font-bold border-b border-neutral-200 dark:border-neutral-900 pb-1.5">
                  <span>Su</span><span>Mo</span><span>Tu</span><span>We</span><span>Th</span><span>Fr</span><span>Sa</span>
                </div>
                <div class="grid grid-cols-7 gap-1 text-center text-xs days-grid"></div>
                <div class="flex items-center justify-between border-t border-neutral-200 dark:border-neutral-900 pt-2.5">
                  <button type="button" class="text-[10px] font-mono text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white today-btn font-semibold px-1 py-0.5 rounded">Today</button>
                  <button type="button" class="text-[10px] font-mono text-neutral-500 hover:text-neutral-900 dark:hover:text-white close-btn font-semibold px-1 py-0.5 rounded">Close</button>
                </div>
              </div>
            </div>

            <!-- Calculate Button -->
            <button
              type="submit"
              id="calc-btn"
              class="w-full h-11 bg-neutral-950 dark:bg-white text-white dark:text-black hover:bg-neutral-800 dark:hover:bg-neutral-200 transition-colors font-semibold text-sm rounded-md focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-neutral-950 dark:focus-visible:ring-white outline-none"
            >
              Calculate Age
            </button>
          </form>
        </div>

        <!-- Output Display (Right) -->
        <div class="lg:col-span-7 space-y-6">
          <!-- Initial Prompt / Empty State (Muted skeleton mode placeholder) -->
          <div id="empty-state" class="hidden"></div>

          <!-- Calculation Results (Muted dashboard footprint by default) -->
          <div id="results-panel" class="space-y-6 opacity-40 pointer-events-none select-none transition-all duration-500">
            <!-- Awaiting Input Status Banner -->
            <div id="dashboard-status-banner" class="border border-dashed border-neutral-300 dark:border-neutral-700 bg-neutral-50/50 dark:bg-neutral-900/30 rounded-xl p-4 text-center text-xs font-mono text-neutral-505 flex items-center justify-center gap-2">
              <span class="inline-block w-2 h-2 rounded-full bg-neutral-400 dark:bg-neutral-600 animate-pulse"></span>
              AWAITING PARAMETERS — CLICK CALCULATE TO POPULATE
            </div>

            <!-- Primary Age Card -->
            <div class="premium-glass-card rounded-xl p-6 space-y-4">
              <h2 class="text-xs font-mono text-neutral-505 uppercase tracking-widest">Calculated Age</h2>
              <div class="grid grid-cols-3 gap-4">
                <div class="premium-glass-card-subtle rounded-lg p-4 text-center">
                  <div id="age-years" class="text-3xl sm:text-4xl font-bold font-mono text-neutral-900 dark:text-white text-glow tabular-nums">—</div>
                  <div class="text-[11px] font-mono text-neutral-505 uppercase mt-1">Years</div>
                </div>
                <div class="premium-glass-card-subtle rounded-lg p-4 text-center">
                  <div id="age-months" class="text-3xl sm:text-4xl font-bold font-mono text-neutral-900 dark:text-white text-glow tabular-nums">—</div>
                  <div class="text-[11px] font-mono text-neutral-505 uppercase mt-1">Months</div>
                </div>
                <div class="premium-glass-card-subtle rounded-lg p-4 text-center">
                  <div id="age-days" class="text-3xl sm:text-4xl font-bold font-mono text-neutral-900 dark:text-white text-glow tabular-nums">—</div>
                  <div class="text-[11px] font-mono text-neutral-505 uppercase mt-1">Days</div>
                </div>
              </div>
            </div>

            <!-- Live Counter Banner (if current date is selected as reference) -->
            <div id="live-banner" class="hidden border border-primary/30 bg-primary/5 rounded-xl p-5 flex items-center justify-between">
              <div class="space-y-1">
                <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full bg-primary/10 border border-primary/20 text-[10px] font-mono text-primary">
                  <span class="w-1.5 h-1.5 rounded-full bg-primary animate-ping"></span>
                  <span>Live Counter</span>
                </span>
                <p class="text-xs text-neutral-500">Total seconds lived, ticking in real time:</p>
              </div>
              <div id="live-seconds" class="text-xl sm:text-2xl font-bold font-mono text-neutral-900 dark:text-white text-glow tabular-nums">
                0
              </div>
            </div>

            <!-- Next Birthday Countdown Card -->
            <div class="premium-glass-card rounded-xl p-6 flex flex-col sm:flex-row items-center justify-between gap-4">
              <div class="space-y-1">
                <h3 class="text-sm font-semibold text-neutral-900 dark:text-white">Next Birthday Countdown</h3>
                <p class="text-xs text-neutral-500 dark:text-neutral-400">Time remaining until your next celebration:</p>
              </div>
              <div class="flex items-baseline gap-1.5">
                <span id="countdown-months" class="text-3xl font-bold font-mono text-neutral-900 dark:text-white tabular-nums">—</span>
                <span class="text-xs font-mono text-neutral-505 uppercase mr-2">mo</span>
                <span id="countdown-days" class="text-3xl font-bold font-mono text-neutral-900 dark:text-white tabular-nums">—</span>
                <span class="text-xs font-mono text-neutral-505 uppercase">days</span>
              </div>
            </div>

            <!-- Detailed Lifespan Grid -->
            <div class="space-y-4">
              <h3 class="text-xs font-mono text-neutral-505 uppercase tracking-widest">Lifespan Breakdown</h3>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="premium-glass-card-subtle rounded-lg p-4 flex items-center justify-between">
                  <span class="text-xs font-medium text-neutral-500 dark:text-neutral-400">Total Months Lived</span>
                  <span id="total-months" class="text-sm font-bold font-mono text-neutral-900 dark:text-white tabular-nums">—</span>
                </div>
                <div class="premium-glass-card-subtle rounded-lg p-4 flex items-center justify-between">
                  <span class="text-xs font-medium text-neutral-500 dark:text-neutral-400">Total Weeks Lived</span>
                  <span id="total-weeks" class="text-sm font-bold font-mono text-neutral-900 dark:text-white tabular-nums">—</span>
                </div>
                <div class="premium-glass-card-subtle rounded-lg p-4 flex items-center justify-between">
                  <span class="text-xs font-medium text-neutral-500 dark:text-neutral-400">Total Days Lived</span>
                  <span id="total-days" class="text-sm font-bold font-mono text-neutral-900 dark:text-white tabular-nums">—</span>
                </div>
                <div class="premium-glass-card-subtle rounded-lg p-4 flex items-center justify-between">
                  <span class="text-xs font-medium text-neutral-500 dark:text-neutral-400">Total Hours Lived</span>
                  <span id="total-hours" class="text-sm font-bold font-mono text-neutral-900 dark:text-white tabular-nums">—</span>
                </div>
                <div class="premium-glass-card-subtle rounded-lg p-4 flex items-center justify-between sm:col-span-2">
                  <span class="text-xs font-medium text-neutral-500 dark:text-neutral-400">Total Minutes Lived</span>
                  <span id="total-minutes" class="text-sm font-bold font-mono text-neutral-900 dark:text-white tabular-nums">—</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Internal Navigation Matrix Section -->
      <section class="border-t border-neutral-200 dark:border-neutral-800 pt-12 mt-12 animate-fade-in">
        <h3 class="text-xs font-mono text-neutral-400 dark:text-neutral-500 uppercase tracking-widest mb-6 text-center sm:text-left">Companion Utilities</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <a href="/bmi-calculator" class="group block p-5 border border-neutral-200 dark:border-neutral-800 hover:border-neutral-400 dark:hover:border-neutral-600 bg-neutral-50/20 dark:bg-neutral-900/10 rounded-xl transition-all duration-300">
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm font-semibold text-neutral-900 dark:text-white group-hover:text-glow">BMI Calculator</span>
              <svg class="w-4 h-4 text-neutral-400 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
            </div>
            <p class="text-xs text-neutral-500 dark:text-neutral-400 leading-relaxed">Calculate your Body Mass Index (BMI) and check your healthy weight categories.</p>
          </a>
          <a href="/calories-calculator" class="group block p-5 border border-neutral-200 dark:border-neutral-800 hover:border-neutral-400 dark:hover:border-neutral-600 bg-neutral-50/20 dark:bg-neutral-900/10 rounded-xl transition-all duration-300">
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm font-semibold text-neutral-900 dark:text-white group-hover:text-glow">Calories Calculator</span>
              <svg class="w-4 h-4 text-neutral-400 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
            </div>
            <p class="text-xs text-neutral-500 dark:text-neutral-400 leading-relaxed">Estimate your Basal Metabolic Rate (BMR), TDEE, and customized macro balance for fitness targets.</p>
          </a>
        </div>
      </section>

      <!-- SEO Informational Content Section -->
      <section class="border-t border-neutral-200 dark:border-neutral-800 pt-16 mt-16 text-neutral-600 dark:text-neutral-400 animate-fade-in">
        <div class="max-w-3xl mx-auto space-y-12">
          
          <!-- Section Header -->
          <div class="text-center space-y-4">
            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-mono font-semibold bg-neutral-100 dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 text-neutral-600 dark:text-neutral-300">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
              COMPLETE CHRONOLOGY GUIDE
            </span>
            <h2 class="text-3xl font-extrabold text-neutral-900 dark:text-white tracking-tight">
              Understanding Age Calculation &amp; Milestones
            </h2>
            <p class="text-sm leading-relaxed text-neutral-500 dark:text-neutral-400 text-pretty">
              Have you ever wondered: <em>"How can I calculate my age online quickly?"</em> Or perhaps you need to verify an exact age for a legal form, gym membership, or school enrollment. Our online <strong>age calculator</strong> is designed to perform precise, real-time calculations. Whether you refer to it as a <strong>date of birth calculator</strong>, a <strong>dob calculator</strong>, or a <strong>birthday calculator</strong>, our tool makes it easy to <strong>calculate your age</strong> down to the exact second.
            </p>
          </div>

          <!-- Interactive Accordion List -->
          <div class="divide-y divide-neutral-200 dark:divide-neutral-800 border-t border-b border-neutral-200 dark:border-neutral-800">
            
            <!-- Question 1 -->
            <details class="group py-5 [&_summary::-webkit-details-marker]:hidden">
              <summary class="flex justify-between items-center font-semibold text-sm sm:text-base text-neutral-900 dark:text-white cursor-pointer select-none">
                <span class="flex items-center gap-3">
                  <span class="text-xs font-mono font-bold text-neutral-400 dark:text-neutral-500">01</span>
                  How do I use this online age calculator by birth date?
                </span>
                <span class="transition-transform duration-200 group-open:rotate-180 text-neutral-400">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </span>
              </summary>
              <div class="mt-3 text-xs sm:text-sm text-neutral-500 dark:text-neutral-400 leading-relaxed pl-8 pr-4">
                To <strong>calculate current age</strong> or run a <strong>date to date age calculator</strong> query, simply select your DOB in the first field. Then choose the target reference date (it defaults to the <strong>age calculator today</strong>). Our tool acts as an <strong>age finder</strong>, immediately computing the years, months, and days elapsed.
              </div>
            </details>

            <!-- Question 2 -->
            <details class="group py-5 [&_summary::-webkit-details-marker]:hidden" open>
              <summary class="flex justify-between items-center font-semibold text-sm sm:text-base text-neutral-900 dark:text-white cursor-pointer select-none">
                <span class="flex items-center gap-3">
                  <span class="text-xs font-mono font-bold text-neutral-400 dark:text-neutral-500">02</span>
                  Can I calculate my age using date of birth on mobile?
                </span>
                <span class="transition-transform duration-200 group-open:rotate-180 text-neutral-400">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </span>
              </summary>
              <div class="mt-3 text-xs sm:text-sm text-neutral-500 dark:text-neutral-400 leading-relaxed pl-8 pr-4">
                Absolutely! This site is built with a responsive design, functioning seamlessly like an <strong>age finder app</strong> or <strong>age calculator app</strong> on any smartphone. Whether you need to <strong>find age by dob</strong> or <strong>work out age from dob</strong> on the move, the layout adjusts beautifully.
              </div>
            </details>

            <!-- Question 3 -->
            <details class="group py-5 [&_summary::-webkit-details-marker]:hidden">
              <summary class="flex justify-between items-center font-semibold text-sm sm:text-base text-neutral-900 dark:text-white cursor-pointer select-none">
                <span class="flex items-center gap-3">
                  <span class="text-xs font-mono font-bold text-neutral-400 dark:text-neutral-500">03</span>
                  Can I work out my birth year from age?
                </span>
                <span class="transition-transform duration-200 group-open:rotate-180 text-neutral-400">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </span>
              </summary>
              <div class="mt-3 text-xs sm:text-sm text-neutral-500 dark:text-neutral-400 leading-relaxed pl-8 pr-4">
                Yes, if you know your current age, you can easily use this tool as a <strong>birth year calculator by age</strong> or <strong>year born calculator</strong>. By placing your target reference age and working backwards, you can determine the exact calendar year you were born, acting as a handy <strong>born date calculator</strong>.
              </div>
            </details>

            <!-- Question 4 -->
            <details class="group py-5 [&_summary::-webkit-details-marker]:hidden">
