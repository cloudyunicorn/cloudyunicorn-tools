---
import Layout from '../layouts/Layout.astro';
import SocialShare from '../components/SocialShare.astro';
---

<Layout 
  title="SaaS Cash Burn Rate & Startup Runway Calculator"
  description="Calculate your startup runway, gross monthly burn, net burn, and default alive status. Use our cash burn rate calculator to model expense and growth projections."
>
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "SaaS Cost Burn & Runway Calculator",
      "url": "https://www.cloudyunicorn.com/saas-cost-burn-calculator",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "description": "Calculate SaaS startup runway, gross burn, net burn, and default alive/dead status. Interactive projections and expense manager.",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    }
  </script>

  <div class="relative min-h-[calc(100vh-16rem)] bg-background py-12">
    <div class="absolute inset-0 bg-grid-pattern bg-grid-fade pointer-events-none opacity-20"></div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 space-y-12">
      <!-- Breadcrumbs -->
      <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-xs font-mono text-neutral-500">
        <a href="/" class="hover:text-neutral-600 dark:hover:text-neutral-300">Tools</a>
        <span>/</span>
        <span class="text-neutral-600 dark:text-neutral-300">SaaS Cost Burn Calculator</span>
      </nav>

      <!-- Section Header -->
      <div class="space-y-4">
        <h1 class="text-3xl sm:text-5xl font-bold tracking-tight text-neutral-900 dark:text-white text-pretty">
          SaaS Cost Burn & Runway Calculator
        </h1>
        <p class="text-neutral-400 max-w-2xl text-sm sm:text-base">
          Evaluate your startup’s financial coordinates. Input your cash balance and MRR, add itemized operational expenses, and model scenarios to verify if you are Default Alive.
        </p>
      </div>

      <!-- Main Columns -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        
        <!-- Inputs & Expense Manager (Left) -->
        <div class="lg:col-span-7 space-y-6">
          
          <!-- Financial Coordinates -->
          <div class="premium-glass-card rounded-xl p-6 space-y-5">
            <h2 class="text-lg font-bold text-neutral-900 dark:text-white flex items-center gap-2">
              <svg class="w-5 h-5 text-neutral-400 dark:text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
              </svg>
              Financial Coordinates
            </h2>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <!-- Starting Cash -->
              <div class="space-y-2">
                <label for="starting-cash" class="block text-xs font-mono text-neutral-400 uppercase tracking-widest">
                  Starting Cash ($)
                </label>
                <div class="relative">
                  <span class="absolute left-3 top-1/2 -translate-y-1/2 text-sm text-neutral-500 font-mono">$</span>
                  <input 
                    type="number" 
                    id="starting-cash" 
                    min="0" 
                    step="1000" 
                    value="150000"
                    placeholder="e.g. 150000"
                    class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded-md h-11 pl-8 pr-3 text-sm text-neutral-900 dark:text-white focus:border-neutral-900 dark:focus:border-white focus:ring-1 focus:ring-neutral-900 dark:focus:ring-white outline-none transition-colors font-mono"
                  />
                </div>
              </div>

              <!-- Starting MRR -->
              <div class="space-y-2">
                <label for="starting-mrr" class="block text-xs font-mono text-neutral-400 uppercase tracking-widest">
                  Current MRR ($)
                </label>
                <div class="relative">
                  <span class="absolute left-3 top-1/2 -translate-y-1/2 text-sm text-neutral-500 font-mono">$</span>
                  <input 
                    type="number" 
                    id="starting-mrr" 
                    min="0" 
                    step="100" 
                    value="8000"
                    placeholder="e.g. 8000"
                    class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded-md h-11 pl-8 pr-3 text-sm text-neutral-900 dark:text-white focus:border-neutral-900 dark:focus:border-white focus:ring-1 focus:ring-neutral-900 dark:focus:ring-white outline-none transition-colors font-mono"
                  />
                </div>
              </div>
            </div>

            <!-- MRR Growth Rate -->
            <div class="space-y-3 pt-2">
              <div class="flex justify-between items-center text-xs font-mono text-neutral-400 uppercase tracking-widest">
                <span>Monthly MRR Growth Rate</span>
                <span class="text-neutral-900 dark:text-white font-bold text-sm" id="mrr-growth-val">6.5%</span>
              </div>
              <div class="flex items-center gap-4">
                <input 
                  type="range" 
                  id="mrr-growth" 
                  min="0" 
                  max="40" 
                  step="0.5" 
                  value="6.5" 
                  class="flex-1 accent-neutral-900 dark:accent-white cursor-pointer h-1.5 bg-neutral-200 dark:bg-neutral-800 rounded-lg appearance-none"
                  aria-label="Monthly MRR Growth Rate Slider"
                />
              </div>
            </div>
          </div>

          <!-- Expense Manager -->
          <div class="premium-glass-card rounded-xl p-6 space-y-6">
            <div class="flex items-center justify-between">
              <h2 class="text-lg font-bold text-neutral-900 dark:text-white flex items-center gap-2">
                <svg class="w-5 h-5 text-neutral-400 dark:text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                </svg>
                Operational Expense Builder
              </h2>
              <span class="text-xs font-mono text-neutral-500" id="expense-count">0 items</span>
            </div>

            <!-- Expense List -->
            <div class="space-y-2 max-h-[300px] overflow-y-auto pr-1 scrollbar-thin" id="expense-list">
              <!-- Dynamically populated -->
            </div>

            <div class="border-t border-neutral-200 dark:border-neutral-800 pt-5 space-y-4">
              <h3 class="text-xs font-mono text-neutral-400 uppercase tracking-widest">Add Custom or Preset Expense</h3>
              
              <!-- Quick presets -->
              <div class="flex flex-wrap gap-1.5" id="expense-presets">
                <span class="text-[10px] font-mono text-neutral-500 self-center mr-1">Presets:</span>
                <button type="button" data-preset="aws" class="px-2.5 py-1 text-[11px] font-medium rounded-full bg-neutral-100 dark:bg-neutral-900 hover:bg-neutral-200 dark:hover:bg-neutral-800 border border-neutral-200 dark:border-neutral-800 text-neutral-700 dark:text-neutral-300 transition-colors cursor-pointer">AWS</button>
                <button type="button" data-preset="supabase" class="px-2.5 py-1 text-[11px] font-medium rounded-full bg-neutral-100 dark:bg-neutral-900 hover:bg-neutral-200 dark:hover:bg-neutral-800 border border-neutral-200 dark:border-neutral-800 text-neutral-700 dark:text-neutral-300 transition-colors cursor-pointer">Supabase</button>
                <button type="button" data-preset="vercel" class="px-2.5 py-1 text-[11px] font-medium rounded-full bg-neutral-100 dark:bg-neutral-900 hover:bg-neutral-200 dark:hover:bg-neutral-800 border border-neutral-200 dark:border-neutral-800 text-neutral-700 dark:text-neutral-300 transition-colors cursor-pointer">Vercel</button>
                <button type="button" data-preset="openai" class="px-2.5 py-1 text-[11px] font-medium rounded-full bg-neutral-100 dark:bg-neutral-900 hover:bg-neutral-200 dark:hover:bg-neutral-800 border border-neutral-200 dark:border-neutral-800 text-neutral-700 dark:text-neutral-300 transition-colors cursor-pointer">OpenAI API</button>
                <button type="button" data-preset="slack" class="px-2.5 py-1 text-[11px] font-medium rounded-full bg-neutral-100 dark:bg-neutral-900 hover:bg-neutral-200 dark:hover:bg-neutral-800 border border-neutral-200 dark:border-neutral-800 text-neutral-700 dark:text-neutral-300 transition-colors cursor-pointer">Slack</button>
                <button type="button" data-preset="google" class="px-2.5 py-1 text-[11px] font-medium rounded-full bg-neutral-100 dark:bg-neutral-900 hover:bg-neutral-200 dark:hover:bg-neutral-800 border border-neutral-200 dark:border-neutral-800 text-neutral-700 dark:text-neutral-300 transition-colors cursor-pointer">Google Workspace</button>
                <button type="button" data-preset="github" class="px-2.5 py-1 text-[11px] font-medium rounded-full bg-neutral-100 dark:bg-neutral-900 hover:bg-neutral-200 dark:hover:bg-neutral-800 border border-neutral-200 dark:border-neutral-800 text-neutral-700 dark:text-neutral-300 transition-colors cursor-pointer">GitHub</button>
                <button type="button" data-preset="founder" class="px-2.5 py-1 text-[11px] font-medium rounded-full bg-neutral-100 dark:bg-neutral-900 hover:bg-neutral-200 dark:hover:bg-neutral-800 border border-neutral-200 dark:border-neutral-800 text-neutral-700 dark:text-neutral-300 transition-colors cursor-pointer">Founder Salary</button>
                <button type="button" data-preset="ads" class="px-2.5 py-1 text-[11px] font-medium rounded-full bg-neutral-100 dark:bg-neutral-900 hover:bg-neutral-200 dark:hover:bg-neutral-800 border border-neutral-200 dark:border-neutral-800 text-neutral-700 dark:text-neutral-300 transition-colors cursor-pointer">Meta/Google Ads</button>
              </div>

              <!-- Input fields for new expense -->
              <div class="grid grid-cols-1 sm:grid-cols-12 gap-3 items-end">
                <div class="sm:col-span-4 space-y-1.5">
                  <label for="new-expense-name" class="block text-[10px] font-mono text-neutral-500 uppercase tracking-wider">Expense Name</label>
                  <input type="text" id="new-expense-name" placeholder="e.g. Supabase..." class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded h-10 px-3 text-xs text-neutral-900 dark:text-white outline-none focus:border-neutral-900 dark:focus:border-white" />
                </div>
                <div class="sm:col-span-3 space-y-1.5">
                  <label for="new-expense-amount" class="block text-[10px] font-mono text-neutral-500 uppercase tracking-wider">Amount ($/mo)</label>
                  <div class="relative">
                    <span class="absolute left-2.5 top-1/2 -translate-y-1/2 text-xs text-neutral-500 font-mono">$</span>
                    <input type="number" id="new-expense-amount" placeholder="25" class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded h-10 pl-6 pr-3 text-xs text-neutral-900 dark:text-white outline-none focus:border-neutral-900 dark:focus:border-white font-mono" />
                  </div>
                </div>
                <div class="sm:col-span-3 space-y-1.5">
                  <label for="new-expense-category" class="block text-[10px] font-mono text-neutral-500 uppercase tracking-wider">Category</label>
                  <select id="new-expense-category" class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded h-10 px-2 text-xs text-neutral-900 dark:text-white outline-none focus:border-neutral-900 dark:focus:border-white cursor-pointer">
                    <option value="infra">Infrastructure</option>
                    <option value="saas-api">SaaS &amp; APIs</option>
                    <option value="marketing">Marketing</option>
                    <option value="payroll">Payroll / Salary</option>
                    <option value="other">Other Operations</option>
                  </select>
                </div>
                <div class="sm:col-span-2">
                  <button type="button" id="add-expense-btn" class="w-full h-10 bg-neutral-950 dark:bg-neutral-50 text-white dark:text-black font-semibold text-xs rounded hover:bg-neutral-900 dark:hover:bg-neutral-100 transition-colors border border-neutral-950 dark:border-neutral-50 cursor-pointer">
                    Add
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Dashboard Outputs & Charts (Right) -->
        <div class="lg:col-span-5 space-y-6">
          
          <!-- Health Dashboard Status Widget -->
          <div id="health-widget" class="relative overflow-hidden rounded-xl border p-6 flex flex-col justify-between transition-all duration-300 bg-neutral-50/50 dark:bg-neutral-900/10 border-neutral-200 dark:border-neutral-800 shadow-sm">
            <!-- Background glow -->
            <div id="health-glow" class="absolute top-0 right-0 -mt-6 -mr-6 w-44 h-44 blur-3xl rounded-full pointer-events-none opacity-40 transition-all duration-300 bg-brand-blue"></div>

            <div class="relative z-10 space-y-5">
              <div class="flex items-center justify-between">
                <span class="text-xs font-mono uppercase tracking-widest text-neutral-500">Runway Forecast</span>
                <span id="health-badge" class="text-[10px] font-mono font-bold uppercase py-0.5 px-2.5 rounded-full border">
                  Calculating...
                </span>
              </div>

              <!-- Main Runway Number -->
              <div class="space-y-1">
                <div class="flex items-baseline gap-2">
                  <span id="runway-value" class="text-5xl font-extrabold tracking-tight text-neutral-900 dark:text-white font-mono">
                    --
                  </span>
                  <span id="runway-unit" class="text-sm font-mono text-neutral-500">Months</span>
                </div>
                <p id="runway-summary" class="text-xs text-neutral-500 leading-relaxed font-light">
                  Input coordinates to forecast cash longevity.
                </p>
              </div>

              <!-- Details Grid -->
              <div class="grid grid-cols-2 gap-4 pt-4 border-t border-neutral-200/50 dark:border-neutral-800/50 text-xs">
                <div class="space-y-1">
                  <span class="block text-neutral-400 font-mono uppercase text-[10px]">Gross Burn</span>
                  <span id="gross-burn-val" class="font-bold text-neutral-900 dark:text-white font-mono text-sm">--</span>
                </div>
                <div class="space-y-1">
                  <span class="block text-neutral-400 font-mono uppercase text-[10px]">Net Burn</span>
                  <span id="net-burn-val" class="font-bold text-neutral-900 dark:text-white font-mono text-sm">--</span>
                </div>
                <div class="space-y-1 col-span-2">
                  <span class="block text-neutral-400 font-mono uppercase text-[10px]">Break-even Target</span>
                  <span id="break-even-val" class="font-bold text-neutral-900 dark:text-white font-mono text-sm">--</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Scenario Ajustment Levers -->
          <div class="premium-glass-card rounded-xl p-6 space-y-5">
            <h2 class="text-xs font-mono text-neutral-400 uppercase tracking-widest">Scenario Adjustments</h2>
            
            <!-- Expense cut level slider -->
            <div class="space-y-2">
              <div class="flex justify-between items-center text-xs font-mono">
                <span class="text-neutral-400">Software/Ops Cost Cut</span>
                <span class="text-neutral-900 dark:text-white font-semibold" id="cost-cut-val">0%</span>
              </div>
              <input 
                type="range" 
                id="cost-cut" 
                min="0" 
                max="50" 
                step="5" 
                value="0" 
                class="w-full accent-neutral-900 dark:accent-white cursor-pointer h-1.5 bg-neutral-200 dark:bg-neutral-800 rounded-lg appearance-none"
                aria-label="Software and Operations Cost Cut Slider"
              />
              <span class="block text-[10px] text-neutral-500 font-light">Applies only to non-payroll/non-salary operating expenses.</span>
            </div>

            <!-- Quick Presets -->
            <div class="grid grid-cols-3 gap-2 pt-2">
              <button type="button" id="scenario-conser" class="px-2 py-1.5 text-[10px] font-mono border border-neutral-200 dark:border-neutral-800 hover:border-neutral-900 dark:hover:border-white rounded bg-neutral-50 dark:bg-neutral-900 text-neutral-600 dark:text-neutral-400 transition-colors cursor-pointer">Conservative</button>
              <button type="button" id="scenario-base" class="px-2 py-1.5 text-[10px] font-mono border border-neutral-200 dark:border-neutral-800 hover:border-neutral-900 dark:hover:border-white rounded bg-neutral-50 dark:bg-neutral-900 text-neutral-600 dark:text-neutral-400 transition-colors cursor-pointer">Base Case</button>
              <button type="button" id="scenario-optim" class="px-2 py-1.5 text-[10px] font-mono border border-neutral-200 dark:border-neutral-800 hover:border-neutral-900 dark:hover:border-white rounded bg-neutral-50 dark:bg-neutral-900 text-neutral-600 dark:text-neutral-400 transition-colors cursor-pointer">High Growth</button>
            </div>
          </div>

          <!-- Sharing & Utilities -->
          <div class="premium-glass-card rounded-xl p-5 flex flex-col sm:flex-row gap-3">
            <button 
              type="button" 
              id="share-btn" 
              class="flex-1 inline-flex items-center justify-center gap-2 h-10 px-4 rounded bg-neutral-100 dark:bg-neutral-900 hover:bg-neutral-200 dark:hover:bg-neutral-800 border border-neutral-200 dark:border-neutral-800 text-xs font-semibold text-neutral-800 dark:text-neutral-200 transition-all duration-150 cursor-pointer"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.684 10.742l4.622-2.311m0 0a3 3 0 114.243 4.243l-4.622 2.311m0 0a3 3 0 11-4.243-4.243m4.622-2.311l4.622 2.311"></path>
              </svg>
              Share Configuration
            </button>
            <button 
              type="button" 
              id="print-btn" 
              class="flex-1 inline-flex items-center justify-center gap-2 h-10 px-4 rounded bg-neutral-100 dark:bg-neutral-900 hover:bg-neutral-200 dark:hover:bg-neutral-800 border border-neutral-200 dark:border-neutral-800 text-xs font-semibold text-neutral-800 dark:text-neutral-200 transition-all duration-150 cursor-pointer"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path>
              </svg>
              Export Report / Print
            </button>
          </div>
        </div>
      </div>

      <!-- Graph & Table Projections (Full width underneath) -->
      <div class="grid grid-cols-1 gap-8">
        
        <!-- Interactive Projection Graph Card -->
        <div class="premium-glass-card rounded-xl p-6 space-y-4">
          <div class="flex items-center justify-between">
            <div>
              <h2 class="text-lg font-bold text-neutral-900 dark:text-white">Cash &amp; Revenue Projection (24-Month)</h2>
              <p class="text-xs text-neutral-500 font-light">Interactive trajectory showing cash reserves and monthly recurring revenue.</p>
            </div>
            <div class="flex items-center gap-4 text-[10px] font-mono uppercase tracking-wider text-neutral-400">
              <span class="flex items-center gap-1.5"><span class="w-2.5 h-0.5 bg-brand-blue inline-block"></span> Cash</span>
              <span class="flex items-center gap-1.5"><span class="w-2.5 h-0.5 bg-brand-green inline-block"></span> MRR</span>
              <span class="flex items-center gap-1.5"><span class="w-2.5 h-0.5 border-t border-dashed border-neutral-400 dark:border-neutral-600 inline-block"></span> Burn</span>
            </div>
          </div>

          <!-- Dynamic SVG Graph Container -->
          <div class="relative w-full h-[260px] sm:h-[300px] bg-neutral-50/25 dark:bg-neutral-900/5 rounded-lg border border-neutral-100 dark:border-neutral-900 p-2 sm:p-4 overflow-hidden select-none" id="chart-container">
            <svg id="projection-chart" class="w-full h-full" viewBox="0 0 600 240" preserveAspectRatio="none">
              <!-- Grid lines & content populated dynamically via JS -->
            </svg>
            
            <!-- Hover Tooltip -->
            <div id="chart-tooltip" class="hidden absolute top-4 left-4 z-30 bg-neutral-950/95 dark:bg-neutral-50/95 text-white dark:text-black text-xs rounded shadow-lg p-2.5 border border-neutral-800 dark:border-neutral-200 pointer-events-none space-y-1 font-mono">
              <!-- Dynamically populated -->
            </div>
          </div>
        </div>

        <!-- Tabular breakdown of the projections -->
        <div class="premium-glass-card rounded-xl overflow-hidden">
          <button type="button" id="toggle-table-btn" class="w-full p-6 flex items-center justify-between bg-neutral-50/20 dark:bg-neutral-900/10 hover:bg-neutral-50/45 dark:hover:bg-neutral-900/25 transition-colors font-bold text-left text-neutral-900 dark:text-white cursor-pointer">
            <span class="text-sm uppercase font-mono tracking-wider">Show Monthly Breakdown Sheet</span>
            <svg id="table-arrow-icon" class="w-4 h-4 transform transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>

          <div id="projection-table-container" class="hidden border-t border-neutral-200 dark:border-neutral-800">
            <div class="overflow-x-auto">
              <table class="w-full text-left text-xs border-collapse">
                <thead>
                  <tr class="bg-neutral-50/40 dark:bg-[#0c0c0e] text-neutral-400 font-mono uppercase tracking-wider border-b border-neutral-200 dark:border-neutral-800 text-[10px]">
                    <th class="py-3.5 px-4 font-semibold">Month</th>
                    <th class="py-3.5 px-4 font-semibold text-right">Cash Balance</th>
                    <th class="py-3.5 px-4 font-semibold text-right">MRR</th>
                    <th class="py-3.5 px-4 font-semibold text-right">Gross Burn</th>
                    <th class="py-3.5 px-4 font-semibold text-right">Net Burn</th>
                    <th class="py-3.5 px-4 font-semibold text-right">Runway Status</th>
                  </tr>
                </thead>
                <tbody id="projection-table-body" class="divide-y divide-neutral-200/50 dark:divide-neutral-800/50 font-mono">
                  <!-- Dynamically populated -->
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Informative Article/FAQ section (SEO) -->
        <div class="space-y-12 pt-12 border-t border-neutral-200 dark:border-neutral-900">
          <!-- Section Header -->
          <div class="text-center space-y-4 animate-fade-in">
            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-mono font-semibold bg-neutral-100 dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 text-neutral-600 dark:text-neutral-300">
              <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 animate-pulse"></span>
              STARTUP FINANCE GUIDE
            </span>
            <h2 class="text-3xl font-extrabold text-neutral-900 dark:text-white tracking-tight">
              Understanding Startup Cash Burn Rate &amp; Runway
            </h2>
            <p class="text-neutral-500 dark:text-neutral-400 max-w-2xl mx-auto text-sm text-pretty">
              Use our guide to understand the key financial metrics, formulas, and terminology to keep your company healthy and calculate how long your cash will last.
            </p>
          </div>

          <!-- FAQ Accordion -->
          <div class="max-w-4xl mx-auto divide-y divide-neutral-200 dark:divide-neutral-800 border-t border-b border-neutral-200 dark:border-neutral-800">
            
            <!-- FAQ 1: Definition & Meaning -->
            <details class="group py-5 [&_summary::-webkit-details-marker]:hidden" open>
              <summary class="flex justify-between items-center font-semibold text-sm sm:text-base text-neutral-900 dark:text-white cursor-pointer select-none">
                <span class="flex items-center gap-3">
                  <span class="text-xs font-mono font-bold text-neutral-400 dark:text-neutral-500">01</span>
                  What is the burn rate and what does it mean?
                </span>
                <span class="transition-transform duration-200 group-open:rotate-180 text-neutral-400">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </span>
              </summary>
              <div class="mt-3 text-xs sm:text-sm text-neutral-505 dark:text-neutral-400 leading-relaxed pl-8 pr-4 space-y-2">
                <p>
                  To <strong>define burn rate</strong>, it is the speed at which a new company or startup spends its venture capital or cash reserves before generating positive cash flow. 
                </p>
                <p>
                  A standard <strong>burn rate definition</strong> separates it into gross burn and net burn. The <strong>cash burn definition</strong> focuses on net burn, which is the net amount of cash a business loses monthly. Understanding your <strong>burn rate meaning</strong> and <strong>cash burn meaning</strong> is critical for survival: it tells you how fast your runway is shrinking and when you need to raise more capital or reach break-even.
                </p>
              </div>
            </details>

            <!-- FAQ 2: Formulas -->
            <details class="group py-5 [&_summary::-webkit-details-marker]:hidden">
              <summary class="flex justify-between items-center font-semibold text-sm sm:text-base text-neutral-900 dark:text-white cursor-pointer select-none">
                <span class="flex items-center gap-3">
                  <span class="text-xs font-mono font-bold text-neutral-400 dark:text-neutral-500">02</span>
                  What is the burn rate formula?
                </span>
                <span class="transition-transform duration-200 group-open:rotate-180 text-neutral-400">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </span>
              </summary>
              <div class="mt-3 text-xs sm:text-sm text-neutral-505 dark:text-neutral-400 leading-relaxed pl-8 pr-4 space-y-3">
                <p>
                  The standard <strong>burn rate formula</strong> or <strong>cash burn formula</strong> depends on whether you are calculating Gross Burn or Net Burn:
                </p>
                <div class="bg-neutral-50 dark:bg-neutral-900 p-4 rounded-lg space-y-2 font-mono text-[11px] border border-neutral-150 dark:border-neutral-850">
                  <div><strong>Gross Burn Rate Formula</strong> = Total Monthly Operating Expenses</div>
                  <div class="pt-2 border-t border-neutral-200 dark:border-neutral-800"><strong>Net Cash Burn Rate Formula</strong> = Total Monthly Operating Expenses - Monthly Revenue</div>
                </div>
                <p>
                  For example, if your monthly expenses are $15,000 and your monthly recurring revenue is $5,000, your <strong>cash burn rate formula</strong> yields a net cash burn of $10,000 per month.
                </p>
              </div>
            </details>

            <!-- FAQ 3: Calculation and Projections -->
            <details class="group py-5 [&_summary::-webkit-details-marker]:hidden">
              <summary class="flex justify-between items-center font-semibold text-sm sm:text-base text-neutral-900 dark:text-white cursor-pointer select-none">
                <span class="flex items-center gap-3">
                  <span class="text-xs font-mono font-bold text-neutral-400 dark:text-neutral-500">03</span>
                  How do I calculate my startup's cash burn rate?
                </span>
                <span class="transition-transform duration-200 group-open:rotate-180 text-neutral-400">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </span>
              </summary>
              <div class="mt-3 text-xs sm:text-sm text-neutral-505 dark:text-neutral-400 leading-relaxed pl-8 pr-4 space-y-2">
                <p>
                  To <strong>calculate cash burn rate</strong>, you need to review your cash balance over a specific period. The simplest <strong>cash burn calculation</strong> takes the starting cash balance, subtracts the ending cash balance, and divides it by the months elapsed:
                </p>
                <div class="bg-neutral-50 dark:bg-neutral-900 p-4 rounded-lg font-mono text-[11px] border border-neutral-150 dark:border-neutral-850">
                  <strong>Monthly Cash Burn Rate</strong> = (Starting Cash - Ending Cash) / Months Elapsed
                </div>
                <p>
                  Our interactive <strong>burn rate calculator</strong> automates this process by letting you itemize your software, infrastructure, marketing, and payroll costs. It calculates your <strong>monthly burn rate</strong>, <strong>monthly cash burn</strong>, and <strong>monthly cash burn rate</strong> in real-time, giving you a 24-month trajectory visual so you can simulate growth and cost cutting scenarios.
