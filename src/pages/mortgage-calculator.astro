---
import Layout from '../layouts/Layout.astro';
import SocialShare from '../components/SocialShare.astro';
---

<Layout 
  title="Mortgage Payment Calculator with Amortization Schedule"
  description="Calculate your monthly home payments including principal, interest, taxes, insurance, HOA, and PMI. Model amortization schedules, refinance loans, and extra payoffs."
>
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Comprehensive Mortgage & Amortization Calculator",
      "url": "https://www.cloudyunicorn.com/mortgage-calculator",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "description": "Calculate monthly home loan payments, PMI threshold drop-offs, and property taxes. Simulate extra payments to calculate years and interest saved.",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    }
  </script>

  <div class="relative min-h-[calc(100vh-16rem)] bg-background py-12">
    <div class="absolute inset-0 bg-grid-pattern bg-grid-fade pointer-events-none opacity-20"></div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 space-y-12">
      <!-- Breadcrumbs -->
      <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-xs font-mono text-neutral-500">
        <a href="/" class="hover:text-neutral-600 dark:hover:text-neutral-300">Tools</a>
        <span>/</span>
        <span class="text-neutral-600 dark:text-neutral-300">Mortgage Calculator</span>
      </nav>

      <!-- Section Header -->
      <div class="space-y-4">
        <h1 class="text-3xl sm:text-5xl font-bold tracking-tight text-neutral-900 dark:text-white text-pretty">
          Comprehensive Mortgage Calculator
        </h1>
        <p class="text-neutral-400 max-w-2xl text-sm sm:text-base">
          Determine your full monthly house payment with principal, interest, taxes, insurance, HOA, and PMI. Model accelerated payoff schedules to calculate interest and time saved.
        </p>
      </div>

      <!-- Main Columns -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        
        <!-- Inputs & Setup (Left) -->
        <div class="lg:col-span-7 space-y-6">
          
          <!-- Loan Details Card -->
          <div class="premium-glass-card rounded-xl p-6 space-y-5">
            <h2 class="text-lg font-bold text-neutral-900 dark:text-white flex items-center gap-2">
              <svg class="w-5 h-5 text-neutral-400 dark:text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
              </svg>
              Mortgage Purchase Coordinates
            </h2>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <!-- Home Price -->
              <div class="space-y-2">
                <label for="home-price" class="block text-xs font-mono text-neutral-400 uppercase tracking-widest">
                  Home Price ($)
                </label>
                <div class="relative">
                  <span class="absolute left-3 top-1/2 -translate-y-1/2 text-sm text-neutral-500 font-mono">$</span>
                  <input 
                    type="number" 
                    id="home-price" 
                    min="1000" 
                    step="5000" 
                    value="400000"
                    placeholder="e.g. 400000"
                    class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded-md h-11 pl-8 pr-3 text-sm text-neutral-900 dark:text-white focus:border-neutral-900 dark:focus:border-white focus:ring-1 focus:ring-neutral-900 dark:focus:ring-white outline-none transition-colors font-mono"
                  />
                </div>
              </div>

              <!-- Interest Rate -->
              <div class="space-y-2">
                <label for="interest-rate" class="block text-xs font-mono text-neutral-400 uppercase tracking-widest">
                  Interest Rate (%)
                </label>
                <div class="relative">
                  <input 
                    type="number" 
                    id="interest-rate" 
                    min="0.1" 
                    max="25" 
                    step="0.05" 
                    value="6.5"
                    placeholder="e.g. 6.5"
                    class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded-md h-11 pl-3 pr-8 text-sm text-neutral-900 dark:text-white focus:border-neutral-900 dark:focus:border-white focus:ring-1 focus:ring-neutral-900 dark:focus:ring-white outline-none transition-colors font-mono"
                  />
                  <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs font-mono text-neutral-400 dark:text-neutral-500">%</span>
                </div>
              </div>

              <!-- Down Payment ($) -->
              <div class="space-y-2">
                <label for="down-payment-cash" class="block text-xs font-mono text-neutral-400 uppercase tracking-widest">
                  Down Payment ($)
                </label>
                <div class="relative">
                  <span class="absolute left-3 top-1/2 -translate-y-1/2 text-sm text-neutral-500 font-mono">$</span>
                  <input 
                    type="number" 
                    id="down-payment-cash" 
                    min="0" 
                    step="1000" 
                    value="80000"
                    placeholder="e.g. 80000"
                    class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded-md h-11 pl-8 pr-3 text-sm text-neutral-900 dark:text-white focus:border-neutral-900 dark:focus:border-white focus:ring-1 focus:ring-neutral-900 dark:focus:ring-white outline-none transition-colors font-mono"
                  />
                </div>
              </div>

              <!-- Down Payment (%) -->
              <div class="space-y-2">
                <label for="down-payment-percent" class="block text-xs font-mono text-neutral-400 uppercase tracking-widest">
                  Down Payment (%)
                </label>
                <div class="relative">
                  <input 
                    type="number" 
                    id="down-payment-percent" 
                    min="0" 
                    max="100" 
                    step="0.5" 
                    value="20"
                    placeholder="e.g. 20"
                    class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded-md h-11 pl-3 pr-8 text-sm text-neutral-900 dark:text-white focus:border-neutral-900 dark:focus:border-white focus:ring-1 focus:ring-neutral-900 dark:focus:ring-white outline-none transition-colors font-mono"
                  />
                  <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs font-mono text-neutral-400 dark:text-neutral-500">%</span>
                </div>
              </div>

              <!-- Loan Term -->
              <div class="space-y-2">
                <label for="loan-term" class="block text-xs font-mono text-neutral-400 uppercase tracking-widest">
                  Loan Term (Years)
                </label>
                <select id="loan-term" class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded-md h-11 px-3 text-sm text-neutral-900 dark:text-white focus:border-neutral-900 dark:focus:border-white focus:ring-1 focus:ring-neutral-900 dark:focus:ring-white outline-none transition-colors cursor-pointer font-sans font-medium">
                  <option value="30">30-Year Fixed</option>
                  <option value="20">20-Year Fixed</option>
                  <option value="15">15-Year Fixed</option>
                  <option value="10">10-Year Fixed</option>
                </select>
              </div>

              <!-- Calculated Loan Amount info -->
              <div class="space-y-2">
                <span class="block text-xs font-mono text-neutral-400 uppercase tracking-widest">Loan Amount</span>
                <div class="flex items-center h-11 px-3 bg-neutral-50/50 dark:bg-neutral-900/50 border border-neutral-200/50 dark:border-neutral-800/50 rounded-md text-sm font-bold font-mono text-neutral-900 dark:text-white" id="loan-amount-display">
                  $320,000
                </div>
              </div>
            </div>
          </div>

          <!-- Extra Payments Simulator -->
          <div class="premium-glass-card rounded-xl p-6 space-y-5">
            <h2 class="text-lg font-bold text-neutral-900 dark:text-white flex items-center gap-2">
              <svg class="w-5 h-5 text-neutral-400 dark:text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
              Extra Payment Acceleration Levers
            </h2>
            <p class="text-xs text-neutral-500 leading-relaxed font-light">
              Model additional payments to understand how much compound interest you can save and how many years you can shave off the term of the mortgage.
            </p>

            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
              <!-- Monthly Extra -->
              <div class="space-y-2">
                <label for="extra-monthly" class="block text-[10px] font-mono text-neutral-400 uppercase tracking-wider">
                  Monthly Extra ($)
                </label>
                <div class="relative">
                  <span class="absolute left-2.5 top-1/2 -translate-y-1/2 text-xs text-neutral-500 font-mono">$</span>
                  <input 
                    type="number" 
                    id="extra-monthly" 
                    min="0" 
                    step="50" 
                    value="0"
                    placeholder="0"
                    class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded h-10 pl-6 pr-2 text-xs text-neutral-900 dark:text-white outline-none focus:border-neutral-900 dark:focus:border-white font-mono"
                  />
                </div>
              </div>

              <!-- Annual Extra -->
              <div class="space-y-2">
                <label for="extra-yearly" class="block text-[10px] font-mono text-neutral-400 uppercase tracking-wider">
                  Annual Extra ($)
                </label>
                <div class="relative">
                  <span class="absolute left-2.5 top-1/2 -translate-y-1/2 text-xs text-neutral-500 font-mono">$</span>
                  <input 
                    type="number" 
                    id="extra-yearly" 
                    min="0" 
                    step="500" 
                    value="0"
                    placeholder="0"
                    class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded h-10 pl-6 pr-2 text-xs text-neutral-900 dark:text-white outline-none focus:border-neutral-900 dark:focus:border-white font-mono"
                  />
                </div>
              </div>

              <!-- One-Time Extra -->
              <div class="space-y-2">
                <label for="extra-onetime" class="block text-[10px] font-mono text-neutral-400 uppercase tracking-wider">
                  One-time Extra ($)
                </label>
                <div class="relative">
                  <span class="absolute left-2.5 top-1/2 -translate-y-1/2 text-xs text-neutral-500 font-mono">$</span>
                  <input 
                    type="number" 
                    id="extra-onetime" 
                    min="0" 
                    step="1000" 
                    value="0"
                    placeholder="0"
                    class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded h-10 pl-6 pr-2 text-xs text-neutral-900 dark:text-white outline-none focus:border-neutral-900 dark:focus:border-white font-mono"
                  />
                </div>
              </div>

              <!-- One-Time Month Slider -->
              <div class="space-y-2 sm:col-span-3 pt-2">
                <div class="flex justify-between items-center text-[10px] font-mono text-neutral-400">
                  <span>Apply One-time Payment at Month</span>
                  <span class="text-neutral-900 dark:text-white font-bold" id="extra-onetime-month-display">Month 12</span>
                </div>
                <input 
                  type="range" 
                  id="extra-onetime-month" 
                  min="1" 
                  max="120" 
                  step="1" 
                  value="12" 
                  class="w-full accent-neutral-900 dark:accent-white cursor-pointer h-1.5 bg-neutral-200 dark:bg-neutral-800 rounded-lg appearance-none"
                  aria-label="Apply One-time Payment Month Slider"
                />
              </div>
            </div>
          </div>

          <!-- Escrow & PMI Expenses -->
          <div class="premium-glass-card rounded-xl p-6 space-y-5">
            <h2 class="text-lg font-bold text-neutral-900 dark:text-white flex items-center gap-2">
              <svg class="w-5 h-5 text-neutral-400 dark:text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
              Escrow Fees, Taxes &amp; PMI
            </h2>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <!-- Property Tax Rate -->
              <div class="space-y-2">
                <label for="tax-rate" class="block text-xs font-mono text-neutral-400 uppercase tracking-widest">
                  Annual Property Tax (%)
                </label>
                <div class="relative">
                  <input 
                    type="number" 
                    id="tax-rate" 
                    min="0" 
                    max="10" 
                    step="0.05" 
                    value="1.2"
                    placeholder="e.g. 1.2"
                    class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded-md h-11 pl-3 pr-8 text-sm text-neutral-900 dark:text-white focus:border-neutral-900 dark:focus:border-white focus:ring-1 focus:ring-neutral-900 dark:focus:ring-white outline-none transition-colors font-mono"
                  />
                  <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs font-mono text-neutral-400 dark:text-neutral-500">%</span>
                </div>
              </div>

              <!-- Home Insurance -->
              <div class="space-y-2">
                <label for="home-insurance" class="block text-xs font-mono text-neutral-400 uppercase tracking-widest">
                  Home Insurance ($/yr)
                </label>
                <div class="relative">
                  <span class="absolute left-3 top-1/2 -translate-y-1/2 text-sm text-neutral-500 font-mono">$</span>
                  <input 
                    type="number" 
                    id="home-insurance" 
                    min="0" 
                    step="100" 
                    value="1200"
                    placeholder="e.g. 1200"
                    class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded-md h-11 pl-8 pr-3 text-sm text-neutral-900 dark:text-white focus:border-neutral-900 dark:focus:border-white focus:ring-1 focus:ring-neutral-900 dark:focus:ring-white outline-none transition-colors font-mono"
                  />
                </div>
              </div>

              <!-- HOA Fees -->
              <div class="space-y-2">
                <label for="hoa-fees" class="block text-xs font-mono text-neutral-400 uppercase tracking-widest">
                  HOA Fees ($/mo)
                </label>
                <div class="relative">
                  <span class="absolute left-3 top-1/2 -translate-y-1/2 text-sm text-neutral-500 font-mono">$</span>
                  <input 
                    type="number" 
                    id="hoa-fees" 
                    min="0" 
                    step="10" 
                    value="0"
                    placeholder="e.g. 0"
                    class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded-md h-11 pl-8 pr-3 text-sm text-neutral-900 dark:text-white focus:border-neutral-900 dark:focus:border-white focus:ring-1 focus:ring-neutral-900 dark:focus:ring-white outline-none transition-colors font-mono"
                  />
                </div>
              </div>

              <!-- PMI Rate -->
              <div class="space-y-2">
                <label for="pmi-rate" class="block text-xs font-mono text-neutral-400 uppercase tracking-widest">
                  Annual PMI Rate (%)
                </label>
                <div class="relative">
                  <input 
                    type="number" 
                    id="pmi-rate" 
                    min="0" 
                    max="5" 
                    step="0.05" 
                    value="0.75"
                    placeholder="e.g. 0.75"
                    class="w-full bg-background border border-neutral-200 dark:border-neutral-800 rounded-md h-11 pl-3 pr-8 text-sm text-neutral-900 dark:text-white focus:border-neutral-900 dark:focus:border-white focus:ring-1 focus:ring-neutral-900 dark:focus:ring-white outline-none transition-colors font-mono"
                  />
                  <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs font-mono text-neutral-400 dark:text-neutral-500">%</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Dashboard Outputs & Visualization (Right) -->
        <div class="lg:col-span-5 space-y-6">
          
          <!-- Monthly Payment Widget -->
          <div class="premium-glass-card rounded-xl p-6 relative overflow-hidden flex flex-col justify-between border border-neutral-200 dark:border-neutral-800 shadow-sm">
            <div class="absolute top-0 right-0 -mt-6 -mr-6 w-44 h-44 blur-3xl rounded-full pointer-events-none opacity-20 bg-brand-blue"></div>

            <div class="relative z-10 space-y-5">
              <span class="text-xs font-mono uppercase tracking-widest text-neutral-500">Estimated Payment</span>
              
              <!-- Large total value -->
              <div class="space-y-1">
                <div class="flex items-baseline gap-2">
                  <span id="monthly-payment-total" class="text-5xl font-extrabold tracking-tight text-neutral-900 dark:text-white font-mono">
                    --
                  </span>
                  <span class="text-sm font-mono text-neutral-500">/ mo</span>
                </div>
                <p id="pmi-conditional-notice" class="text-[11px] text-neutral-500 font-light hidden">
                  *Includes <span id="pmi-amount-badge" class="font-semibold text-neutral-700 dark:text-neutral-300">--</span> PMI because down payment is under 20%.
                </p>
              </div>

              <!-- SVG Donut Chart breakdown -->
              <div class="flex justify-center items-center py-2 h-[150px]">
                <svg id="donut-chart" class="w-[140px] h-[140px]" viewBox="0 0 200 200">
                  <!-- Generated dynamically in JS -->
                </svg>
              </div>

              <!-- Itemized breakdown details -->
              <div class="space-y-2.5 pt-4 border-t border-neutral-200/50 dark:border-neutral-800/50 text-xs font-mono">
                <div class="flex justify-between items-center">
                  <span class="flex items-center gap-2 text-neutral-500">
                    <span class="w-2.5 h-2.5 rounded-sm bg-[#6468cb]"></span> Principal &amp; Interest
                  </span>
                  <span id="breakdown-pi" class="font-bold text-neutral-800 dark:text-neutral-200">--</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="flex items-center gap-2 text-neutral-500">
                    <span class="w-2.5 h-2.5 rounded-sm bg-[#7fcb64]"></span> Property Tax
                  </span>
                  <span id="breakdown-tax" class="font-bold text-neutral-800 dark:text-neutral-200">--</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="flex items-center gap-2 text-neutral-500">
                    <span class="w-2.5 h-2.5 rounded-sm bg-[#da6868]"></span> Home Insurance
                  </span>
                  <span id="breakdown-ins" class="font-bold text-neutral-800 dark:text-neutral-200">--</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="flex items-center gap-2 text-neutral-500">
                    <span class="w-2.5 h-2.5 rounded-sm bg-[#dacf68]"></span> HOA Fees
                  </span>
                  <span id="breakdown-hoa" class="font-bold text-neutral-800 dark:text-neutral-200">--</span>
                </div>
                <div id="breakdown-pmi-row" class="flex justify-between items-center hidden">
                  <span class="flex items-center gap-2 text-neutral-500">
                    <span class="w-2.5 h-2.5 rounded-sm bg-[#d45656]"></span> PMI (Insurance)
                  </span>
                  <span id="breakdown-pmi" class="font-bold text-neutral-800 dark:text-neutral-200">--</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Accelerated Payoff metrics badge (glows green when extra payments applied!) -->
          <div id="acceleration-badge-card" class="relative overflow-hidden rounded-xl border p-5 flex flex-col justify-between transition-all duration-300 border-neutral-200 dark:border-neutral-800 bg-neutral-50/50 dark:bg-neutral-900/10">
            <div id="acceleration-glow" class="absolute top-0 right-0 -mt-6 -mr-6 w-36 h-36 blur-3xl rounded-full pointer-events-none opacity-0 transition-opacity duration-300 bg-emerald-500"></div>
            
            <div class="relative z-10 space-y-3">
              <span class="text-[10px] font-mono uppercase tracking-wider text-neutral-400 block" id="accelerated-header">Acceleration Metrics</span>
              
              <div class="grid grid-cols-2 gap-4">
                <div class="space-y-1">
                  <span class="block text-[10px] text-neutral-400 font-mono uppercase">Interest Saved</span>
                  <span id="acceleration-savings-val" class="text-lg font-bold text-neutral-800 dark:text-neutral-200 font-mono">$0</span>
                </div>
                <div class="space-y-1">
                  <span class="block text-[10px] text-neutral-400 font-mono uppercase">Time Saved</span>
                  <span id="acceleration-time-val" class="text-lg font-bold text-neutral-800 dark:text-neutral-200 font-mono">0 Months</span>
                </div>
              </div>
              <p class="text-[11px] text-neutral-500 font-light" id="acceleration-summary">
                No extra payments active. Fill extra payment inputs to simulate financial acceleration.
              </p>
            </div>
          </div>

          <!-- Total Lifetime Loan Cost Card -->
          <div class="premium-glass-card rounded-xl p-5 space-y-4 text-xs font-mono">
            <h3 class="text-[10px] font-mono text-neutral-400 uppercase tracking-widest">Lifetime Cost Coordinates</h3>
            
            <div class="space-y-2">
              <div class="flex justify-between items-center">
                <span class="text-neutral-500">Total Interest Paid</span>
                <span id="lifetime-interest" class="font-bold text-neutral-900 dark:text-white">--</span>
              </div>
              <div class="flex justify-between items-center">
                <span class="text-neutral-500">Total Payments (Cost of Loan)</span>
                <span id="lifetime-total" class="font-bold text-neutral-900 dark:text-white">--</span>
              </div>
              <div class="flex justify-between items-center">
                <span class="text-neutral-500">Projected Payoff Date</span>
                <span id="payoff-date-val" class="font-bold text-neutral-900 dark:text-white">--</span>
              </div>
            </div>
          </div>

          <!-- Action buttons for sharing and printing -->
          <div class="premium-glass-card rounded-xl p-5 flex flex-col sm:flex-row gap-3">
            <button 
              type="button" 
              id="share-btn" 
              class="flex-1 inline-flex items-center justify-center gap-2 h-10 px-4 rounded bg-neutral-100 dark:bg-neutral-900 hover:bg-neutral-200 dark:hover:bg-neutral-800 border border-neutral-200 dark:border-neutral-800 text-xs font-semibold text-neutral-800 dark:text-neutral-200 transition-all duration-150 cursor-pointer"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.684 10.742l4.622-2.311m0 0a3 3 0 114.243 4.243l-4.622 2.311m0 0a3 3 0 11-4.243-4.243m4.622-2.311l4.622 2.311"></path>
              </svg>
              Share Calculator Setup
            </button>
            <button 
              type="button" 
              id="print-btn" 
              class="flex-1 inline-flex items-center justify-center gap-2 h-10 px-4 rounded bg-neutral-100 dark:bg-neutral-900 hover:bg-neutral-200 dark:hover:bg-neutral-800 border border-neutral-200 dark:border-neutral-800 text-xs font-semibold text-neutral-800 dark:text-neutral-200 transition-all duration-150 cursor-pointer"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path>
              </svg>
              Export Report / Print
            </button>
          </div>
        </div>
      </div>

      <!-- Amortization Schedule (Full width) -->
      <div class="grid grid-cols-1 gap-8">
        
        <!-- Interactive Amortization Card -->
        <div class="premium-glass-card rounded-xl overflow-hidden">
          <div class="p-6 border-b border-neutral-200 dark:border-neutral-800 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
            <div>
              <h2 class="text-lg font-bold text-neutral-900 dark:text-white">Loan Amortization Schedule</h2>
