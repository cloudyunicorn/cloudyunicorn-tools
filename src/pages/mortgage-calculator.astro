          <!-- FAQ Accordion -->
          <div class="max-w-4xl mx-auto divide-y divide-neutral-200 dark:divide-neutral-800 border-t border-b border-neutral-200 dark:border-neutral-800">
            
            <!-- Section 1: monthly mortgage payment components -->
            <details class="group py-5 [&_summary::-webkit-details-marker]:hidden" open>
              <summary class="flex justify-between items-center font-semibold text-sm sm:text-base text-neutral-900 dark:text-white cursor-pointer select-none">
