        <SocialShare shareText="Estimate your full monthly payments, property taxes, PMI, and extra payoff metrics with this Premium Mortgage Calculator!" />
      </div>
    </div>
  </div>

  <script is:inline>
    function initMortgageCalculator() {
      // Elements
      const homePriceInput = document.getElementById('home-price');
      const interestRateInput = document.getElementById('interest-rate');
      const downPaymentCashInput = document.getElementById('down-payment-cash');
      const downPaymentPercentInput = document.getElementById('down-payment-percent');
      const loanTermSelect = document.getElementById('loan-term');
      const loanAmountDisplay = document.getElementById('loan-amount-display');

      const extraMonthlyInput = document.getElementById('extra-monthly');
      const extraYearlyInput = document.getElementById('extra-yearly');
      const extraOnetimeInput = document.getElementById('extra-onetime');
      const extraOnetimeMonthSlider = document.getElementById('extra-onetime-month');
      const extraOnetimeMonthDisplay = document.getElementById('extra-onetime-month-display');

      const taxRateInput = document.getElementById('tax-rate');
      const homeInsuranceInput = document.getElementById('home-insurance');
      const hoaFeesInput = document.getElementById('hoa-fees');
      const pmiRateInput = document.getElementById('pmi-rate');

      const monthlyPaymentTotal = document.getElementById('monthly-payment-total');
      const pmiConditionalNotice = document.getElementById('pmi-conditional-notice');
      const pmiAmountBadge = document.getElementById('pmi-amount-badge');

      const donutChartSvg = document.getElementById('donut-chart');

      const breakdownPi = document.getElementById('breakdown-pi');
      const breakdownTax = document.getElementById('breakdown-tax');
      const breakdownIns = document.getElementById('breakdown-ins');
      const breakdownHoa = document.getElementById('breakdown-hoa');
      const breakdownPmiRow = document.getElementById('breakdown-pmi-row');
      const breakdownPmi = document.getElementById('breakdown-pmi');

      const accelerationBadgeCard = document.getElementById('acceleration-badge-card');
      const accelerationGlow = document.getElementById('acceleration-glow');
      const accelerationSavingsVal = document.getElementById('acceleration-savings-val');
      const accelerationTimeVal = document.getElementById('acceleration-time-val');
      const accelerationSummary = document.getElementById('acceleration-summary');

      const lifetimeInterest = document.getElementById('lifetime-interest');
      const lifetimeTotal = document.getElementById('lifetime-total');
      const payoffDateVal = document.getElementById('payoff-date-val');

      const tabAnnual = document.getElementById('tab-annual');
      const tabMonthly = document.getElementById('tab-monthly');
      const toggleAmortizationBtn = document.getElementById('toggle-amortization-btn');
      const amortArrowIcon = document.getElementById('amort-arrow-icon');
      const amortizationTableContainer = document.getElementById('amortization-table-container');
      const amortizationTableBody = document.getElementById('amortization-table-body');

      const shareBtn = document.getElementById('share-btn');
      const printBtn = document.getElementById('print-btn');

      // State
      let amortizationView = 'annual'; // 'annual' or 'monthly'
      let isAmortizationCollapsed = false;

      // Synchronization variables to avoid recursive input loops
      let synchronizingDownPayment = false;

      // Preset load parameters
      function parseUrlState() {
        const hash = window.location.hash || window.location.search;
        if (!hash) return;

        try {
          const params = new URLSearchParams(hash.substring(1));
          const stateData = params.get('state');
          if (!stateData) return;

          const decoded = JSON.parse(atob(stateData));
          if (decoded.price !== undefined) homePriceInput.value = decoded.price;
          if (decoded.rate !== undefined) interestRateInput.value = decoded.rate;
          if (decoded.dpCash !== undefined) downPaymentCashInput.value = decoded.dpCash;
          if (decoded.term !== undefined) loanTermSelect.value = decoded.term;
          if (decoded.tax !== undefined) taxRateInput.value = decoded.tax;
          if (decoded.ins !== undefined) homeInsuranceInput.value = decoded.ins;
          if (decoded.hoa !== undefined) hoaFeesInput.value = decoded.hoa;
          if (decoded.pmiRate !== undefined) pmiRateInput.value = decoded.pmiRate;
          if (decoded.exMo !== undefined) extraMonthlyInput.value = decoded.exMo;
          if (decoded.exYr !== undefined) extraYearlyInput.value = decoded.exYr;
          if (decoded.exOne !== undefined) extraOnetimeInput.value = decoded.exOne;
          if (decoded.exOneMo !== undefined) {
            extraOnetimeMonthSlider.value = decoded.exOneMo;
            extraOnetimeMonthDisplay.textContent = `Month ${decoded.exOneMo}`;
          }

          // Sync down payment percentage
          const price = parseFloat(decoded.price) || 0;
          const cash = parseFloat(decoded.dpCash) || 0;
          if (price > 0) {
            downPaymentPercentInput.value = ((cash / price) * 100).toFixed(2);
          }
        } catch (e) {
          console.error('Error parsing mortgage calculator parameters', e);
        }
      }

      // Format currency utility
      function formatCurrency(val) {
        return '$' + Math.round(val).toLocaleString('en-US');
      }

      // Input Synchronization: Down Payment percentage vs dollar cash
      homePriceInput.addEventListener('input', () => {
        if (synchronizingDownPayment) return;
        synchronizingDownPayment = true;
        const price = parseFloat(homePriceInput.value) || 0;
        const pct = parseFloat(downPaymentPercentInput.value) || 0;
        const cashValue = (price * pct) / 100;
        downPaymentCashInput.value = Math.round(cashValue);
        synchronizingDownPayment = false;
        calculateMortgage();
      });

      downPaymentCashInput.addEventListener('input', () => {
        if (synchronizingDownPayment) return;
        synchronizingDownPayment = true;
        const price = parseFloat(homePriceInput.value) || 0;
        const cash = parseFloat(downPaymentCashInput.value) || 0;
        if (price > 0) {
          downPaymentPercentInput.value = ((cash / price) * 100).toFixed(2);
        } else {
          downPaymentPercentInput.value = 0;
        }
        synchronizingDownPayment = false;
        calculateMortgage();
      });

      downPaymentPercentInput.addEventListener('input', () => {
        if (synchronizingDownPayment) return;
        synchronizingDownPayment = true;
        const price = parseFloat(homePriceInput.value) || 0;
        const pct = parseFloat(downPaymentPercentInput.value) || 0;
        const cashValue = (price * pct) / 100;
        downPaymentCashInput.value = Math.round(cashValue);
        synchronizingDownPayment = false;
        calculateMortgage();
      });

      extraOnetimeMonthSlider.addEventListener('input', (e) => {
        extraOnetimeMonthDisplay.textContent = `Month ${e.target.value}`;
        calculateMortgage();
      });

      // Recalculate triggers
      [interestRateInput, loanTermSelect, extraMonthlyInput, extraYearlyInput, extraOnetimeInput, taxRateInput, homeInsuranceInput, hoaFeesInput, pmiRateInput].forEach(el => {
        el.addEventListener('input', calculateMortgage);
      });

      // Tabs annual vs monthly toggle
      tabAnnual.addEventListener('click', () => {
        tabAnnual.setAttribute('aria-selected', 'true');
        tabMonthly.setAttribute('aria-selected', 'false');
        amortizationView = 'annual';
        calculateMortgage();
      });

      tabMonthly.addEventListener('click', () => {
        tabAnnual.setAttribute('aria-selected', 'false');
        tabMonthly.setAttribute('aria-selected', 'true');
        amortizationView = 'monthly';
        calculateMortgage();
      });

      // Expand/Collapse table
      toggleAmortizationBtn.addEventListener('click', () => {
        isAmortizationCollapsed = !isAmortizationCollapsed;
        if (isAmortizationCollapsed) {
          amortizationTableContainer.classList.add('hidden');
          amortArrowIcon.classList.remove('rotate-180');
        } else {
          amortizationTableContainer.classList.remove('hidden');
          amortArrowIcon.classList.add('rotate-180');
        }
      });

      // Mortgage calculation simulation
      function calculateMortgage() {
        const price = parseFloat(homePriceInput.value) || 0;
        const interestRate = (parseFloat(interestRateInput.value) || 0) / 100;
        const downPayment = parseFloat(downPaymentCashInput.value) || 0;
        const loanYears = parseInt(loanTermSelect.value) || 30;
        
        const taxRate = (parseFloat(taxRateInput.value) || 0) / 100;
        const yearlyInsurance = parseFloat(homeInsuranceInput.value) || 0;
        const monthlyHoa = parseFloat(hoaFeesInput.value) || 0;
        const annualPmiRate = (parseFloat(pmiRateInput.value) || 0) / 100;

        const extraMonthly = parseFloat(extraMonthlyInput.value) || 0;
        const extraYearly = parseFloat(extraYearlyInput.value) || 0;
        const extraOnetime = parseFloat(extraOnetimeInput.value) || 0;
        const extraOnetimeMonth = parseInt(extraOnetimeMonthSlider.value) || 12;

        const loanAmount = Math.max(0, price - downPayment);
        loanAmountDisplay.textContent = formatCurrency(loanAmount);

        // Standard Principal & Interest
        const monthlyRate = interestRate / 12;
        const numMonths = loanYears * 12;
        
        let piPayment = 0;
        if (loanAmount > 0) {
          if (monthlyRate === 0) {
            piPayment = loanAmount / numMonths;
          } else {
            piPayment = loanAmount * (monthlyRate * Math.pow(1 + monthlyRate, numMonths)) / (Math.pow(1 + monthlyRate, numMonths) - 1);
          }
        }

        // Monthly Tax & Ins
        const monthlyTax = (price * taxRate) / 12;
        const monthlyInsurance = yearlyInsurance / 12;

        // PMI - applies initial monthly if down payment < 20% home price
        const initialPmiRequirement = downPayment < (price * 0.20);
        const monthlyPmi = initialPmiRequirement ? (loanAmount * annualPmiRate) / 12 : 0;

        // Standard payment total
        const monthlyTotal = piPayment + monthlyTax + monthlyInsurance + monthlyHoa + monthlyPmi;
        monthlyPaymentTotal.textContent = formatCurrency(monthlyTotal);

        if (initialPmiRequirement && monthlyPmi > 0) {
          pmiConditionalNotice.classList.remove('hidden');
          pmiAmountBadge.textContent = formatCurrency(monthlyPmi);
        } else {
          pmiConditionalNotice.classList.add('hidden');
        }

        // Update Breakdown list
        breakdownPi.textContent = formatCurrency(piPayment);
        breakdownTax.textContent = formatCurrency(monthlyTax);
        breakdownIns.textContent = formatCurrency(monthlyInsurance);
        breakdownHoa.textContent = formatCurrency(monthlyHoa);

        if (monthlyPmi > 0) {
          breakdownPmiRow.classList.remove('hidden');
          breakdownPmi.textContent = formatCurrency(monthlyPmi);
        } else {
          breakdownPmiRow.classList.add('hidden');
        }

        // Draw Donut Chart SVG
        renderDonutChart(piPayment, monthlyTax, monthlyInsurance, monthlyHoa, monthlyPmi);

        // RUN SCHEDULE SIMULATIONS (Baseline vs. Accelerated)
        const baselineSim = runSimulation(loanAmount, numMonths, monthlyRate, piPayment, price, annualPmiRate, monthlyTax, monthlyInsurance, monthlyHoa, 0, 0, 0, 0);
        const acceleratedSim = runSimulation(loanAmount, numMonths, monthlyRate, piPayment, price, annualPmiRate, monthlyTax, monthlyInsurance, monthlyHoa, extraMonthly, extraYearly, extraOnetime, extraOnetimeMonth);

        // Lifetime cost calculations based on baseline
        lifetimeInterest.textContent = formatCurrency(baselineSim.totalInterest);
        lifetimeTotal.textContent = formatCurrency(baselineSim.totalCost + downPayment);

        // Accelerated summary badge card
        const timeSavedMonths = Math.max(0, baselineSim.payoffMonths - acceleratedSim.payoffMonths);
        const interestSavings = Math.max(0, baselineSim.totalInterest - acceleratedSim.totalInterest);

        if (timeSavedMonths > 0 || interestSavings > 0) {
          accelerationBadgeCard.classList.add('border-emerald-200', 'dark:border-emerald-800/80', 'bg-emerald-50/10', 'dark:bg-emerald-950/5');
          accelerationGlow.classList.remove('opacity-0');
          accelerationGlow.classList.add('opacity-20');

          accelerationSavingsVal.textContent = formatCurrency(interestSavings);
          
          if (timeSavedMonths >= 12) {
            const yrs = Math.floor(timeSavedMonths / 12);
            const mos = Math.round(timeSavedMonths % 12);
            accelerationTimeVal.textContent = `${yrs} yr${yrs === 1 ? '' : 's'}${mos > 0 ? ` ${mos} mo` : ''}`;
          } else {
            accelerationTimeVal.textContent = `${Math.round(timeSavedMonths)} Mos`;
          }

          const payoffYearsSaved = (timeSavedMonths / 12).toFixed(1);
          accelerationSummary.textContent = `Accelerated payments reduce your home term by ${payoffYearsSaved} years. Savings of ${formatCurrency(interestSavings)} in interest compound returns.`;
        } else {
          accelerationBadgeCard.classList.remove('border-emerald-200', 'dark:border-emerald-800/80', 'bg-emerald-50/10', 'dark:bg-emerald-950/5');
          accelerationGlow.classList.add('opacity-0');
          accelerationGlow.classList.remove('opacity-20');

          accelerationSavingsVal.textContent = '$0';
          accelerationTimeVal.textContent = '0 Months';
          accelerationSummary.textContent = 'No extra payments active. Fill extra payment inputs to simulate financial acceleration.';
        }

        // Project Payoff Date String (using baseline or accelerated payoff months)
        const date = new Date();
        const activePayoffMonths = acceleratedSim.payoffMonths;
        date.setMonth(date.getMonth() + activePayoffMonths);
        
        const formatter = new Intl.DateTimeFormat('en-US', { month: 'long', year: 'numeric' });
        payoffDateVal.textContent = formatter.format(date) + ` (${activePayoffMonths} mos)`;

        // Render selected amortization table
        renderAmortizationTable(acceleratedSim.schedule, amortizationView);
      }

      // Core month-by-month financial projection loop
      function runSimulation(loanAmt, totalMonths, monthlyRate, scheduledPi, homePrice, pmiRate, tax, insurance, hoa, exMo, exYr, exOne, exOneMonth) {
        let balance = loanAmt;
        const schedule = [];
        let totalInterest = 0;
        let totalCost = 0;
        let pmiThreshold = homePrice * 0.80;
        let payoffMonths = 0;

        for (let m = 1; m <= totalMonths; m++) {
          if (balance <= 0) break;

          payoffMonths = m;
          const interestPortion = balance * monthlyRate;
          let principalPortion = scheduledPi - interestPortion;
          
          if (principalPortion < 0) principalPortion = 0;

          // Determine monthly PMI eligibility (applies if balance > 80% original value)
          const pmiActive = balance > pmiThreshold && pmiRate > 0;
          const activePmi = pmiActive ? (loanAmt * pmiRate) / 12 : 0;

          // Process extra payments
          let extraPaymentApplied = 0;
          extraPaymentApplied += exMo; // Monthly
          if (m % 12 === 0) extraPaymentApplied += exYr; // Annual
          if (m === exOneMonth) extraPaymentApplied += exOne; // One-time

          let totalPrincipalToPay = principalPortion + extraPaymentApplied;

          // Caps payoff to prevent negative balances
          if (totalPrincipalToPay > balance) {
            totalPrincipalToPay = balance;
            extraPaymentApplied = Math.max(0, balance - principalPortion);
          }

          balance -= totalPrincipalToPay;
          totalInterest += interestPortion;
          
          const escrowFees = tax + insurance + hoa + activePmi;
          totalCost += (scheduledPi + escrowFees + extraPaymentApplied);

          schedule.push({
            month: m,
            startBalance: balance + totalPrincipalToPay,
            principal: totalPrincipalToPay - extraPaymentApplied,
            interest: interestPortion,
            escrow: escrowFees,
            extra: extraPaymentApplied,
            endBalance: balance
          });
        }

        return {
          totalInterest,
          totalCost,
          payoffMonths,
          schedule
        };
      }

      // Draw SVG donut chart using circle stroke dash offsets
      function renderDonutChart(pi, tax, ins, hoa, pmi) {
        donutChartSvg.innerHTML = '';
        
        const values = [pi, tax, ins, hoa, pmi];
        const colors = ['#6468cb', '#7fcb64', '#da6868', '#dacf68', '#d45656'];
        const total = values.reduce((a, b) => a + b, 0);

        if (total === 0) return;

        const radius = 70;
        const circumference = 2 * Math.PI * radius; // ~439.82
        let accumulatedPercent = 0;

        values.forEach((val, idx) => {
          if (val <= 0) return;

          const pct = val / total;
          const strokeLength = pct * circumference;
          const strokeOffset = circumference - strokeLength + (accumulatedPercent * circumference);

          const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
          circle.setAttribute('cx', '100');
          circle.setAttribute('cy', '100');
          circle.setAttribute('r', String(radius));
          circle.setAttribute('fill', 'transparent');
          circle.setAttribute('stroke', colors[idx]);
          circle.setAttribute('stroke-width', '18');
          circle.setAttribute('stroke-dasharray', `${strokeLength} ${circumference - strokeLength}`);
          circle.setAttribute('stroke-dashoffset', String(-accumulatedPercent * circumference));
          circle.setAttribute('transform', 'rotate(-90 100 100)');
          circle.setAttribute('class', 'transition-all duration-300 hover:stroke-[22]');
          
          donutChartSvg.appendChild(circle);
          accumulatedPercent += pct;
        });

        // Add inner label for donut hole (Total payment)
        const textVal = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        textVal.setAttribute('x', '100');
        textVal.setAttribute('y', '98');
        textVal.setAttribute('text-anchor', 'middle');
        textVal.setAttribute('class', 'fill-neutral-900 dark:fill-white font-mono font-bold text-[18px]');
        textVal.textContent = formatCurrency(total);
        donutChartSvg.appendChild(textVal);

        const textSub = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        textSub.setAttribute('x', '100');
        textSub.setAttribute('y', '115');
        textSub.setAttribute('text-anchor', 'middle');
        textSub.setAttribute('class', 'fill-neutral-400 dark:fill-neutral-500 font-sans text-[10px] tracking-wide uppercase font-medium');
        textSub.textContent = 'Total Monthly';
        donutChartSvg.appendChild(textSub);
      }

      // Render table rows in amortization container
      function renderAmortizationTable(schedule, mode) {
        amortizationTableBody.innerHTML = '';

        if (mode === 'annual') {
          // Group by 12 month sets
          let yearsList = [];
          let currentYr = 1;
          let yrStart = 0;
          let yrPrincipal = 0;
          let yrInterest = 0;
          let yrEscrow = 0;
          let yrExtra = 0;

          schedule.forEach((m, idx) => {
            if (idx === 0 || m.month % 12 === 1) {
              yrStart = m.startBalance;
            }

            yrPrincipal += m.principal;
            yrInterest += m.interest;
            yrEscrow += m.escrow;
            yrExtra += m.extra;

            if (m.month % 12 === 0 || idx === schedule.length - 1) {
              yearsList.push({
                period: `Year ${currentYr}`,
                startBalance: yrStart,
                principal: yrPrincipal,
                interest: yrInterest,
                escrow: yrEscrow,
                extra: yrExtra,
                endBalance: m.endBalance
              });
              
              // reset
              currentYr++;
              yrPrincipal = 0;
              yrInterest = 0;
              yrEscrow = 0;
              yrExtra = 0;
            }
          });

          yearsList.forEach(y => {
            const row = document.createElement('tr');
            row.className = 'border-b border-neutral-200/40 dark:border-neutral-800/40 hover:bg-neutral-50/40 dark:hover:bg-[#0c0c0e]/30 transition-colors text-xs text-neutral-800 dark:text-neutral-200';
            row.innerHTML = `
              <td class="py-3 px-4 font-semibold text-neutral-500">${y.period}</td>
              <td class="py-3 px-4 text-right">${formatCurrency(y.startBalance)}</td>
              <td class="py-3 px-4 text-right">${formatCurrency(y.principal)}</td>
              <td class="py-3 px-4 text-right text-red-600 dark:text-red-400">${formatCurrency(y.interest)}</td>
              <td class="py-3 px-4 text-right">${formatCurrency(y.escrow)}</td>
              <td class="py-3 px-4 text-right text-emerald-600 dark:text-emerald-400">${y.extra > 0 ? formatCurrency(y.extra) : '-'}</td>
              <td class="py-3 px-4 text-right font-semibold">${formatCurrency(y.endBalance)}</td>
            `;
            amortizationTableBody.appendChild(row);
          });

        } else {
          // Render raw monthly detail (limit render if extremely massive, but 360 is perfectly fine for browser runtime)
          schedule.forEach(m => {
            const row = document.createElement('tr');
            row.className = 'border-b border-neutral-200/40 dark:border-neutral-800/40 hover:bg-neutral-50/40 dark:hover:bg-[#0c0c0e]/30 transition-colors text-xs text-neutral-800 dark:text-neutral-200';
            row.innerHTML = `
              <td class="py-3 px-4 font-semibold text-neutral-500">Month ${m.month}</td>
              <td class="py-3 px-4 text-right">${formatCurrency(m.startBalance)}</td>
              <td class="py-3 px-4 text-right">${formatCurrency(m.principal)}</td>
              <td class="py-3 px-4 text-right text-red-600 dark:text-red-400">${formatCurrency(m.interest)}</td>
              <td class="py-3 px-4 text-right">${formatCurrency(m.escrow)}</td>
              <td class="py-3 px-4 text-right text-emerald-600 dark:text-emerald-400">${m.extra > 0 ? formatCurrency(m.extra) : '-'}</td>
              <td class="py-3 px-4 text-right font-semibold">${formatCurrency(m.endBalance)}</td>
            `;
            amortizationTableBody.appendChild(row);
          });
        }
      }

      // Share configuration copier
      shareBtn.addEventListener('click', () => {
        const state = {
          price: parseFloat(homePriceInput.value) || 0,
          rate: parseFloat(interestRateInput.value) || 0,
          dpCash: parseFloat(downPaymentCashInput.value) || 0,
          term: loanTermSelect.value,
          tax: parseFloat(taxRateInput.value) || 0,
          ins: parseFloat(homeInsuranceInput.value) || 0,
          hoa: parseFloat(hoaFeesInput.value) || 0,
          pmiRate: parseFloat(pmiRateInput.value) || 0,
          exMo: parseFloat(extraMonthlyInput.value) || 0,
          exYr: parseFloat(extraYearlyInput.value) || 0,
          exOne: parseFloat(extraOnetimeInput.value) || 0,
          exOneMo: parseInt(extraOnetimeMonthSlider.value) || 12
        };

        const base64State = btoa(JSON.stringify(state));
        const shareUrl = `${window.location.origin}${window.location.pathname}?state=${base64State}`;

        navigator.clipboard.writeText(shareUrl).then(() => {
          const origText = shareBtn.innerHTML;
          shareBtn.innerHTML = `
            <svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            Setup Copied!
          `;
          setTimeout(() => {
            shareBtn.innerHTML = origText;
          }, 2000);
        }).catch(err => {
          console.error('Failed to copy share link', err);
          alert('Could not copy share URL. Here it is: ' + shareUrl);
        });
      });

      // Print button handler
      printBtn.addEventListener('click', () => {
        window.print();
      });

      // Init flow execution
      parseUrlState();
      calculateMortgage();
    }

    // Register loader hooks
    document.addEventListener('astro:page-load', initMortgageCalculator);
  </script>

