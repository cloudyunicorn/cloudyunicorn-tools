---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const pathname = new URL(Astro.request.url).pathname;

const mobileLinks = [
  { href: '/', label: 'Home' },
  { href: '/age-calculator', label: 'Age Calculator' },
  { href: '/bmi-calculator', label: 'BMI Calculator' },
  { href: '/calories-calculator', label: 'Calories Calculator' },
];
---

<!DOCTYPE html>
<html lang="en" class="dark selection:bg-neutral-800 selection:text-white antialiased">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} — CloudyUnicorn Tools</title>
    <meta name="description" content={description} />
    
    <!-- Google Fonts: Inter & Geist Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Geist+Mono:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Open Graph / SEO -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.cloudyunicorn.com/" />
    <meta property="og:title" content={`${title} — CloudyUnicorn Tools`} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="CloudyUnicorn Tools" />
    <ClientRouter />
    <script is:inline>
      // Force dark mode on Swaps
      document.documentElement.classList.add('dark');
      document.addEventListener('astro:after-swap', () => {
        document.documentElement.classList.add('dark');
      });

      if (window.hasLoadedSplash) {
        document.documentElement.classList.add('splash-loaded');
      }
    </script>
    <style is:global>
      .splash-loaded #initial-splash-loader {
        display: none !important;
      }
    </style>
  </head>
  <body class="bg-background text-foreground min-h-screen flex flex-col font-sans transition-colors duration-300">
    <!-- Initial Splash Loader (identical to Softryt) -->
    <div
      id="initial-splash-loader"
      class="fixed inset-0 z-[10000] flex flex-col items-center justify-center bg-[#0a0a0f] transition-all duration-700 ease-in-out"
    >
      <div class="absolute inset-0 bg-hero-glow opacity-50 pointer-events-none"></div>

      <div class="relative z-10 flex flex-col items-center gap-6">
        <div class="relative flex items-center justify-center w-24 h-24">
          <div class="absolute inset-0 rounded-full bg-gradient-to-tr from-brand-blue via-brand-red to-brand-green opacity-40 blur-xl animate-pulse"></div>
          <img
            src="/logo.png"
            alt="Cloudy Unicorn Logo"
            class="w-18 h-18 object-contain drop-shadow-[0_0_15px_rgba(100,104,203,0.5)] animate-bounce duration-[2500ms]"
          />
        </div>

        <div class="text-2xl font-bold tracking-tight text-white flex flex-col items-center gap-2">
          <span>
            cloudyunicorn{" "}
            <span class="animate-text-gradient">
              tools
            </span>
          </span>
        </div>

        <!-- Custom premium color-wheel spinner -->
        <div class="relative w-10 h-10 mt-4" aria-live="polite" aria-label="Loading…">
          <div class="absolute inset-0 rounded-full border-2 border-white/5"></div>
          <div class="absolute inset-0 rounded-full border-2 border-t-brand-blue border-r-brand-red border-b-brand-green border-l-brand-yellow animate-spin duration-1000"></div>
        </div>
      </div>
    </div>

    <!-- Skip link for accessibility -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-white text-black px-4 py-2 rounded-md font-medium z-50">
      Skip to content
    </a>

    <!-- Sticky Vercel/Softryt floating Navigation Header -->
    <header
      class="fixed top-0 left-0 z-50 w-full px-4 sm:px-6 lg:px-8 pt-4 pb-2 bg-transparent pointer-events-none"
    >
      <div class="max-w-7xl mx-auto flex h-14 items-center justify-between px-6 bg-white/75 dark:bg-neutral-950/70 backdrop-blur-xl border border-neutral-200 dark:border-neutral-800/80 rounded-full shadow-lg shadow-neutral-100/10 dark:shadow-black/20 pointer-events-auto transition-colors duration-300">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 group">
          <div class="flex items-center justify-center w-8 h-8 transition-transform group-hover:scale-105">
            <img src="/logo.png" alt="Cloudy Unicorn Logo" class="w-full h-full object-contain drop-shadow-md" />
          </div>
          <span class="text-xl font-bold tracking-tight text-neutral-900 dark:text-white select-none">
            cloudyunicorn <span class="bg-gradient-to-r from-brand-blue via-brand-red to-brand-green bg-clip-text text-transparent">tools</span>
          </span>
        </a>

        <!-- Right Side items (All Tools dropdown, mobile burger) -->
        <div class="flex items-center gap-2.5 sm:gap-4">
          <!-- All Tools Dropdown Pill (desktop only) -->
          <div class="hidden md:block relative" id="all-tools-dropdown-container">
            <button
              type="button"
              id="all-tools-dropdown-btn"
              class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-neutral-200 dark:border-neutral-800 bg-neutral-50/50 dark:bg-neutral-900/50 text-xs font-semibold text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white hover:bg-neutral-100 dark:hover:bg-neutral-900 hover:border-neutral-300 dark:hover:border-neutral-700 transition-all duration-300 cursor-pointer outline-none focus-visible:ring-1 focus-visible:ring-white"
              aria-expanded="false"
              aria-haspopup="true"
            >
              <span>All Tools</span>
              <svg class="w-3.5 h-3.5 text-neutral-400 dark:text-neutral-500 transition-transform duration-300" id="all-tools-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>
            
            <!-- Dropdown Menu -->
            <div
              id="all-tools-dropdown-menu"
              class="hidden absolute right-0 top-full mt-2 w-[180px] z-50 animate-in fade-in slide-in-from-top-2 duration-150 origin-top-right"
            >
              <div class="bg-white/95 dark:bg-neutral-950/95 backdrop-blur-2xl border border-neutral-200 dark:border-neutral-800 shadow-xl rounded-xl p-1.5 flex flex-col gap-1">
                <a href="/age-calculator" class="px-3 py-2 text-xs font-semibold text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white hover:bg-neutral-100 dark:hover:bg-neutral-900 rounded-lg transition-colors">Age Calculator</a>
                <a href="/bmi-calculator" class="px-3 py-2 text-xs font-semibold text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white hover:bg-neutral-100 dark:hover:bg-neutral-900 rounded-lg transition-colors">BMI Calculator</a>
                <a href="/calories-calculator" class="px-3 py-2 text-xs font-semibold text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white hover:bg-neutral-100 dark:hover:bg-neutral-900 rounded-lg transition-colors">Calories Calculator</a>
              </div>
            </div>
          </div>

          <!-- Mobile Nav Toggle button (Explore pill matching softryt) -->
          <div class="md:hidden relative flex items-center" id="mobile-menu-container">
            <button
              type="button"
              id="mobile-nav-toggle"
              class="inline-flex items-center justify-center w-9 h-9 rounded-full border border-neutral-200 dark:border-neutral-800 bg-neutral-50/50 dark:bg-neutral-900/50 text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white hover:bg-neutral-100 dark:hover:bg-neutral-900 hover:border-neutral-300 dark:hover:border-neutral-700 transition-all duration-300 cursor-pointer outline-none focus-visible:ring-1 focus-visible:ring-white"
              aria-expanded="false"
              aria-controls="mobile-nav-menu"
            >
              <div class="w-4.5 h-3 flex flex-col justify-between relative" id="hamburger-bars">
                <span class="h-0.5 w-full bg-brand-blue rounded-full transition-all duration-300 origin-center"></span>
                <span class="h-0.5 w-full bg-brand-red rounded-full transition-all duration-300"></span>
                <span class="h-0.5 w-full bg-brand-green rounded-full transition-all duration-300 origin-center"></span>
              </div>
              <span class="sr-only">Toggle menu</span>
            </button>
            
            <!-- Floating Mobile Dropdown Menu -->
            <div
              id="mobile-nav-menu"
              class="hidden absolute right-0 top-full mt-3 w-[220px] z-50 animate-in fade-in slide-in-from-top-3 zoom-in-95 duration-200 origin-top-right"
            >
              <div class="bg-white/95 dark:bg-neutral-950/95 backdrop-blur-2xl border border-neutral-200 dark:border-neutral-800 shadow-xl rounded-2xl p-2.5 flex flex-col gap-1.5">
                {mobileLinks.map((link) => {
                  const isActive = pathname === link.href;
                  return (
                    <a
                      href={link.href}
                      class={`px-4 py-2.5 text-xs font-semibold uppercase tracking-wider transition-all rounded-xl text-center border ${
                        isActive
                          ? "bg-neutral-100 dark:bg-neutral-900 text-neutral-900 dark:text-white border-neutral-200 dark:border-neutral-800 font-bold"
                          : "text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white hover:bg-neutral-100/50 dark:hover:bg-neutral-900/50 border-transparent"
                      }`}
                    >
                      {link.label}
                    </a>
                  );
                })}
              </div>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- Main Content Area -->
    <main id="main-content" class="flex-grow">
      <slot />
    </main>

    <!-- Vercel-style Footer -->
    <footer class="border-t border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-[#070707] py-12 mt-auto transition-colors duration-300">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
          <div class="md:col-span-2 space-y-4">
            <div class="flex items-center gap-2 text-neutral-900 dark:text-white font-semibold">
              <img 
                src="/logo.png" 
                alt="CloudyUnicorn Logo" 
                width="20" 
                height="20" 
                class="w-5 h-5 rounded object-contain" 
              />
              <span>cloudyunicorn tools</span>
            </div>
            <p class="text-sm text-neutral-600 dark:text-neutral-400 max-w-sm">
              A premium suite of clean, developer-grade online calculators. Built with high precision, speed, and Vercel-inspired minimalism.
            </p>
          </div>
          <div>
            <h3 class="text-xs font-mono text-neutral-400 dark:text-neutral-500 uppercase tracking-widest mb-3">Tools</h3>
            <ul class="space-y-2 text-sm">
              <li><a href="/age-calculator" class="text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white transition-colors duration-150">Age Calculator</a></li>
              <li><a href="/bmi-calculator" class="text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white transition-colors duration-150">BMI Calculator</a></li>
              <li><a href="/calories-calculator" class="text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white transition-colors duration-150">Calories Calculator</a></li>
            </ul>
          </div>
          <div>
            <h3 class="text-xs font-mono text-neutral-400 dark:text-neutral-500 uppercase tracking-widest mb-3">Platform</h3>
            <ul class="space-y-2 text-sm">
              <li><a href="/" class="text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white transition-colors duration-150 font-semibold text-glow">cloudyunicorn.com</a></li>
              <li class="text-neutral-500 dark:text-neutral-500">More tools coming soon…</li>
            </ul>
          </div>
        </div>
        <div class="mt-8 pt-8 border-t border-neutral-200 dark:border-neutral-900 flex flex-col sm:flex-row items-center justify-between gap-4">
          <p class="text-xs text-neutral-500 font-mono">
            &copy; {new Date().getFullYear()} cloudyunicorn. All rights reserved.
          </p>
          <div class="flex gap-4 text-xs font-mono text-neutral-500 dark:text-neutral-500">
            <a href="#" class="hover:text-neutral-900 dark:hover:text-white">Privacy Policy</a>
            <span>&middot;</span>
            <a href="#" class="hover:text-neutral-900 dark:hover:text-white">Terms of Service</a>
          </div>
        </div>
      </div>
    </footer>

    <script>
      function initLayout() {
        // Theme Toggle Button (Removed)

        // Navigation Menu Toggle (Mobile Pill Dropdown)
        const menuContainer = document.getElementById('mobile-menu-container');
        const btn = document.getElementById('mobile-nav-toggle') as HTMLButtonElement;
        const menu = document.getElementById('mobile-nav-menu') as HTMLDivElement;
        const bars = document.querySelectorAll('#hamburger-bars span');

        if (btn && menu) {
          btn.addEventListener('click', (e) => {
            e.stopPropagation();
            const expanded = btn.getAttribute('aria-expanded') === 'true';
            btn.setAttribute('aria-expanded', String(!expanded));
            menu.classList.toggle('hidden');

            // Toggle Hamburger Transformation Animation (Softryt style)
            if (!expanded) {
              // Transform to X
              bars[0].className = 'h-0.5 w-full bg-brand-blue rounded-full transition-all duration-300 rotate-45 absolute top-[5px] left-0';
              bars[1].className = 'h-0.5 w-full bg-brand-red rounded-full transition-all duration-300 opacity-0';
              bars[2].className = 'h-0.5 w-full bg-brand-green rounded-full transition-all duration-300 -rotate-45 absolute top-[5px] left-0';
            } else {
              // Transform back to Hamburger
              bars[0].className = 'h-0.5 w-full bg-brand-blue rounded-full transition-all duration-300 origin-center';
              bars[1].className = 'h-0.5 w-full bg-brand-red rounded-full transition-all duration-300';
              bars[2].className = 'h-0.5 w-full bg-brand-green rounded-full transition-all duration-300 origin-center';
            }
          });

          // Close on click outside
          document.addEventListener('click', (e) => {
            if (menuContainer && !menuContainer.contains(e.target as Node)) {
              btn.setAttribute('aria-expanded', 'false');
              menu.classList.add('hidden');
              bars[0].className = 'h-0.5 w-full bg-brand-blue rounded-full transition-all duration-300 origin-center';
              bars[1].className = 'h-0.5 w-full bg-brand-red rounded-full transition-all duration-300';
              bars[2].className = 'h-0.5 w-full bg-brand-green rounded-full transition-all duration-300 origin-center';
            }
          });
        }

        // All Tools Dropdown Toggle (Desktop Only)
        const allToolsContainer = document.getElementById('all-tools-dropdown-container');
        const allToolsBtn = document.getElementById('all-tools-dropdown-btn') as HTMLButtonElement;
        const allToolsMenu = document.getElementById('all-tools-dropdown-menu') as HTMLDivElement;
        const allToolsChevron = document.getElementById('all-tools-chevron') as HTMLElement;

        if (allToolsBtn && allToolsMenu && allToolsChevron) {
          allToolsBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            const expanded = allToolsBtn.getAttribute('aria-expanded') === 'true';
            allToolsBtn.setAttribute('aria-expanded', String(!expanded));
            allToolsMenu.classList.toggle('hidden');
            
            if (!expanded) {
              allToolsChevron.classList.add('rotate-180');
            } else {
              allToolsChevron.classList.remove('rotate-180');
            }
          });

          // Close on click outside
          document.addEventListener('click', (e) => {
            if (allToolsContainer && !allToolsContainer.contains(e.target as Node)) {
              allToolsBtn.setAttribute('aria-expanded', 'false');
              allToolsMenu.classList.add('hidden');
              allToolsChevron.classList.remove('rotate-180');
            }
          });
        }

        // Initial Splash Loader fadeout (Softryt transition logic)
        const splash = document.getElementById('initial-splash-loader');
        if (splash) {
          if ((window as any).hasLoadedSplash) {
            splash.remove();
          } else {
            setTimeout(() => {
              splash.classList.add('opacity-0', 'pointer-events-none', 'scale-98');
              setTimeout(() => {
                splash.remove();
                (window as any).hasLoadedSplash = true;
              }, 700); // 700ms transition time
            }, 450); // 450ms initial delay
          }
        }
      }

      // Initialize on page load (including view transition loads)
      document.addEventListener('astro:page-load', initLayout);

      // Force splash loaded class on html after swap
      document.addEventListener('astro:after-swap', () => {
        if ((window as any).hasLoadedSplash) {
          document.documentElement.classList.add('splash-loaded');
        }
      });
    </script>
  </body>
</html>
